{{ 'trg-about.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign trg_brand_count = 0
  if shop.metaobjects.brand != blank
    assign trg_brand_count = shop.metaobjects.brand.values_count
  endif
  if trg_brand_count <= 0
    assign trg_brand_count = 400
  endif
-%}

{%- comment -%} ─── HERO ─── {%- endcomment -%}
<section class="trg-ab-hero">
  <div class="trg-ab-hero__inner">
    <div class="trg-ab-hero__eyebrow">Our Approach</div>
    <h1 class="trg-ab-hero__title">Built for the guy who <em>already knows</em> what he wants</h1>
    <p class="trg-ab-hero__lead">A menswear directory for quality-conscious buyers. No activewear. No fast fashion. No sponsored placements.</p>
    <div class="trg-ab-hero__rule">
      <div class="trg-ab-hero__stat">
        <div class="trg-ab-hero__stat-val">{{ trg_brand_count }}<span>+</span></div>
        <div class="trg-ab-hero__stat-lbl">Brands tracked</div>
      </div>
      <div class="trg-ab-hero__stat-div"></div>
      <div class="trg-ab-hero__stat">
        <div class="trg-ab-hero__stat-val"><span>0</span></div>
        <div class="trg-ab-hero__stat-lbl">Paid placements</div>
      </div>
      <div class="trg-ab-hero__stat-div"></div>
      <div class="trg-ab-hero__stat">
        <div class="trg-ab-hero__stat-val"><span>100</span>%</div>
        <div class="trg-ab-hero__stat-lbl">Editorial</div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} ─── MANIFESTO ─── {%- endcomment -%}
<section class="trg-ab-manifesto">
  <div class="trg-ab-manifesto__inner">
    <div class="trg-ab-manifesto__label">The short version</div>
    <div class="trg-ab-manifesto__text">The menswear internet is full of affiliate farms and SEO listicles. We built the <em>clean, well-organized index</em> we wish had existed. Structured around brands worth knowing about, not brands that pay the most.</div>
  </div>
</section>

{%- comment -%} ─── MAIN GRID ─── {%- endcomment -%}
<div class="trg-ab-main">

  {%- comment -%} PROSE COLUMN {%- endcomment -%}
  <div class="trg-ab-prose">

    {%- comment -%} Section 1: Why {%- endcomment -%}
    <div class="trg-ab-section">
      <div class="trg-ab-eyebrow">Why we built this</div>
      <h2 class="trg-ab-heading">Search results are broken.<br>We're <em>fixing the index.</em></h2>
      <div class="trg-ab-body">
        <p>If you've spent time trying to research a quality menswear brand, you already know the problem. Search results are dominated by affiliate farms, SEO listicles, and Reddit threads where everyone argues past each other. The brands worth knowing: Buck Mason, Taylor Stitch, Rancourt, Viberg. They're buried under the noise.</p>
        <p>The Right Garment was built as the resource we wish had existed. A clean, structured index of quality menswear brands, built by people who care about construction, materials, and longevity over trend cycles.</p>
      </div>

      <blockquote class="trg-ab-quote">
        <div class="trg-ab-quote__text">The best wardrobe isn't the biggest one. It's the one that requires the fewest decisions.</div>
      </blockquote>

      <div class="trg-ab-body">
        <p>We're not a magazine and we're not a blog. We're an intelligence layer: a structured, filterable directory that helps you find exactly the brand you need for exactly the thing you're trying to buy.</p>
      </div>
    </div>

    <hr class="trg-ab-rule">

    {%- comment -%} Section 2: How {%- endcomment -%}
    <div class="trg-ab-section">
      <div class="trg-ab-eyebrow">How we pick brands</div>
      <h2 class="trg-ab-heading">Every brand is <em>manually evaluated.</em></h2>
      <div class="trg-ab-body">
        <p>We don't accept paid placements. A brand's presence in the directory is based entirely on whether it clears our editorial bar: quality construction, honest materials, and a track record in the menswear community.</p>
      </div>

      <div class="trg-ab-principles">
        <div class="trg-ab-principle">
          <div class="trg-ab-principle__num" aria-hidden="true">01</div>
          <div class="trg-ab-principle__title">Quality over completeness</div>
          <div class="trg-ab-principle__body">We'd rather have 300 well-vetted brands than 3,000 undifferentiated ones. If it falls apart after a season, it isn't here.</div>
        </div>
        <div class="trg-ab-principle">
          <div class="trg-ab-principle__num" aria-hidden="true">02</div>
          <div class="trg-ab-principle__title">Real data, not affiliate fluff</div>
          <div class="trg-ab-principle__body">Shipping policies, return windows, cross-border details. We surface the information that actually matters at checkout.</div>
        </div>
        <div class="trg-ab-principle">
          <div class="trg-ab-principle__num" aria-hidden="true">03</div>
          <div class="trg-ab-principle__title">Editorial independence</div>
          <div class="trg-ab-principle__body">Affiliate participation has zero bearing on whether a brand appears. Brands we earn from are listed identically to brands we don't.</div>
        </div>
        <div class="trg-ab-principle">
          <div class="trg-ab-principle__num" aria-hidden="true">04</div>
          <div class="trg-ab-principle__title">Deliberate scope</div>
          <div class="trg-ab-principle__body">Natural materials, considered construction, lasting design. No activewear, no fast fashion, no hype drops.</div>
        </div>
      </div>

      <div class="trg-ab-not-here">
        <span class="trg-ab-not-here__label">Not here:</span>
        <span class="trg-ab-not-here__tag">Activewear</span>
        <span class="trg-ab-not-here__tag">Fast fashion</span>
        <span class="trg-ab-not-here__tag">Hype drops</span>
        <span class="trg-ab-not-here__tag">Athleisure</span>
        <span class="trg-ab-not-here__tag">Streetwear</span>
      </div>
    </div>

    <hr class="trg-ab-rule">

    {%- comment -%} Section 3: Business model {%- endcomment -%}
    <div class="trg-ab-section">
      <div class="trg-ab-eyebrow">Business model</div>
      <h2 class="trg-ab-heading">How we make money, and why it <em>doesn't compromise</em> the directory.</h2>
      <div class="trg-ab-body">
        <p>When you click through to a brand or retailer from The Right Garment and make a purchase, we earn a commission through the brand's affiliate program. This happens at no extra cost to you. The price you see is the price you pay.</p>
        <p>Crucially, affiliate participation has no bearing on whether a brand appears in the directory. Brands we recommend but don't earn from are listed identically to brands we do. Our editorial integrity is the product. Without it, the site is worthless.</p>
        <p>For full details on how this works, see our <a href="/pages/affiliate-disclosure">Affiliate Disclosure</a>.</p>
      </div>
    </div>

  </div>

  {%- comment -%} SIDEBAR {%- endcomment -%}
  <aside class="trg-ab-sidebar">

    <div class="trg-ab-sb">
      <div class="trg-ab-sb__head">Who's behind this</div>
      <div class="trg-ab-sb__body">
        <p class="trg-ab-team">An independent project built by two brothers in <strong>Montreal</strong> who've been the target audience for this site for years, which is exactly why we built it.</p>
        <p class="trg-ab-team">No investors. No editorial relationships with brands. The directory stays independent or it doesn't exist.</p>
        <div class="trg-ab-badge">
          <span class="trg-ab-badge__dot"></span>
          Independently operated
        </div>
      </div>
    </div>

    <div class="trg-ab-newsletter">
      <div class="trg-ab-newsletter__title">The occasional <em>well-edited</em> email.</div>
      <div class="trg-ab-newsletter__body">New brands, restocks, and shopping intelligence for quality-conscious buyers. No noise.</div>
      <a href="/pages/newsletter" class="trg-ab-newsletter__btn">
        Subscribe, it's free
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="trg-ab-sb">
      <div class="trg-ab-sb__head">Explore</div>
      <div class="trg-ab-sb__body">
        <a href="/pages/brands" class="trg-ab-link">
          Browse All Brands
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pages/submit-brand" class="trg-ab-link">
          Submit a Brand
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pages/affiliate-disclosure" class="trg-ab-link">
          Affiliate Disclosure
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pages/colour-guide" class="trg-ab-link">
          Colour Guide
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

  </aside>

</div>

{%- comment -%} ─── END CTA ─── {%- endcomment -%}
<section class="trg-ab-end">
  <div class="trg-ab-end__inner">
    <div class="trg-ab-end__eyebrow">Ready to browse</div>
    <h2 class="trg-ab-end__title">{{ trg_brand_count }}+ brands. <em>Zero</em> noise.</h2>
    <p class="trg-ab-end__sub">Every brand in the directory has been manually evaluated for quality, construction, and materials.</p>
    <div class="trg-ab-end__buttons">
      <a href="/pages/brands" class="trg-ab-end__btn trg-ab-end__btn--primary">
        Browse the Directory
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/pages/submit-brand" class="trg-ab-end__btn trg-ab-end__btn--secondary">Submit a Brand</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About TRG",
  "tag": "section",
  "class": "trg-about-section"
}
{% endschema %}
