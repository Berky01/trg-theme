      "settings": {
        "custom_liquid": "<style>\n  :root {\n    --paper: #f5f1eb;\n    --warm-white: #faf8f4;\n    --card-bg: #ffffff;\n    --ink: #1a1a18;\n    --mid: #8a8478;\n    --accent: #c4562a;\n    --tag-bg: #ede8e0;\n    --border: #ddd8cf;\n    --subtle: #e8e3db;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  *,\n  *::before,\n  *::after {\n    margin: 0;\n    padding: 0;\n  }\n\n  html {\n    font-size: 16px;\n  }\n\n  body {\n    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    background-color: var(--paper);\n    color: var(--ink);\n    min-height: 100vh;\n    font-weight: 300;\n    line-height: 1.75;\n  }\n\n  /* Header Styling */\n  [data-section-type=\"header\"],\n  header,\n  .shopify-section[data-section-type=\"header\"] {\n    background-color: var(--ink) !important;\n  }\n\n  /* Logo Styling */\n  .header__heading-link,\n  [data-header-logo],\n  .header__logo,\n  a[href=\"/\"] {\n    font-family: 'Playfair Display', serif !important;\n    color: var(--paper) !important;\n  }\n\n  /* Style \"Garment\" word in italic and accent color */\n  .header__heading-link em,\n  [data-header-logo] em,\n  .header__logo em,\n  a[href=\"/\"] em {\n    font-style: italic !important;\n    color: var(--accent) !important;\n  }\n\n  /* Navigation Links Styling */\n  .header__menu-item a,\n  .header__menu a,\n  nav a,\n  [data-header-menu] a,\n  .menu a {\n    color: rgba(245, 241, 235, 0.65) !important;\n    transition: color 0.2s ease;\n  }\n\n  .header__menu-item a:hover,\n  .header__menu a:hover,\n  nav a:hover,\n  [data-header-menu] a:hover,\n  .menu a:hover,\n  .header__menu-item a.active,\n  .header__menu a.active,\n  nav a.active,\n  [data-header-menu] a.active,\n  .menu a.active {\n    color: var(--paper) !important;\n  }\n\n  /* Sign In Button Styling */\n  .header__action-item button,\n  .header__action button,\n  [data-header-action] button,\n  .header__account,\n  .header__account-link,\n  button[aria-label*=\"Account\"],\n  button[aria-label*=\"Sign\"],\n  a[href*=\"account\"],\n  a[href*=\"login\"] {\n    background-color: transparent !important;\n    border: 1px solid rgba(245, 241, 235, 0.3) !important;\n    color: var(--paper) !important;\n    border-radius: 2px !important;\n    transition: all 0.2s ease;\n  }\n\n  .header__action-item button:hover,\n  .header__action button:hover,\n  [data-header-action] button:hover,\n  .header__account:hover,\n  .header__account-link:hover,\n  button[aria-label*=\"Account\"]:hover,\n  button[aria-label*=\"Sign\"]:hover,\n  a[href*=\"account\"]:hover,\n  a[href*=\"login\"]:hover {\n    border-color: rgba(245, 241, 235, 0.5) !important;\n    background-color: rgba(245, 241, 235, 0.05) !important;\n  }\n\n  /* Page Header Styles */\n  .page-header {\n    background-color: var(--warm-white);\n    border-bottom: 1px solid var(--border);\n    padding: 2.5rem 2rem 2rem;\n  }\n\n  .page-header-inner {\n    max-width: 1320px;\n    margin: 0 auto;\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n  }\n\n  .page-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 2.4rem;\n    font-weight: 400;\n    line-height: 1.15;\n    color: var(--ink);\n  }\n\n  .page-title em {\n    font-style: italic;\n    color: var(--accent);\n  }\n\n  .page-subtitle {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.75rem;\n    color: var(--mid);\n    font-weight: 400;\n    margin-top: 0.4rem;\n  }\n\n  .result-count {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.75rem;\n    color: var(--mid);\n    text-align: right;\n    font-weight: 400;\n  }\n\n  .result-count strong {\n    color: var(--ink);\n    font-weight: 500;\n  }\n\n  /* Search Bar Styles */\n  .search-bar-wrapper {\n    background-color: var(--warm-white);\n    border-bottom: 1px solid var(--border);\n    padding: 1rem 2rem;\n  }\n\n  .search-bar-inner {\n    max-width: 1320px;\n    margin: 0 auto;\n    position: relative;\n  }\n\n  .search-input-group {\n    position: relative;\n  }\n\n  .search-input-group input {\n    width: 100%;\n    padding: 0.75rem 1rem 0.75rem 2.75rem;\n    border: 1px solid var(--border);\n    border-radius: 3px;\n    background-color: var(--card-bg);\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.9rem;\n    font-weight: 300;\n    color: var(--ink);\n    transition: border-color 0.2s ease;\n  }\n\n  .search-input-group input:focus {\n    outline: none;\n    border-color: var(--ink);\n  }\n\n  .search-input-group input::placeholder {\n    color: var(--mid);\n  }\n\n  .search-icon {\n    position: absolute;\n    left: 1rem;\n    top: 50%;\n    transform: translateY(-50%);\n    color: var(--mid);\n    pointer-events: none;\n  }\n\n  /* Layout */\n  .page-body {\n    max-width: 1320px;\n    margin: 0 auto;\n    padding: 2rem;\n    display: grid;\n    grid-template-columns: 240px 1fr;\n    gap: 2.5rem;\n  }\n\n  /* Filters Sidebar */\n  .filters-sidebar {\n    position: sticky;\n    top: 72px;\n  }\n\n  .filter-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 1.5rem;\n  }\n\n  .filter-title {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.7rem;\n    font-weight: 500;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--mid);\n  }\n\n  .clear-all-btn {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.75rem;\n    font-weight: 500;\n    color: var(--accent);\n    background: none;\n    border: none;\n    cursor: pointer;\n    opacity: 0;\n    transition: opacity 0.2s ease;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .clear-all-btn.visible {\n    opacity: 1;\n  }\n\n  .filter-group {\n    margin-bottom: 1.25rem;\n  }\n\n  .filter-group-title {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.8rem;\n    font-weight: 500;\n    color: var(--ink);\n    margin-bottom: 0.75rem;\n    cursor: pointer;\n    user-select: none;\n  }\n\n  .filter-options {\n    display: flex;\n    flex-direction: column;\n    gap: 0.5rem;\n  }\n\n  .filter-option {\n    display: flex;\n    align-items: center;\n    gap: 0.75rem;\n    cursor: pointer;\n    user-select: none;\n  }\n\n  .filter-checkbox {\n    width: 15px;\n    height: 15px;\n    border: 1.5px solid var(--border);\n    border-radius: 2px;\n    background-color: var(--card-bg);\n    cursor: pointer;\n    position: relative;\n    transition: all 0.2s ease;\n  }\n\n  .filter-checkbox:hover {\n    border-color: var(--ink);\n  }\n\n  .filter-checkbox.checked {\n    background-color: var(--ink);\n    border-color: var(--ink);\n  }\n\n  .filter-checkbox.checked::after {\n    content: '✓';\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    color: var(--card-bg);\n    font-size: 0.75rem;\n    font-weight: bold;\n  }\n\n  .filter-label {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.85rem;\n    font-weight: 400;\n    color: var(--ink);\n  }\n\n  .toggle-switch {\n    width: 34px;\n    height: 19px;\n    background-color: var(--subtle);\n    border-radius: 9.5px;\n    position: relative;\n    cursor: pointer;\n    transition: background-color 0.2s ease;\n  }\n\n  .toggle-switch.active {\n    background-color: var(--ink);\n  }\n\n  .toggle-switch.canada {\n    background-color: #d4291a;\n  }\n\n  .toggle-switch::after {\n    content: '';\n    position: absolute;\n    width: 15px;\n    height: 15px;\n    background-color: var(--card-bg);\n    border-radius: 50%;\n    top: 2px;\n    left: 2px;\n    transition: left 0.2s ease;\n  }\n\n  .toggle-switch.active::after {\n    left: 17px;\n  }\n\n  .filter-divider {\n    border-bottom: 1px solid var(--subtle);\n    margin: 1.25rem 0;\n  }\n\n  /* Sort Bar */\n  .sort-bar {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 2rem;\n    padding-bottom: 1rem;\n    border-bottom: 1px solid var(--border);\n  }\n\n  .active-tags {\n    display: flex;\n    gap: 0.5rem;\n    flex-wrap: wrap;\n  }\n\n  .active-tag {\n    background-color: var(--ink);\n    color: var(--card-bg);\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.72rem;\n    font-weight: 500;\n    padding: 0.4rem 0.75rem;\n    border-radius: 2px;\n    display: inline-flex;\n    align-items: center;\n    gap: 0.5rem;\n    transition: background-color 0.2s ease;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .active-tag:hover {\n    background-color: var(--accent);\n  }\n\n  .active-tag-remove {\n    cursor: pointer;\n    font-weight: bold;\n  }\n\n  .sort-select {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.8rem;\n    font-weight: 400;\n    border: 1px solid var(--border);\n    background-color: var(--card-bg);\n    border-radius: 2px;\n    padding: 0.5rem 0.75rem;\n    color: var(--ink);\n    cursor: pointer;\n    transition: border-color 0.2s ease;\n  }\n\n  .sort-select:hover,\n  .sort-select:focus {\n    border-color: var(--ink);\n    outline: none;\n  }\n\n  /* Animations */\n  @keyframes fadeUp {\n    from {\n      opacity: 0;\n      transform: translateY(8px);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  /* Product Grid */\n  .product-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 1px;\n    background-color: var(--border);\n    border: 1px solid var(--border);\n  }\n\n  /* Product Card */\n  .product-card {\n    background-color: var(--card-bg);\n    display: flex;\n    flex-direction: column;\n    animation: fadeUp 0.3s ease;\n    transition: background-color 0.2s ease;\n    border-radius: 3px;\n  }\n\n  .product-card:hover {\n    background-color: var(--warm-white);\n  }\n\n  /* Product Image Area */\n  .product-image-area {\n    position: relative;\n    aspect-ratio: 3 / 4;\n    background-color: var(--tag-bg);\n    overflow: hidden;\n    border-radius: 3px;\n  }\n\n  .product-image {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    transition: transform 0.4s ease;\n  }\n\n  .product-card:hover .product-image {\n    transform: scale(1.03);\n  }\n\n  .product-image-placeholder {\n    width: 100%;\n    height: 100%;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 1.5rem;\n    color: var(--ink);\n    opacity: 0.5;\n  }\n\n  /* Badges & Overlays */\n  .badge-overlay {\n    position: absolute;\n    top: 0.6rem;\n    left: 0.6rem;\n    display: flex;\n    flex-direction: column;\n    gap: 0.25rem;\n  }\n\n  .badge {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.62rem;\n    font-weight: 500;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 0.2rem 0.45rem;\n    border-radius: 2px;\n    display: inline-block;\n    width: fit-content;\n  }\n\n  .badge-new {\n    background-color: var(--ink);\n    color: var(--paper);\n  }\n\n  .badge-sale {\n    background-color: var(--accent);\n    color: #ffffff;\n  }\n\n  .badge-ca-ship {\n    background-color: rgba(212, 41, 26, 0.9);\n    color: #ffffff;\n  }\n\n  .wishlist-btn {\n    position: absolute;\n    top: 0.6rem;\n    right: 0.6rem;\n    width: 28px;\n    height: 28px;\n    background-color: var(--card-bg);\n    border: none;\n    border-radius: 2px;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    opacity: 0;\n    transition: opacity 0.2s ease, color 0.2s ease;\n  }\n\n  .product-card:hover .wishlist-btn {\n    opacity: 1;\n  }\n\n  .wishlist-btn:hover,\n  .wishlist-btn.saved {\n    color: var(--accent);\n  }\n\n  /* Product Info */\n  .product-info {\n    padding: 0.9rem 1rem;\n    display: flex;\n    flex-direction: column;\n    flex: 1;\n  }\n\n  .product-brand {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.68rem;\n    font-weight: 500;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: var(--mid);\n    margin-bottom: 0.25rem;\n  }\n\n  .product-name {\n    font-family: 'Playfair Display', serif;\n    font-size: 0.95rem;\n    font-weight: 600;\n    line-height: 1.25;\n    color: var(--ink);\n    margin-bottom: 0.4rem;\n  }\n\n  .product-meta {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.72rem;\n    color: var(--mid);\n    font-weight: 300;\n    margin-bottom: 0.5rem;\n  }\n\n  .product-price-row {\n    display: flex;\n    align-items: baseline;\n    gap: 0.5rem;\n    margin-top: auto;\n  }\n\n  .product-price {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.9rem;\n    font-weight: 500;\n    color: var(--ink);\n  }\n\n  .product-price.sale {\n    color: var(--accent);\n  }\n\n  .product-original-price {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.78rem;\n    color: var(--mid);\n    text-decoration: line-through;\n    font-weight: 300;\n  }\n\n  /* Product Footer */\n  .product-footer {\n    padding: 0.65rem 1rem;\n    border-top: 1px solid var(--subtle);\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n\n  .product-cta-primary {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.7rem;\n    font-weight: 500;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    background: none;\n    border: none;\n    color: var(--ink);\n    cursor: pointer;\n    transition: color 0.2s ease;\n  }\n\n  .product-cta-primary:hover {\n    color: var(--accent);\n  }\n\n  .product-cta-brand {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.68rem;\n    font-weight: 400;\n    color: var(--mid);\n    background: none;\n    border: none;\n    cursor: pointer;\n    transition: color 0.2s ease;\n  }\n\n  .product-cta-brand:hover {\n    color: var(--accent);\n  }\n\n  /* Load More Button */\n  .load-more-btn {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.8rem;\n    font-weight: 500;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 0.85rem 2.5rem;\n    border: 1.5px solid var(--ink);\n    background-color: transparent;\n    color: var(--ink);\n    border-radius: 2px;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    margin: 2rem auto;\n    display: block;\n  }\n\n  .load-more-btn:hover {\n    background-color: var(--ink);\n    color: #ffffff;\n  }\n\n  /* Mobile Filter Button */\n  .mobile-filter-btn {\n    display: none;\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.8rem;\n    font-weight: 500;\n    border: 1.5px solid var(--border);\n    background-color: var(--card-bg);\n    color: var(--ink);\n    padding: 0.5rem 1rem;\n    border-radius: 2px;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n  }\n\n  .mobile-filter-btn:hover {\n    border-color: var(--ink);\n  }\n\n  /* Mobile Responsive */\n  @media (max-width: 900px) {\n    .page-body {\n      grid-template-columns: 1fr;\n    }\n\n    .filters-sidebar {\n      display: none;\n    }\n\n    .mobile-filter-btn {\n      display: block;\n    }\n\n    .product-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n</style>",
