{%- liquid

  comment

    ═══════════════════════════════════════════════════════════════════

    TRG PRODUCT PDP — Self-contained section (v3)

    Replaces Dwell's product-information section for full design control

    ═══════════════════════════════════════════════════════════════════

  endcomment



  assign p = product



  if request.visual_preview_mode and p == blank

    assign p = collections.all.products.first

  endif



  assign vendor_name = p.vendor | default: 'Brand'

  assign brand_handle = vendor_name | handleize

  assign brand_meta = shop.metaobjects.brand[brand_handle]

  if brand_meta == blank

    assign alt_name = vendor_name | replace: '&', 'and'

    assign alt_handle = alt_name | handleize

    assign brand_meta = shop.metaobjects.brand[alt_handle]

    if brand_meta != blank

      assign brand_handle = alt_handle

    endif

  endif

  assign brand_url = '/collections/' | append: brand_handle



  assign buy_path = p.metafields.trg.buy_path.value | default: p.metafields.trg.buy_path | default: 'Direct' | strip

  assign buy_path_normalized = buy_path | downcase



  assign buy_url_us = p.metafields.trg.buy_url.value | default: p.metafields.trg.buy_url

  assign buy_url_us = buy_url_us | default: p.metafields.trg.affiliate_link.value | default: p.metafields.trg.affiliate_link

  assign buy_url_ca = p.metafields.trg.buy_url_ca.value | default: p.metafields.trg.buy_url_ca | default: buy_url_us
  assign selected_variant = p.selected_or_first_available_variant
  assign selected_colour = ''
  for option in p.options_with_values
    assign opt_lower = option.name | downcase
    if opt_lower == 'color' or opt_lower == 'colour'
      assign selected_colour = option.selected_value | default: selected_variant.option1 | strip
      break
    endif
  endfor

  assign trg_variant_color_data = p.metafields.trg.variant_color_data.value

  assign trg_source_variant_id = p.metafields.trg.source_variant_external_id.value | default: p.metafields.trg.source_variant_external_id | append: ''

  assign trg_has_grouped_colours = false

  if trg_variant_color_data != blank and trg_variant_color_data.size > 1

    assign trg_has_grouped_colours = true

  endif



  assign retailer_name_us = p.metafields.trg.retailer_name_us.value | default: p.metafields.trg.retailer_name_us

  assign retailer_url_us  = p.metafields.trg.retailer_url_us.value  | default: p.metafields.trg.retailer_url_us

  assign retailer_name_ca = p.metafields.trg.retailer_name_ca.value | default: p.metafields.trg.retailer_name_ca

  assign retailer_url_ca  = p.metafields.trg.retailer_url_ca.value  | default: p.metafields.trg.retailer_url_ca



  assign eff_retailer_name_ca = retailer_name_ca

  assign eff_retailer_url_ca  = retailer_url_ca

  if eff_retailer_url_ca == blank

    assign eff_retailer_name_ca = retailer_name_us

    assign eff_retailer_url_ca  = retailer_url_us

  endif



  assign is_direct   = false

  assign is_both     = false

  assign is_reseller = false

  if buy_path_normalized == 'both'

    assign is_both = true

  elsif buy_path_normalized contains 'reseller'

    assign is_reseller = true

  else

    assign is_direct = true

  endif



  assign material   = p.metafields.trg.material_type

  assign care_inst  = p.metafields.trg.care_instructions

  assign ship_info  = p.metafields.trg.shipping_info

  assign made_in    = p.metafields.trg.made_in_country

  assign style_aes  = p.metafields.trg.style_aesthetic

  assign season     = p.metafields.trg.season

  assign price_rng  = p.metafields.trg.price_range



  assign made_in_str = made_in | downcase

  assign is_na = false

  if made_in_str contains 'usa' or made_in_str contains 'united states' or made_in_str contains 'canada' or made_in_str contains 'mexico'

    assign is_na = true

  endif



  assign ships_raw = p.metafields.trg.ships_to_canada.value | default: p.metafields.trg.ships_to_canada

  assign ships_to_ca = false

  if ships_raw == 'Yes' or ships_raw == 'yes' or ships_raw == true

    assign ships_to_ca = true

  endif

  assign duties_raw = p.metafields.trg.ca_duties_apply.value | default: p.metafields.trg.ca_duties_apply

  assign duties_apply = false

  if duties_raw == 'Yes' or duties_raw == 'yes' or duties_raw == true

    assign duties_apply = true

  endif

  assign returns_window = p.metafields.trg.returns_window.value | default: p.metafields.trg.returns_window

  assign also_available_raw = p.metafields.trg.also_available.value | default: p.metafields.trg.also_available | default: ''



  assign has_affiliate = false

  assign brand_aff_program = brand_meta.affiliate_program.value | default: ''

  assign brand_aff_network = brand_meta.affiliate_network.value | default: ''

  if brand_aff_program == 'Yes'

    assign has_affiliate = true

  elsif brand_aff_network != blank and brand_aff_network != 'No' and brand_aff_network != 'no'

    assign has_affiliate = true

  endif



  assign price_cents = selected_variant.price | default: p.price

  assign price_dollars = price_cents | divided_by: 100

  assign price_remainder = price_cents | modulo: 100



  assign bc_collection = nil

  for col in p.collections

    if col.handle != 'all' and col.handle != 'frontpage'

      assign bc_collection = col

      break

    endif

  endfor

-%}

{%- comment -%}TRG SEO — Product JSON-LD (G10){%- endcomment -%}
{%- if product != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ canonical_url | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} }{% if product.featured_image %},
  "image": {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}{% endif %}{% if product.selected_or_first_available_variant %},
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_url | json }},
    "priceCurrency": "{{ shop.currency }}",
    "price": "{{ product.price_min | money_without_currency | remove: ',' | strip }}",
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
  }{% endif %}
}
</script>
{%- endif -%}

{% if p != blank %}

{%- comment -%} ═══ BREADCRUMB ═══ {%- endcomment -%}

<nav class="trg-pdp-bc" aria-label="Breadcrumb">

  <div class="trg-pdp-bc__inner">

    <a href="/">Home</a>

    <span class="trg-pdp-bc__sep" aria-hidden="true">&#8250;</span>
    <a href="/collections/all">Products</a>
    {%- if bc_collection -%}
      <span class="trg-pdp-bc__sep" aria-hidden="true">&#8250;</span>
      <a href="{{ bc_collection.url }}">{{ bc_collection.title }}</a>
    {%- endif -%}
    <span class="trg-pdp-bc__sep" aria-hidden="true">&#8250;</span>
    <span class="trg-pdp-bc__current">{{ p.title }}</span>
  </div>
</nav>
{%- comment -%}TRG SEO — BreadcrumbList JSON-LD (G11){%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://therightgarment.com/" },
    { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://therightgarment.com/collections/all" }{% if bc_collection %},
    { "@type": "ListItem", "position": 3, "name": {{ bc_collection.title | json }}, "item": {{ shop.url | append: bc_collection.url | json }} },
    { "@type": "ListItem", "position": 4, "name": {{ p.title | json }}, "item": {{ canonical_url | json }} }{% else %},
    { "@type": "ListItem", "position": 3, "name": {{ p.title | json }}, "item": {{ canonical_url | json }} }{% endif %}
  ]
}
</script>

{%- comment -%} ═══ MAIN 55/45 GRID ═══ {%- endcomment -%}

<div class="trg-pdp" {{ section.shopify_attributes }}>



  {%- comment -%} ── GALLERY ── {%- endcomment -%}

  <div class="trg-pdp__gallery">

    <div class="trg-pdp__gallery-main" id="trg-gallery-main">

      {%- if p.featured_media -%}

        <img

          src="{{ p.featured_media | image_url: width: 900 }}" srcset="{{ p.featured_media | image_url: width: 450 }} 450w, {{ p.featured_media | image_url: width: 900 }} 900w, {{ p.featured_media | image_url: width: 1200 }} 1200w" sizes="(min-width: 990px) 45vw, (min-width: 750px) 50vw, calc(100vw - 2rem)"

          alt="{{ p.featured_media.alt | default: p.title | escape }}"

          width="{{ p.featured_media.width }}"

          height="{{ p.featured_media.height }}"

          loading="eager"

          id="trg-gallery-img"

        >

      {%- else -%}

        <div class="trg-pdp__gallery-placeholder" id="trg-gallery-img">

          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 5-5 4 4 3-3 6 6"/><circle cx="8.5" cy="8.5" r="1.5"/></svg>

          <span>Product Image</span>

        </div>

      {%- endif -%}

    </div>

    {%- if p.media.size > 1 -%}

      <div class="trg-pdp__thumbs">

        {%- for media in p.media -%}

          <button

            class="trg-pdp__thumb{% if forloop.first %} active{% endif %}"

            data-src="{{ media | image_url: width: 900 }}"

            data-alt="{{ media.alt | default: p.title | escape }}"

            type="button"

          >

            <img src="{{ media | image_url: width: 160 }}" srcset="{{ media | image_url: width: 80 }} 1x, {{ media | image_url: width: 160 }} 2x" alt="" loading="lazy">

          </button>

        {%- endfor -%}

      </div>

    {%- else -%}

      <div class="trg-pdp__thumbs">

        <div class="trg-pdp__thumb active"><div class="trg-pdp__thumb-ph">Front</div></div>

        <div class="trg-pdp__thumb"><div class="trg-pdp__thumb-ph">Back</div></div>

        <div class="trg-pdp__thumb"><div class="trg-pdp__thumb-ph">Detail</div></div>

        <div class="trg-pdp__thumb"><div class="trg-pdp__thumb-ph">On Model</div></div>

      </div>

    {%- endif -%}

  </div>



  {%- comment -%} ── INFO COLUMN ── {%- endcomment -%}

  <div class="trg-pdp__info">



    {%- comment -%} Brand link with arrow {%- endcomment -%}

    <a class="trg-pdp__brand-link" href="{{ brand_url }}">

      {{ vendor_name | escape }}

      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>

    </a>



    {%- comment -%} Title {%- endcomment -%}

    <h1 class="trg-pdp__title">{{ p.title }}</h1>



    {%- comment -%} Price {%- endcomment -%}

    <div class="trg-pdp__price-row">

      <span class="trg-pdp__price">${{ price_dollars }}{%- if price_remainder > 0 -%}.{{ price_remainder | prepend: '00' | slice: -2, 2 }}{%- endif -%}</span>

      <span class="trg-pdp__price-ca">~CA${{ price_dollars | times: 137 | divided_by: 100 }}</span>

      <span class="trg-pdp__price-ca-badge">CA Estimate</span>

    </div>



    {%- if trg_has_grouped_colours -%}

      <div class="trg-pdp__selector trg-pdp__selector--grouped-colours">

        <div class="trg-pdp__selector-label">Colour</div>

        <div class="trg-pdp__chips trg-pdp__chips--colours">

          {%- for color_group in trg_variant_color_data -%}

            {%- liquid
              assign grouped_colour_value = color_group.color_raw | default: color_group.color_normalized | strip
              assign grouped_colour_label = grouped_colour_value | default: color_group.color_normalized | strip
              assign grouped_colour_hex = color_group.color_hex | default: '#ddd8cf'
              assign grouped_colour_variant_id = color_group.first_variant_id | default: color_group.source_variant_external_id | append: ''
              assign grouped_colour_active = false
              if selected_colour != blank and grouped_colour_value == selected_colour
                assign grouped_colour_active = true
              elsif trg_source_variant_id != blank and grouped_colour_variant_id == trg_source_variant_id
                assign grouped_colour_active = true
              elsif trg_source_variant_id == blank and forloop.first
                assign grouped_colour_active = true
              endif
            -%}

            <button

              class="trg-pdp__chip trg-pdp__chip--colour{% if grouped_colour_active %} active{% endif %}"

              type="button"

              data-option-index="0"

              data-value="{{ grouped_colour_value | escape }}"

              aria-label="{{ grouped_colour_label | escape }}"

            ><span class="trg-pdp__chip-swatch" style="--trg-colour-swatch: {{ grouped_colour_hex }};"></span><span>{{ grouped_colour_label }}</span></button>

          {%- endfor -%}

        </div>

      </div>

    {%- endif -%}

    {%- comment -%} Variant picker (size chips) {%- endcomment -%}

    {%- if p.has_only_default_variant == false -%}

      {%- for option in p.options_with_values -%}

        {%- assign opt_lower = option.name | downcase -%}

        {%- assign hide_grouped_colour_option = false -%}

        {%- if trg_has_grouped_colours -%}

          {%- if opt_lower == 'color' or opt_lower == 'colour' -%}

            {%- assign hide_grouped_colour_option = true -%}

          {%- endif -%}

        {%- endif -%}

        {%- unless hide_grouped_colour_option -%}

        <div class="trg-pdp__selector">

          <div class="trg-pdp__selector-label">{{ option.name }}</div>

          <div class="trg-pdp__chips">

            {%- for val in option.values -%}
              {%- assign option_value_active = false -%}
              {%- if val == option.selected_value -%}
                {%- assign option_value_active = true -%}
              {%- elsif option.selected_value == blank and forloop.first -%}
                {%- assign option_value_active = true -%}
              {%- endif -%}

              <button

                class="trg-pdp__chip{% if option_value_active %} active{% endif %}"

                type="button"

                data-option-index="{{ forloop.parentloop.index0 }}"

                data-option-name="{{ option.name | escape }}"

                data-value="{{ val | escape }}"

              >{{ val }}</button>

            {%- endfor -%}

          </div>

        </div>

        {%- endunless -%}

      {%- endfor -%}

    {%- endif -%}



    {%- comment -%} ═══ CTA SECTION ═══ {%- endcomment -%}

    <div class="trg-pdp__cta-section">



      {%- comment -%} ── US MARKET ── {%- endcomment -%}

      <div class="trg-pdp__market trg-pdp__market--us">



        {%- if is_direct and buy_url_us != blank -%}

          <a href="{{ buy_url_us }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-primary">

            Buy at {{ vendor_name | escape }}

            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

          </a>

        {%- endif -%}



        {%- if is_both -%}

          {%- if buy_url_us != blank -%}

            <a href="{{ buy_url_us }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-primary">

              Buy at {{ vendor_name | escape }}

              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

            </a>

          {%- endif -%}

          {%- if retailer_name_us != blank and retailer_url_us != blank -%}

            <div class="trg-pdp__cta-divider">Also sold at</div>

            <a href="{{ retailer_url_us }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-secondary">

              Buy at {{ retailer_name_us | escape }}

              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

            </a>

          {%- endif -%}

        {%- endif -%}



        {%- if is_reseller and retailer_name_us != blank and retailer_url_us != blank -%}

          <a href="{{ retailer_url_us }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-primary" style="background:#1a1a18;">

            Buy at {{ retailer_name_us | escape }}

            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

          </a>

        {%- endif -%}



        {%- comment -%} Fallback if no URL at all {%- endcomment -%}

        {%- if is_direct and buy_url_us == blank -%}

          {%- if is_both == false and is_reseller == false -%}

            <p class="trg-pdp__no-link">No direct link available — search <strong>{{ p.title | escape }}</strong> at your preferred retailer.</p>

          {%- endif -%}

        {%- endif -%}

      </div>



      {%- comment -%} ── CA MARKET ── {%- endcomment -%}

      <div class="trg-pdp__market trg-pdp__market--ca">



        {%- if is_direct and buy_url_ca != blank -%}

          <a href="{{ buy_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-primary">

            Buy at {{ vendor_name | escape }}

            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

          </a>

          <p class="trg-pdp__ca-note">Ships directly to Canada. Duties may apply at checkout.</p>

        {%- endif -%}



        {%- if is_both -%}

          {%- if buy_url_ca != blank -%}

            <a href="{{ buy_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-primary">

              Buy at {{ vendor_name | escape }}

              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

            </a>

          {%- endif -%}

          {%- if eff_retailer_url_ca != blank -%}

            <div class="trg-pdp__cta-divider">Also sold at</div>

            <a href="{{ eff_retailer_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-secondary">

              Buy at {{ eff_retailer_name_ca | escape }}

              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

            </a>

          {%- endif -%}

          <p class="trg-pdp__ca-note">Ships to Canada via retailer. Duties may apply at delivery.</p>

        {%- endif -%}



        {%- if is_reseller and eff_retailer_url_ca != blank -%}

          <a href="{{ eff_retailer_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-pdp__btn-primary" style="background:#1a1a18;">

            Buy at {{ eff_retailer_name_ca | escape }}

            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>

          </a>

          <p class="trg-pdp__ca-note">Ships to Canada via {{ eff_retailer_name_ca | escape }}. Duties may apply at delivery.</p>

        {%- endif -%}

      </div>



    </div>



    {%- comment -%} ═══ ALSO AVAILABLE AT (dedup surfacing) ═══ {%- endcomment -%}

    {%- if also_available_raw != blank and also_available_raw != '[]' -%}

      <div class="trg-pdp__also-at" data-alts="{{ also_available_raw | escape }}">

        <div class="trg-pdp__also-at__label">{{ section.settings.also_available_label | escape }}</div>

        <div class="trg-pdp__also-at__links" id="trg-pdp-also-links"></div>

      </div>

    {%- endif -%}



    {%- if has_affiliate -%}

    <p class="trg-pdp__disclosure">Affiliate link — TRG may earn a commission at no extra cost to you</p>

    {%- endif -%}



    {%- comment -%} Wishlist {%- endcomment -%}

    <button

      class="trg-pdp__wishlist"

      id="trg-pdp-wishlist"

      type="button"

      data-product="{{ p.handle }}"

      onclick="window.trgToggleWishlist && window.trgToggleWishlist(this)"

    >

      <svg class="trg-pdp__wishlist-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>

      <span class="trg-pdp__wishlist-text">{{ section.settings.wishlist_label | escape }}</span>

    </button>



    {%- comment -%} ═══ CANADA STRIP ═══ (hidden default, body[data-region=CA] shows) {%- endcomment -%}

    <div class="trg-pdp__canada" id="trg-canada-strip">

      <button class="trg-pdp__canada-header" type="button" onclick="this.closest('.trg-pdp__canada').classList.toggle('open')">

        <span class="trg-pdp__canada-title">

          <span aria-hidden="true">🍁</span> Canadian Buyers

        </span>

        <svg class="trg-pdp__canada-chevron" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 15l-6-6-6 6"/></svg>

      </button>

      <div class="trg-pdp__canada-body">

        {%- if ships_to_ca -%}

          <div class="trg-pdp__canada-fact">

            <svg class="trg-pdp__canada-icon--ok" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>

            <span><strong>Ships to Canada</strong> — direct from brand</span>

          </div>

        {%- else -%}

          <div class="trg-pdp__canada-fact">

            <svg class="trg-pdp__canada-icon--warn" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>

            <span><strong>Shipping to Canada</strong> — check retailer</span>

          </div>

        {%- endif -%}

        {%- if duties_apply -%}

          <div class="trg-pdp__canada-fact">

            <svg class="trg-pdp__canada-icon--warn" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>

            <span><strong>Duties not prepaid</strong> — may apply at delivery</span>

          </div>

        {%- else -%}

          <div class="trg-pdp__canada-fact">

            <svg class="trg-pdp__canada-icon--ok" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>

            <span><strong>No duties</strong> — DDP, price is final</span>

          </div>

        {%- endif -%}

        {%- if returns_window != blank -%}

          <div class="trg-pdp__canada-fact">

            <svg class="trg-pdp__canada-icon--ok" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>

            <span><strong>Returns:</strong> {{ returns_window }}</span>

          </div>

        {%- endif -%}

      </div>

    </div>



    {%- comment -%} ═══ META GRID ═══ {%- endcomment -%}

    <div class="trg-pdp__meta">

      <div class="trg-pdp__meta-item{% if material == blank %} trg-pdp__meta-item--hidden{% endif %}" id="trg-meta-material">

          <span class="trg-pdp__meta-key">Material</span>

