        </div>

      {%- endif -%}

      {%- if style_aes != blank -%}

        <div class="trg-pdp__meta-item">

          <span class="trg-pdp__meta-key">Style</span>

          <span class="trg-pdp__meta-val trg-pdp__meta-val--tag">{{ style_aes }}</span>

        </div>

      {%- endif -%}

      {%- if season != blank -%}

        <div class="trg-pdp__meta-item">

          <span class="trg-pdp__meta-key">Season</span>

          <span class="trg-pdp__meta-val">{{ season }}</span>

        </div>

      {%- endif -%}

    </div>



    {%- comment -%} ═══ ACCORDION ═══ {%- endcomment -%}

    <div class="trg-pdp__accordion">



      {%- if p.description != blank -%}

      <div class="trg-pdp__acc-item open">

        <button class="trg-pdp__acc-trigger" type="button" onclick="this.closest('.trg-pdp__acc-item').classList.toggle('open')">

          <span class="trg-pdp__acc-label">Details</span>

          <svg class="trg-pdp__acc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 15l-6-6-6 6"/></svg>

        </button>

        <div class="trg-pdp__acc-body">

          <div class="trg-pdp__acc-desc">{{ p.description }}</div>

        </div>

      </div>

      {%- endif -%}



      <div class="trg-pdp__acc-item">

        <button class="trg-pdp__acc-trigger" type="button" onclick="this.closest('.trg-pdp__acc-item').classList.toggle('open')">

          <span class="trg-pdp__acc-label">Materials + Care</span>

          <svg class="trg-pdp__acc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 15l-6-6-6 6"/></svg>

        </button>

        <div class="trg-pdp__acc-body" id="trg-acc-materials">

          {%- if material != blank or care_inst != blank -%}

            {%- if material != blank -%}<p style="margin:0 0 0.4rem;font-weight:500;color:#1a1a18;">{{ material }}</p>{%- endif -%}

            {%- if care_inst != blank -%}<p style="margin:0;">{{ care_inst }}</p>{%- endif -%}

          {%- else -%}

            Care instructions vary by product — check the brand's site for details.

          {%- endif -%}

        </div>

      </div>



      <div class="trg-pdp__acc-item">

        <button class="trg-pdp__acc-trigger" type="button" onclick="this.closest('.trg-pdp__acc-item').classList.toggle('open')">

          <span class="trg-pdp__acc-label">Shipping + Returns</span>

          <svg class="trg-pdp__acc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 15l-6-6-6 6"/></svg>

        </button>

        <div class="trg-pdp__acc-body" id="trg-acc-shipping">

          {%- if ship_info != blank -%}

            {{ ship_info }}

          {%- else -%}

            Shipping policies vary by brand and retailer. Visit the brand's site for current rates and delivery times.

          {%- endif -%}

        </div>

      </div>

    </div>



  </div>

</div>





{%- comment -%} ═══ COMPLETE THE LOOK — COLOUR GUIDE ═══ {%- endcomment -%}

{%- liquid

  assign ctl_colour = selected_colour | strip

  if ctl_colour == blank
    assign ctl_colour = p.metafields.trg.color.value | default: p.metafields.trg.color | strip
  endif

  if ctl_colour == blank and trg_variant_color_data != blank

    assign trg_fallback_colour = ''

    for colour_group in trg_variant_color_data

      assign group_variant_id = colour_group.source_variant_external_id | append: ''

      assign group_colour = colour_group.color_normalized | default: colour_group.color_raw | strip

      if trg_fallback_colour == blank and group_colour != blank

        assign trg_fallback_colour = group_colour

      endif

      if trg_source_variant_id != blank and group_variant_id == trg_source_variant_id and group_colour != blank

        assign ctl_colour = group_colour

        break

      endif

    endfor

    if ctl_colour == blank

      assign ctl_colour = trg_fallback_colour

    endif

  endif

  if ctl_colour == blank

    for option in p.options_with_values

      assign opt_lower = option.name | downcase

      if opt_lower == 'color' or opt_lower == 'colour'

        assign ctl_colour = option.values.first

        break

      endif

    endfor

  endif

  if ctl_colour == blank

    assign title_parts = p.title | split: ' - '

    if title_parts.size > 1

      assign ctl_colour = title_parts.last | strip

    endif

  endif

  if ctl_colour == blank

    assign title_parts = p.title | split: ' in '

    if title_parts.size > 1

      assign ctl_colour = title_parts.last | strip

    endif

  endif

  if ctl_colour == blank

    assign title_parts = p.title | split: ' — '

    if title_parts.size > 1

      assign ctl_colour = title_parts.last | strip

    endif

  endif



  assign pt_lower = p.type | downcase

  assign ctl_garment = 'shirt'

  if pt_lower contains 'pant' or pt_lower contains 'chino' or pt_lower contains 'jean' or pt_lower contains 'trouser'

    assign ctl_garment = 'trousers'

  elsif pt_lower contains 'knit' or pt_lower contains 'sweater' or pt_lower contains 'hoodie' or pt_lower contains 'sweatshirt' or pt_lower contains 'fleece'

    assign ctl_garment = 'knitwear'

  elsif pt_lower contains 'jacket' or pt_lower contains 'blazer' or pt_lower contains 'suit'

    assign ctl_garment = 'jacket'

  elsif pt_lower contains 'coat' or pt_lower contains 'outerwear' or pt_lower contains 'parka'

    assign ctl_garment = 'coat'

  elsif pt_lower contains 'boot' or pt_lower contains 'shoe' or pt_lower contains 'sneaker' or pt_lower contains 'footwear'

    assign ctl_garment = 'shoes'

  endif

-%}



