{% assign suggestion_count = 0 %}
{% for block in section.blocks %}
  {% assign block_label = block.settings.label | strip %}
  {% assign block_query = block.settings.query | strip %}
  {% if block.settings.url != blank or block_label != blank or block_query != blank %}
    {% assign suggestion_count = suggestion_count | plus: 1 %}
  {% endif %}
{% endfor %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--full-width color-{{ section.settings.color_scheme }} trg-search-bar-section{% if section.settings.start_hidden %} trg-search-bar-section--collapsible{% endif %}{% if section.settings.start_hidden == false %} is-revealed{% endif %}"
  style="
    --trg-search-padding-top: {{ section.settings.padding_block_start }}px;
    --trg-search-padding-bottom: {{ section.settings.padding_block_end }}px;
    --trg-search-max-width: {{ section.settings.max_width }}px;
    --trg-search-border-bottom-width: {% if section.settings.accent_border %}2px{% else %}1px{% endif %};
    --trg-search-border-bottom-color: {% if section.settings.accent_border %}var(--color-primary){% else %}rgb(var(--color-border-rgb) / 0.95){% endif %};
  "
  data-trg-search-bar
  {% if section.settings.start_hidden %}
    data-trg-search-collapsible
    aria-hidden="true"
  {% else %}
    aria-hidden="false"
  {% endif %}
  {{ section.shopify_attributes }}
>
  <div class="trg-search-bar__shell">
    <form
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      class="trg-search-bar__form"
      data-trg-search-form
    >
      <input
        type="hidden"
        name="options[prefix]"
        value="last"
      >

      {% if section.settings.label != blank %}
        <span class="trg-search-bar__label">{{ section.settings.label | escape }}</span>
      {% endif %}

      <div class="trg-search-bar__field">
        <label
          class="visually-hidden"
          for="TrgSearchBar-{{ section.id }}"
        >
          {{ section.settings.accessibility_label | escape }}
        </label>
        <span class="svg-wrapper trg-search-bar__icon">
          {{ 'icon-search.svg' | inline_asset_content }}
        </span>
        <input
          id="TrgSearchBar-{{ section.id }}"
          class="trg-search-bar__input"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ section.settings.placeholder | escape }}"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="off"
          data-trg-search-input
        >
      </div>

      {% if suggestion_count > 0 %}
        <div
          class="trg-search-bar__divider"
          aria-hidden="true"
        ></div>
        <div class="trg-search-bar__pills">
          {% for block in section.blocks %}
            {% liquid
              assign suggestion_label = block.settings.label | strip
              assign suggestion_query = block.settings.query | strip
              assign suggestion_url = block.settings.url

              if suggestion_label == blank
                assign suggestion_label = suggestion_query
              endif

              if suggestion_query == blank
                assign suggestion_query = suggestion_label
              endif
            %}

            {% if suggestion_label != blank %}
              {% if suggestion_url != blank %}
                <a
                  class="trg-search-bar__pill"
                  href="{{ suggestion_url }}"
                  {{ block.shopify_attributes }}
                >
                  {{ suggestion_label | escape }}
                </a>
              {% elsif suggestion_query != blank %}
                <button
                  type="button"
                  class="button-unstyled trg-search-bar__pill"
                  data-trg-search-pill="{{ suggestion_query | escape }}"
                  {{ block.shopify_attributes }}
                >
                  {{ suggestion_label | escape }}
                </button>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <button
          type="submit"
          class="trg-search-bar__submit"
          data-trg-search-submit
        >
          <span>{{ section.settings.button_label | escape }}</span>
          <span class="svg-wrapper trg-search-bar__submit-icon">
            {{ 'icon-arrow.svg' | inline_asset_content }}
          </span>
        </button>
      {% endif %}
    </form>

    <p class="trg-search-bar__empty" hidden data-trg-search-empty>
      {{ section.settings.empty_message | escape }}
    </p>
  </div>
</section>

{% stylesheet %}
  .trg-search-bar-section {
    padding-block: var(--trg-search-padding-top) var(--trg-search-padding-bottom);
    border-top: 1px solid rgb(var(--color-border-rgb) / 0.95);
    border-bottom: var(--trg-search-border-bottom-width) solid var(--trg-search-border-bottom-color);
    position: relative;
    z-index: 2;
    overflow: clip;
    transition:
      max-height 0.32s ease,
      opacity 0.24s ease,
      transform 0.24s ease,
      border-color 0.2s ease,
      padding 0.24s ease;
  }

  .trg-search-bar-section--collapsible {
    max-height: 0;
    opacity: 0;
    transform: translateY(-8px);
    padding-block: 0;
    border-top-color: transparent;
    border-bottom-color: transparent;
    pointer-events: none;
  }

  .trg-search-bar-section--collapsible.is-revealed {
    max-height: 220px;
    opacity: 1;
    transform: translateY(0);
    padding-block: var(--trg-search-padding-top) var(--trg-search-padding-bottom);
    border-top-color: rgb(var(--color-border-rgb) / 0.95);
    border-bottom-color: var(--trg-search-border-bottom-color);
    pointer-events: auto;
  }

  .trg-search-bar-section.is-focused {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
  }

  .trg-search-bar__shell {
    width: min(calc(100% - 32px), var(--trg-search-max-width));
    margin-inline: auto;
  }

  .trg-search-bar__form {
    display: flex;
    align-items: center;
    gap: clamp(12px, 1.6vw, 24px);
    min-height: 74px;
  }

  .trg-search-bar__label {
    padding: 20px 24px 20px 0;
    border-right: 1px solid rgb(var(--color-border-rgb) / 0.95);
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 1.1vw, 1.08rem);
    font-style: italic;
    line-height: 1.1;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .trg-search-bar__field {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1 1 260px;
    min-width: 0;
    align-self: stretch;
  }

  .trg-search-bar__icon {
    color: rgb(var(--color-foreground-rgb) / 0.5);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .trg-search-bar__icon svg,
  .trg-search-bar__submit-icon svg {
    width: 100%;
    height: 100%;
  }

  .trg-search-bar__input {
    border: 0;
    background: transparent;
    color: rgb(var(--color-foreground-rgb));
    font-family: var(--font-heading--family);
    font-size: clamp(1.05rem, 1.45vw, 1.16rem);
    line-height: 1.25;
    width: 100%;
    min-width: 0;
    padding-block: 20px;
    box-shadow: none;
  }

  .trg-search-bar__input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.28);
    font-style: italic;
  }

  .trg-search-bar__input:focus {
    outline: none;
  }

  .trg-search-bar__divider {
    width: 1px;
    align-self: stretch;
    background: rgb(var(--color-border-rgb) / 0.95);
    flex-shrink: 0;
  }

  .trg-search-bar__pills {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .trg-search-bar__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 0.35rem 0.75rem;
    border: 1px solid rgb(var(--color-border-rgb) / 0.95);
    border-radius: 2px;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    font-weight: 500;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
    background: transparent;
  }

  .trg-search-bar__pill:hover {
    color: rgb(var(--color-foreground-rgb));
    border-color: rgb(var(--color-foreground-rgb));
    background: rgb(var(--color-foreground-rgb) / 0.03);
  }

  .trg-search-bar__pill:focus-visible,
  .trg-search-bar__submit:focus-visible,
  .trg-search-bar__input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .trg-search-bar__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 38px;
    padding: 0.7rem 1.2rem;
    border: 0;
    border-radius: 2px;
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .trg-search-bar__submit:hover {
    transform: translateY(-1px);
    background: var(--color-primary-button-hover-background);
    color: var(--color-primary-button-hover-text);
  }

  .trg-search-bar__submit-icon {
    width: 11px;
    height: 11px;
  }

  .trg-search-bar__empty {
    margin: 0;
    padding: 0 0 14px;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    font-size: 0.82rem;
  }

  @media screen and (max-width: 900px) {
    .trg-search-bar-section--collapsible.is-revealed {
      max-height: 180px;
    }

    .trg-search-bar__form {
      gap: 14px;
      min-height: 0;
    }

    .trg-search-bar__label,
    .trg-search-bar__divider,
    .trg-search-bar__pills {
      display: none;
    }

    .trg-search-bar__input {
      padding-block: 16px;
      font-size: 1rem;
    }

    .trg-search-bar__submit {
      padding: 0.6rem 1rem;
    }
  }

  @media screen and (max-width: 749px) {
    .trg-search-bar__shell {
      width: min(calc(100% - 24px), var(--trg-search-max-width));
    }

    .trg-search-bar__form {
      gap: 12px;
    }

    .trg-search-bar__submit {
      flex-shrink: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Search Bar",
  "tag": "section",
  "class": "trg-search-bar-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "start_hidden",
      "label": "Start hidden until header search is clicked",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "accent_border",
      "label": "Use accent bottom border",
      "default": false
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "Search the store"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "Brands, styles, categories..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Collection empty state message",
      "default": "No pieces match this search."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 960,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1320
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "suggestion",
      "name": "Suggestion pill",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Workwear"
        },
        {
          "type": "text",
          "id": "query",
          "label": "Search query",
          "default": "Workwear"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Custom link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TRG Search Bar",
      "blocks": [
        {
          "type": "suggestion",
          "settings": {
            "label": "Workwear",
            "query": "Workwear"
          }
        },
        {
          "type": "suggestion",
          "settings": {
            "label": "Heritage",
            "query": "Heritage"
          }
        },
        {
          "type": "suggestion",
          "settings": {
            "label": "Ships to Canada",
            "query": "Ships to Canada"
          }
        }
      ]
    }
  ]
}
{% endschema %}
