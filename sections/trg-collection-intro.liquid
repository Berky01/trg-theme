{% liquid
  assign heading_html = section.settings.custom_title
  if section.settings.title_source == 'collection' and collection.title != blank
    assign heading_html = collection.title
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--full-width color-{{ section.settings.color_scheme }} trg-collection-intro"
  {{ section.shopify_attributes }}
>
  <div class="trg-collection-intro__bar">
    <div class="trg-collection-intro__inner">
      {% if section.settings.eyebrow != blank %}
        <p class="trg-collection-intro__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      <div class="trg-collection-intro__title">{{ heading_html }}</div>
    </div>
  </div>
</section>

{% stylesheet %}
  @keyframes trg-collection-fade-up {
    from {
      opacity: 0;
      transform: translate3d(0, 10px, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .trg-collection-intro {
    padding-block: 0;
    background: #1a1a18;
    border-top: 1px solid rgb(245 241 235 / 0.08);
    border-bottom: 1px solid rgb(245 241 235 / 0.08);
  }

  .trg-collection-intro__bar {
    min-height: 72px;
    display: flex;
    align-items: center;
    background: #1a1a18;
  }

  .trg-collection-intro__inner {
    width: min(calc(100% - 64px), 1320px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .trg-collection-intro__eyebrow {
    margin: 0;
    padding-right: 1.5rem;
    border-right: 1px solid rgb(245 241 235 / 0.12);
    color: #c4562a;
    font-family: var(--font-body--family);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
    animation: trg-collection-fade-up 0.4s 0.05s ease both;
  }

  .trg-collection-intro__title {
    padding-left: 1.5rem;
    color: #f5f1eb;
    font-family: var(--font-heading--family);
    font-size: 1.9rem;
    font-weight: 400;
    line-height: 1;
    white-space: nowrap;
    animation: trg-collection-fade-up 0.4s 0.1s ease both;
  }

  .trg-collection-intro__title > * {
    margin: 0;
    font: inherit;
    color: inherit;
    line-height: inherit;
  }

  .trg-collection-intro__title em {
    color: #c4562a;
    font-style: italic;
  }

  @media screen and (max-width: 900px) {
    .trg-collection-intro__bar {
      min-height: 52px;
    }

    .trg-collection-intro__inner {
      width: min(calc(100% - 32px), 1320px);
    }

    .trg-collection-intro__eyebrow {
      display: none;
    }

    .trg-collection-intro__title {
      padding-left: 0;
      font-size: 1.4rem;
      white-space: normal;
    }
  }

  @media screen and (max-width: 480px) {
    .trg-collection-intro__inner {
      width: min(calc(100% - 32px), 1320px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Collection Intro",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-header-ink"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Product Catalogue"
    },
    {
      "type": "select",
      "id": "title_source",
      "label": "Title source",
      "options": [
        {
          "value": "collection",
          "label": "Collection title"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "custom"
    },
    {
      "type": "richtext",
      "id": "custom_title",
      "label": "Custom title",
      "default": "<p>Find the <em>Right</em> Piece</p>",
      "visible_if": "{{ section.settings.title_source == 'custom' }}"
    },
    {
      "type": "select",
      "id": "body_source",
      "label": "Body source",
      "options": [
        {
          "value": "custom",
          "label": "Custom"
        },
        {
          "value": "collection_description",
          "label": "Collection description"
        }
      ],
      "default": "custom"
    },
    {
      "type": "richtext",
      "id": "custom_body",
      "label": "Custom body",
      "default": "<p>Curated menswear - quality goods across North America.</p>",
      "visible_if": "{{ section.settings.body_source == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": false
    },
    {
      "type": "text",
      "id": "result_label",
      "label": "Result label",
      "default": "products"
    }
  ],
  "presets": [
    {
      "name": "TRG Collection Intro"
    }
  ]
}
{% endschema %}
