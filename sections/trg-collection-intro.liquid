{% liquid
  assign heading_html = section.settings.custom_title
  if section.settings.title_source == 'collection' and collection.title != blank
    assign heading_html = collection.title
  endif

  assign lead_html = section.settings.custom_body
  if section.settings.body_source == 'collection_description' and collection.description != blank
    assign lead_html = collection.description
  endif

  assign suggestion_count = 0
  for block in section.blocks
    assign block_label = block.settings.label | strip
    assign block_query = block.settings.query | strip
    if block_label != blank or block_query != blank
      assign suggestion_count = suggestion_count | plus: 1
    endif
  endfor
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--full-width color-{{ section.settings.color_scheme }} trg-collection-intro">
  <div class="trg-collection-intro__banner">
    <div class="trg-collection-intro__banner-inner">
      <div class="trg-collection-intro__banner-copy">
        {% if section.settings.eyebrow != blank %}
          <p class="trg-collection-intro__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}
        <div class="trg-collection-intro__title">{{ heading_html }}</div>
        {% if lead_html != blank %}
          <div class="trg-collection-intro__subtitle">{{ lead_html }}</div>
        {% endif %}
      </div>

      {% if section.settings.show_count %}
        <p class="trg-collection-intro__result-count">
          <strong data-trg-result-count data-trg-total-count="{{ collection.products_count }}">{{ collection.products_count }}</strong>
          {{ section.settings.result_label | escape }}
        </p>
      {% endif %}
    </div>
  </div>

  {% if section.settings.enable_collection_search %}
    <div class="trg-collection-intro__search-bar" data-trg-inline-search-shell>
      <div class="trg-collection-intro__search-inner">
        <form class="trg-collection-intro__search-form" data-trg-inline-search-form role="search">
          <span class="trg-collection-intro__search-label">{{ section.settings.search_label | escape }}</span>
          <span class="svg-wrapper trg-collection-intro__search-icon" aria-hidden="true">
            {{ 'icon-search.svg' | inline_asset_content }}
          </span>
          <label class="visually-hidden" for="TrgCollectionSearch-{{ section.id }}">
            {{ section.settings.search_placeholder | escape }}
          </label>
          <input
            id="TrgCollectionSearch-{{ section.id }}"
            class="trg-collection-intro__search-input"
            type="search"
            placeholder="{{ section.settings.search_placeholder | escape }}"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            data-trg-inline-search-input
          >

          <div class="trg-collection-intro__search-divider" aria-hidden="true"></div>

          <div class="trg-collection-intro__search-pills">
            {% if suggestion_count > 0 %}
              {% for block in section.blocks %}
                {% liquid
                  assign suggestion_label = block.settings.label | strip
                  assign suggestion_query = block.settings.query | strip
                  if suggestion_label == blank
                    assign suggestion_label = suggestion_query
                  endif
                  if suggestion_query == blank
                    assign suggestion_query = suggestion_label
                  endif
                %}
                {% if suggestion_label != blank and suggestion_query != blank %}
                  <button
                    type="button"
                    class="button-unstyled trg-collection-intro__search-pill"
                    data-trg-inline-search-pill="{{ suggestion_query | escape }}"
                    {{ block.shopify_attributes }}
                  >
                    {{ suggestion_label | escape }}
                  </button>
                {% endif %}
              {% endfor %}
            {% else %}
              {% assign default_queries = 'Workwear|Merino|Made in Canada' | split: '|' %}
              {% for default_query in default_queries %}
                <button
                  type="button"
                  class="button-unstyled trg-collection-intro__search-pill"
                  data-trg-inline-search-pill="{{ default_query | escape }}"
                >
                  {{ default_query | escape }}
                </button>
              {% endfor %}
            {% endif %}
          </div>

          <div class="trg-collection-intro__search-divider" aria-hidden="true"></div>

          <button
            type="submit"
            class="trg-collection-intro__search-submit"
            data-trg-inline-search-submit
          >
            <span>{{ section.settings.search_button_label | escape }}</span>
            <span class="svg-wrapper trg-collection-intro__search-submit-icon" aria-hidden="true">
              {{ 'icon-arrow.svg' | inline_asset_content }}
            </span>
          </button>
        </form>

        <p class="trg-collection-intro__empty" hidden data-trg-inline-search-empty>
          {{ section.settings.empty_message | escape }}
        </p>
      </div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  @keyframes trg-collection-fade-up {
    from {
      opacity: 0;
      transform: translate3d(0, 14px, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .trg-collection-intro {
    padding-block: 0;
    background: #1a1a18;
  }

  .trg-collection-intro__banner {
    background: #1a1a18;
    border-top: 1px solid rgb(245 241 235 / 0.08);
  }

  .trg-collection-intro__banner-inner,
  .trg-collection-intro__search-inner {
    width: min(calc(100% - 32px), 1320px);
    margin: 0 auto;
  }

  .trg-collection-intro__banner-inner {
    padding: 2.5rem 2rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 1rem;
  }

  .trg-collection-intro__banner-copy {
    min-width: 0;
  }

  .trg-collection-intro__eyebrow {
    margin: 0 0 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #c4562a;
    font-family: var(--font-body--family);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    animation: trg-collection-fade-up 0.5s 0.1s ease both;
  }

  .trg-collection-intro__eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: #c4562a;
    flex-shrink: 0;
  }

  .trg-collection-intro__title {
    color: #f5f1eb;
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 3vw, 2.4rem);
    line-height: 1.08;
    animation: trg-collection-fade-up 0.55s 0.15s ease both;
  }

  .trg-collection-intro__title > * {
    margin: 0;
    font: inherit;
    color: inherit;
    line-height: inherit;
  }

  .trg-collection-intro__title em {
    color: #c4562a;
    font-style: italic;
  }

  .trg-collection-intro__subtitle {
    margin-top: 0.5rem;
    color: rgb(245 241 235 / 0.45);
    font-family: var(--font-body--family);
    font-size: 0.82rem;
    font-weight: 300;
    line-height: 1.6;
    animation: trg-collection-fade-up 0.55s 0.25s ease both;
  }

  .trg-collection-intro__subtitle > * {
    margin: 0;
    color: inherit;
  }

  .trg-collection-intro__result-count {
    margin: 0;
    padding-bottom: 0.4rem;
    color: rgb(245 241 235 / 0.35);
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
    animation: trg-collection-fade-up 0.55s 0.3s ease both;
  }

  .trg-collection-intro__result-count strong {
    color: rgb(245 241 235 / 0.75);
    font-weight: 500;
  }

  .trg-collection-intro__search-bar {
    background: #1a1a18;
    border-top: 1px solid rgb(245 241 235 / 0.08);
    border-bottom: 2px solid #c4562a;
    position: relative;
    z-index: 2;
  }

  .trg-collection-intro__search-bar.is-focused {
    outline: 2px solid #c4562a;
    outline-offset: -2px;
  }

  .trg-collection-intro__search-form {
    min-height: 74px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .trg-collection-intro__search-label {
    padding: 1.1rem 1.5rem 1.1rem 0;
    border-right: 1px solid rgb(245 241 235 / 0.1);
    color: rgb(245 241 235 / 0.4);
    font-family: var(--font-heading--family);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.1;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .trg-collection-intro__search-icon {
    width: 16px;
    height: 16px;
    color: rgb(245 241 235 / 0.35);
    flex-shrink: 0;
  }

  .trg-collection-intro__search-icon svg,
  .trg-collection-intro__search-submit-icon svg {
    width: 100%;
    height: 100%;
  }

  .trg-collection-intro__search-input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 1.1rem 0;
    border: 0;
    background: transparent;
    color: #f5f1eb;
    font-family: var(--font-heading--family);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.25;
    box-shadow: none;
  }

  .trg-collection-intro__search-input::placeholder {
    color: rgb(245 241 235 / 0.25);
  }

  .trg-collection-intro__search-input:focus {
    outline: none;
  }

  .trg-collection-intro__search-divider {
    width: 1px;
    height: 1.25rem;
    background: rgb(245 241 235 / 0.1);
    flex-shrink: 0;
  }

  .trg-collection-intro__search-pills {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .trg-collection-intro__search-pill {
    padding: 0.28rem 0.6rem;
    border: 1px solid rgb(245 241 235 / 0.15);
    border-radius: 2px;
    color: rgb(245 241 235 / 0.5);
    font-family: var(--font-body--family);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .trg-collection-intro__search-pill:hover {
    color: #f5f1eb;
    border-color: rgb(245 241 235 / 0.4);
  }

  .trg-collection-intro__search-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 38px;
    padding: 0.5rem 1.1rem;
    border: 0;
    border-radius: 2px;
    background: #c4562a;
    color: #fff;
    font-family: var(--font-body--family);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.15s ease;
    flex-shrink: 0;
  }

  .trg-collection-intro__search-submit:hover {
    background: #b04a22;
  }

  .trg-collection-intro__search-submit-icon {
    width: 11px;
    height: 11px;
  }

  .trg-collection-intro__empty {
    margin: 0;
    padding: 0.75rem 0 1rem;
    color: rgb(245 241 235 / 0.55);
    font-size: 0.82rem;
  }

  .trg-collection-intro__search-input:focus-visible,
  .trg-collection-intro__search-pill:focus-visible,
  .trg-collection-intro__search-submit:focus-visible {
    outline: 2px solid #c4562a;
    outline-offset: 2px;
  }

  @media screen and (max-width: 900px) {
    .trg-collection-intro__banner-inner {
      grid-template-columns: 1fr;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .trg-collection-intro__result-count {
      padding-bottom: 0;
    }

    .trg-collection-intro__search-form {
      gap: 1rem;
    }

    .trg-collection-intro__search-label,
    .trg-collection-intro__search-divider,
    .trg-collection-intro__search-pills {
      display: none;
    }

    .trg-collection-intro__search-input {
      padding: 1rem 0;
      font-size: 1rem;
    }

    .trg-collection-intro__search-submit {
      padding: 0.5rem 0.9rem;
    }
  }

  @media screen and (max-width: 749px) {
    .trg-collection-intro__banner-inner,
    .trg-collection-intro__search-inner {
      width: min(calc(100% - 24px), 1320px);
    }

    .trg-collection-intro__banner-inner {
      padding-inline: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Collection Intro",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-header-ink"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Product Catalogue"
    },
    {
      "type": "select",
      "id": "title_source",
      "label": "Title source",
      "options": [
        {
          "value": "collection",
          "label": "Collection title"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "custom"
    },
    {
      "type": "richtext",
      "id": "custom_title",
      "label": "Custom title",
      "default": "<p>Find the <em>Right</em> Piece</p>",
      "visible_if": "{{ section.settings.title_source == 'custom' }}"
    },
    {
      "type": "select",
      "id": "body_source",
      "label": "Body source",
      "options": [
        {
          "value": "custom",
          "label": "Custom"
        },
        {
          "value": "collection_description",
          "label": "Collection description"
        }
      ],
      "default": "custom"
    },
    {
      "type": "richtext",
      "id": "custom_body",
      "label": "Custom body",
      "default": "<p>Curated menswear - quality goods across North America.</p>",
      "visible_if": "{{ section.settings.body_source == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "text",
      "id": "result_label",
      "label": "Result label",
      "default": "products"
    },
    {
      "type": "checkbox",
      "id": "enable_collection_search",
      "label": "Enable quick client-side search",
      "default": true
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Products, brands, fabrics..."
    },
    {
      "type": "text",
      "id": "search_button_label",
      "label": "Search button label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty state message",
      "default": "No pieces match this search."
    }
  ],
  "blocks": [
    {
      "type": "suggestion",
      "name": "Suggestion pill",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "query",
          "label": "Query"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TRG Collection Intro",
      "blocks": [
        {
          "type": "suggestion",
          "settings": {
            "label": "Workwear",
            "query": "Workwear"
          }
        },
        {
          "type": "suggestion",
          "settings": {
            "label": "Merino",
            "query": "Merino"
          }
        },
        {
          "type": "suggestion",
          "settings": {
            "label": "Made in Canada",
            "query": "Made in Canada"
          }
        }
      ]
    }
  ]
}
{% endschema %}
