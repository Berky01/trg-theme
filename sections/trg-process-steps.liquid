<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--full-width color-{{ section.settings.color_scheme }} trg-section trg-steps trg-steps--{{ section.settings.layout_variant }}"
  style="--trg-steps-accent: {{ section.settings.accent_color | default: '#c4562a' }};">
  <div class="trg-shell trg-steps__grid">
    <div class="trg-steps__header" data-trg-reveal>
      {%- render 'trg-section-header',
        eyebrow: section.settings.eyebrow,
        title: section.settings.title,
        body: section.settings.body,
        align: 'left'
      -%}
    </div>

    <div class="trg-steps__list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign step_number = forloop.index | prepend: '0' | slice: -2, 2
          if block.settings.custom_number != blank
            assign step_number = block.settings.custom_number
          endif
        -%}
        <div class="trg-step-card" data-trg-reveal {{ block.shopify_attributes }}>
          <div class="trg-step-card__top">
            <span class="trg-step-card__num">{{ step_number }}</span>
            {%- if block.settings.icon != blank -%}
              <span class="trg-step-card__icon">{{ block.settings.icon | escape }}</span>
            {%- endif -%}
          </div>
          <h3 class="trg-step-card__title">{{ block.settings.title | escape }}</h3>
          <p class="trg-step-card__body">{{ block.settings.body | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* ── TRG Process Steps ────────────────────── */

  .trg-steps {
    padding-block: clamp(48px, 6vw, 80px);
  }

  .trg-steps__grid {
    display: grid;
    gap: clamp(28px, 4vw, 48px);
  }

  @media screen and (min-width: 990px) {
    .trg-steps__grid {
      grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
      gap: clamp(40px, 5vw, 80px);
      align-items: start;
    }
  }

  /* ── Header overrides for editorial_dark ── */

  .trg-steps--editorial_dark .trg-section-header {
    align-items: start;
  }

  .trg-steps--editorial_dark .trg-heading {
    color: rgb(var(--color-foreground-rgb));
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    line-height: 1.15;
  }

  .trg-steps--editorial_dark .trg-lead,
  .trg-steps--editorial_dark .trg-lead > * {
    color: rgb(var(--color-foreground-rgb) / 0.42);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .trg-steps--editorial_dark .trg-eyebrow {
    color: rgb(var(--color-foreground-rgb) / 0.5);
  }

  /* ── Step list ── */

  .trg-steps__list {
    display: grid;
    gap: clamp(16px, 2.5vw, 24px);
  }

  @media screen and (min-width: 990px) {
    .trg-steps--editorial_dark .trg-steps__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .trg-steps--editorial_dark .trg-steps__list {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  /* ── Step cards ── */

  .trg-steps--editorial_dark .trg-step-card {
    padding: clamp(20px, 2.5vw, 28px);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: var(--trg-card-radius);
    background: rgb(var(--color-foreground-rgb) / 0.03);
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .trg-steps--editorial_dark .trg-step-card:hover {
    border-color: rgb(var(--color-foreground-rgb) / 0.15);
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  @media screen and (max-width: 989px) {
    .trg-steps--editorial_dark .trg-step-card {
      border-radius: 0;
      border-bottom: 0;
    }
    .trg-steps--editorial_dark .trg-step-card:first-child {
      border-radius: var(--trg-card-radius) var(--trg-card-radius) 0 0;
    }
    .trg-steps--editorial_dark .trg-step-card:last-child {
      border-radius: 0 0 var(--trg-card-radius) var(--trg-card-radius);
      border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    }
  }

  .trg-step-card__top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: clamp(12px, 1.5vw, 18px);
  }

  .trg-step-card__num {
    font-family: var(--font-heading--family);
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    line-height: 1;
    color: var(--trg-steps-accent);
    opacity: 0.7;
  }

  .trg-step-card__icon {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 3px;
    font-size: 0.8rem;
    color: rgb(var(--color-foreground-rgb) / 0.45);
  }

  .trg-step-card__title {
    margin: 0 0 8px;
    color: rgb(var(--color-foreground-rgb));
    font-family: var(--font-heading--family);
    font-size: clamp(0.92rem, 1.2vw, 1rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .trg-step-card__body {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.52);
    font-size: clamp(0.81rem, 0.9vw, 0.87rem);
    line-height: 1.65;
  }

  /* ── card_split variant (original base layout) ── */
  .trg-steps--card_split .trg-step-card {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 12px;
    align-items: start;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Process Steps",
  "tag": "section",
  "class": "trg-process-steps",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How it works"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>How it <em>works</em></p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Editorial curation and practical shopping intelligence.</p>"
    },
    {
      "type": "select",
      "id": "layout_variant",
      "label": "Layout",
      "options": [
        {
          "value": "editorial_dark",
          "label": "Editorial dark"
        },
        {
          "value": "card_split",
          "label": "Card split"
        }
      ],
      "default": "editorial_dark"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Step number accent",
      "default": "#c4562a"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "custom_number",
          "label": "Custom number"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "We do the research"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Every listing is manually evaluated for quality signals and shipping clarity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TRG Process Steps",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
