{% liquid
  assign brand_entries = shop.metaobjects.brand.values
  assign total_brands = brand_entries.size
  assign featured_brand = blank
  assign featured_handle = section.settings.featured_brand_handle | strip

  if featured_handle != blank and shop.metaobjects.brand != blank
    assign featured_brand = shop.metaobjects.brand[featured_handle]
  endif

  if featured_brand == blank and brand_entries != blank
    assign featured_brand = brand_entries | first
  endif

  assign category_map = 'All Brands::all,Casualwear::casualwear,Footwear::footwear,Formalwear::formalwear,Outerwear::outerwear,Denim::denim,Knitwear::knitwear,Smart Casual::smart-casual,Basics::basics,Workwear::workwear,Streetwear::streetwear' | split: ','
%}

<section class="section section--full-width trg-brand-directory">
  <div class="trg-shell trg-brand-directory__shell">
    <aside class="trg-brand-directory__sidebar">
      <div class="trg-brand-directory__sidebar-label">Browse by</div>
      {% for category_entry in category_map %}
        {% liquid
          assign category_parts = category_entry | split: '::'
          assign category_label = category_parts[0]
          assign category_slug = category_parts[1]
          assign category_count = 0

          if category_slug == 'all'
            assign category_count = total_brands
          else
            for brand in brand_entries
              assign brand_category_field = brand.primary_category
              assign brand_category = brand_category_field.value | default: brand_category_field | downcase
              assign normalized_slug = category_slug | replace: '-', ' '
              if brand_category contains normalized_slug
                assign category_count = category_count | plus: 1
              endif
            endfor
          endif
        %}
        <a class="trg-brand-directory__sidebar-link{% if forloop.first %} is-active{% endif %}" href="#{{ category_slug }}">
          <span>{{ category_label }}</span>
          <span>{{ category_count }}</span>
        </a>
      {% endfor %}
    </aside>

    <div class="trg-brand-directory__content">
      <div class="trg-brand-directory__search-wrap">
        <label class="visually-hidden" for="trg-brand-directory-search">Search brands</label>
        <div class="trg-brand-directory__search">
          <span class="trg-brand-directory__search-icon" aria-hidden="true">
            {{- 'icon-search.svg' | inline_asset_content -}}
          </span>
          <input
            id="trg-brand-directory-search"
            class="trg-brand-directory__search-input"
            type="search"
            placeholder="Search brands..."
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-trg-brand-directory-search
          >
        </div>
      </div>

      <div class="trg-brand-directory__intro" id="all">
        <h1 class="trg-brand-directory__title">All Brands</h1>
        <p class="trg-brand-directory__subtitle">{{ total_brands }} brand profiles</p>
      </div>

      <div class="trg-brand-directory__all-links" data-trg-brand-directory-list>
        {% for brand in brand_entries %}
          {% liquid
            assign brand_name_field = brand.name
            assign brand_name = brand_name_field.value | default: brand_name_field | default: brand.handle

            assign brand_category_field = brand.primary_category
            assign brand_category = brand_category_field.value | default: brand_category_field | downcase

            capture brand_link
              render 'trg-brand-page-url', brand_item: brand
            endcapture
            assign brand_link = brand_link | strip
          %}
          <a
            class="trg-brand-directory__brand-link"
            href="{{ brand_link }}"
            data-brand-name="{{ brand_name | downcase | escape }}"
            data-brand-category="{{ brand_category | escape }}"
          >
            {{ brand_name }}
          </a>
        {% endfor %}
      </div>

      {% for category_entry in category_map offset: 1 %}
        {% liquid
          assign category_parts = category_entry | split: '::'
          assign category_label = category_parts[0]
          assign category_slug = category_parts[1]
          assign normalized_slug = category_slug | replace: '-', ' '
          assign section_count = 0
        %}
        <section class="trg-brand-directory__group" id="{{ category_slug }}">
          <div class="trg-brand-directory__group-head">
            <h2 class="trg-brand-directory__group-title">{{ category_label }}</h2>
            {% for brand in brand_entries %}
              {% liquid
                assign brand_category_field = brand.primary_category
                assign brand_category = brand_category_field.value | default: brand_category_field | downcase
                if brand_category contains normalized_slug
                  assign section_count = section_count | plus: 1
                endif
              %}
            {% endfor %}
            <span class="trg-brand-directory__group-count">{{ section_count }} brands</span>
          </div>
          <div class="trg-brand-directory__group-links">
            {% for brand in brand_entries %}
              {% liquid
                assign brand_name_field = brand.name
                assign brand_name = brand_name_field.value | default: brand_name_field | default: brand.handle
                assign brand_category_field = brand.primary_category
                assign brand_category = brand_category_field.value | default: brand_category_field | downcase

                capture brand_link
                  render 'trg-brand-page-url', brand_item: brand
                endcapture
                assign brand_link = brand_link | strip
              %}
              {% if brand_category contains normalized_slug %}
                <a
                  class="trg-brand-directory__brand-link"
                  href="{{ brand_link }}"
                  data-brand-name="{{ brand_name | downcase | escape }}"
                  data-brand-category="{{ brand_category | escape }}"
                >
                  {{ brand_name }}
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </div>

    <aside class="trg-brand-directory__featured">
      {% if featured_brand != blank %}
        {% liquid
          assign featured_name_field = featured_brand.name
          assign featured_name = featured_name_field.value | default: featured_name_field | default: featured_brand.handle

          assign featured_category_field = featured_brand.primary_category
          assign featured_category = featured_category_field.value | default: featured_category_field

          assign featured_country_field = featured_brand.country
          assign featured_country = featured_country_field.value | default: featured_country_field

          assign featured_copy_field = featured_brand.description
          assign featured_copy = featured_copy_field.value | default: featured_copy_field

          assign featured_logo_field = featured_brand.logo
          assign featured_logo = featured_logo_field.value | default: featured_logo_field
          if featured_logo != blank and featured_logo.preview_image != blank
            assign featured_logo = featured_logo.preview_image
          endif

          capture featured_link
            render 'trg-brand-page-url', brand_item: featured_brand
          endcapture
          assign featured_link = featured_link | strip
        %}

        <div class="trg-brand-directory__featured-label">Featured brand</div>
        <a class="trg-brand-directory__featured-card" href="{{ featured_link }}">
          <div class="trg-brand-directory__featured-media">
            {% if featured_logo != blank %}
              {{
                featured_logo
                | image_url: width: 420
                | image_tag:
                  loading: 'lazy',
                  widths: '200, 320, 420',
                  sizes: '180px',
                  alt: featured_name
              }}
            {% else %}
              <span>{{ featured_name | slice: 0, 2 | upcase }}</span>
            {% endif %}
          </div>
          <div class="trg-brand-directory__featured-body">
            {% if featured_category != blank or featured_country != blank %}
              <div class="trg-brand-directory__featured-meta">
                {{ featured_category }}{% if featured_category != blank and featured_country != blank %} · {% endif %}{{ featured_country }}
              </div>
            {% endif %}
            <div class="trg-brand-directory__featured-title">{{ featured_name }}</div>
            {% if featured_copy != blank %}
              <div class="trg-brand-directory__featured-copy">{{ featured_copy | strip_html | truncate: 120 }}</div>
            {% endif %}
            <div class="trg-brand-directory__featured-cta">View brand</div>
          </div>
        </a>
      {% endif %}
    </aside>
  </div>
</section>

<script>
  (() => {
    const section = document.currentScript?.closest('.shopify-section');
    const root = section?.querySelector('.trg-brand-directory');
    if (!root || !root.classList.contains('trg-brand-directory')) return;

    const searchInput = root.querySelector('[data-trg-brand-directory-search]');
    const links = root.querySelectorAll('[data-brand-name]');

    if (!searchInput || !links.length) return;

    const handleSearch = () => {
      const term = searchInput.value.trim().toLowerCase();

      links.forEach((link) => {
        const name = link.dataset.brandName || '';
        const category = link.dataset.brandCategory || '';
        const match = term === '' || name.includes(term) || category.includes(term);
        link.hidden = !match;
      });
    };

    searchInput.addEventListener('input', handleSearch);
  })();
</script>

{% stylesheet %}
  .trg-brand-directory {
    --trg-brand-ink: #1a1a18;
    --trg-brand-paper: #f5f1eb;
    --trg-brand-panel: #221f1b;
    --trg-brand-panel-2: #2b2723;
    --trg-brand-border: rgba(245, 241, 235, 0.1);
    --trg-brand-muted: rgba(245, 241, 235, 0.45);
    --trg-brand-accent: #c4562a;
    background: linear-gradient(180deg, #f2eee8 0%, #f5f1eb 100%);
    color: var(--trg-brand-ink);
    padding-block: 28px 56px;
  }

  .trg-brand-directory__shell {
    display: grid;
    gap: 0;
    background: var(--trg-brand-panel);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 22px 48px rgba(24, 18, 10, 0.18);
  }

  .trg-brand-directory__sidebar,
  .trg-brand-directory__featured {
    background: var(--trg-brand-panel);
    color: #f5f1eb;
    padding: 20px;
  }

  .trg-brand-directory__sidebar {
    border-bottom: 1px solid var(--trg-brand-border);
  }

  .trg-brand-directory__sidebar-label,
  .trg-brand-directory__featured-label {
    color: rgba(196, 86, 42, 0.95);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .trg-brand-directory__sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 0.75rem 0.9rem;
    color: var(--trg-brand-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    background: transparent;
    transition: color 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }

  .trg-brand-directory__sidebar-link.is-active,
  .trg-brand-directory__sidebar-link:hover {
    color: #fff;
    background: rgba(196, 86, 42, 0.12);
    border-left-color: var(--trg-brand-accent);
  }

  .trg-brand-directory__content {
    padding: 24px;
    background: #23201c;
    color: #f5f1eb;
  }

  .trg-brand-directory__search-wrap {
    margin-bottom: 24px;
  }

  .trg-brand-directory__search {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 46px;
    border: 1px solid rgba(245, 241, 235, 0.14);
    background: rgba(255, 255, 255, 0.04);
    padding: 0 14px;
  }

  .trg-brand-directory__search-icon {
    color: rgba(245, 241, 235, 0.38);
    width: 16px;
    height: 16px;
    display: inline-flex;
  }

  .trg-brand-directory__search-icon svg {
    width: 100%;
    height: 100%;
  }

  .trg-brand-directory__search-input {
    width: 100%;
    border: 0;
    background: transparent;
    color: #f5f1eb;
    font-size: 0.92rem;
    padding: 0;
    box-shadow: none;
    appearance: none;
  }

  .trg-brand-directory__search-input::placeholder {
    color: rgba(245, 241, 235, 0.34);
    font-style: italic;
  }

  .trg-brand-directory__search-input:focus {
    outline: 0;
  }

  .trg-brand-directory__intro {
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(245, 241, 235, 0.08);
  }

  .trg-brand-directory__title,
  .trg-brand-directory__group-title {
    margin: 0;
    font-family: var(--font-heading--family);
    color: #fff;
  }

  .trg-brand-directory__title {
    font-size: clamp(1.9rem, 3vw, 2.6rem);
  }

  .trg-brand-directory__subtitle,
  .trg-brand-directory__group-count {
    margin: 0.5rem 0 0;
    color: rgba(245, 241, 235, 0.42);
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .trg-brand-directory__all-links,
  .trg-brand-directory__group-links {
    display: grid;
    gap: 8px 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 18px;
  }

  .trg-brand-directory__group {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(245, 241, 235, 0.08);
  }

  .trg-brand-directory__group-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
  }

  .trg-brand-directory__brand-link {
    color: rgba(245, 241, 235, 0.78);
    text-decoration: none;
    line-height: 1.55;
  }

  .trg-brand-directory__brand-link:hover {
    color: #fff;
  }

  .trg-brand-directory__featured {
    border-top: 1px solid var(--trg-brand-border);
  }

  .trg-brand-directory__featured-card {
    display: block;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--trg-brand-border);
    background: var(--trg-brand-panel-2);
  }

  .trg-brand-directory__featured-media {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    overflow: hidden;
    font-family: var(--font-heading--family);
    font-size: 2rem;
    color: rgba(245, 241, 235, 0.45);
  }

  .trg-brand-directory__featured-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trg-brand-directory__featured-body {
    padding: 16px;
  }

  .trg-brand-directory__featured-meta {
    color: rgba(196, 86, 42, 0.95);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .trg-brand-directory__featured-title {
    margin-top: 8px;
    font-family: var(--font-heading--family);
    font-size: 1.35rem;
    color: #fff;
  }

  .trg-brand-directory__featured-copy {
    margin-top: 10px;
    color: rgba(245, 241, 235, 0.62);
    line-height: 1.7;
    font-size: 0.84rem;
  }

  .trg-brand-directory__featured-cta {
    margin-top: 14px;
    color: var(--trg-brand-accent);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .trg-brand-directory__all-links,
    .trg-brand-directory__group-links {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 1100px) {
    .trg-brand-directory__shell {
      grid-template-columns: 240px minmax(0, 1fr) 260px;
    }

    .trg-brand-directory__sidebar {
      border-bottom: 0;
      border-right: 1px solid var(--trg-brand-border);
    }

    .trg-brand-directory__featured {
      border-top: 0;
      border-left: 1px solid var(--trg-brand-border);
    }

    .trg-brand-directory__all-links,
    .trg-brand-directory__group-links {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Brand Directory",
  "tag": "section",
  "class": "trg-brand-directory-section",
  "settings": [
    {
      "type": "text",
      "id": "featured_brand_handle",
      "label": "Featured brand handle",
      "default": "viberg"
    }
  ],
  "presets": [
    {
      "name": "TRG Brand Directory"
    }
  ]
}
{% endschema %}
