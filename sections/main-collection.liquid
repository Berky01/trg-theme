  (() => {
    const url = new URL(window.location.href);
    if (url.hash) {
      document.addEventListener(
        'DOMContentLoaded',
        () => {
          const card = document.getElementById(url.hash.slice(1));
          if (card) {
            card.scrollIntoView({ behavior: 'instant' });
          }
        },
        { once: true }
      );
    }

    const FILTER_STORAGE_KEY = 'trg_filters_open';
    const WISHLIST_STORAGE_KEY = 'trg_plp_saved_products';

    const normalizeText = (value) => (value || '').toString().trim().toLowerCase();
    const escapeHtml = (value) =>
      (value || '')
        .toString()
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    class TrgPlpController {
      constructor(root) {
        this.root = root;
        this.syncTimeout = null;
        this.handleClick = this.handleClick.bind(this);
        this.handleChange = this.handleChange.bind(this);
        this.handleInput = this.handleInput.bind(this);
        this.handleScroll = this.handleScroll.bind(this);
        this.handleUrlChange = this.handleUrlChange.bind(this);
      }

      connect() {
        if (this.root.dataset.trgPlpReady === 'true') return;

        this.root.dataset.trgPlpReady = 'true';
        this.installHistoryHooks();
        this.restoreFilterState();

        document.addEventListener('click', this.handleClick);
        document.addEventListener('change', this.handleChange, true);
        document.addEventListener('input', this.handleInput, true);
        window.addEventListener('scroll', this.handleScroll, { passive: true });
        window.addEventListener('trg:url-changed', this.handleUrlChange);
        document.addEventListener('shopify:section:load', this.handleUrlChange);

        const searchInput = document.querySelector('[data-trg-search-input]');
        if (searchInput?.form) {
          searchInput.form.addEventListener('submit', (event) => {
            event.preventDefault();
            this.applySearch();
          });
        }

        this.syncSortSelect();
        this.renderActiveTags();
        this.applySearch();
        this.syncWishlistState();
        this.updateBackToTop();
      }

      installHistoryHooks() {
        if (window.__trgPlpHistoryPatched) return;

        window.__trgPlpHistoryPatched = true;
        const dispatch = () => window.dispatchEvent(new Event('trg:url-changed'));

        for (const method of ['pushState', 'replaceState']) {
          const original = history[method];
          history[method] = function patchedHistoryState(...args) {
            const result = original.apply(this, args);
            dispatch();
            return result;
          };
        }

        window.addEventListener('popstate', dispatch);
      }

      restoreFilterState() {
        const storedState = window.localStorage.getItem(FILTER_STORAGE_KEY);
        document.body.classList.toggle('filters-hidden', storedState === '0');
      }

      handleUrlChange() {
        this.scheduleSync();
      }

      handleInput(event) {
        if (event.target instanceof HTMLInputElement && event.target.matches('[data-trg-search-input]')) {
          this.applySearch();
        }
      }

      handleChange(event) {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        if (target.matches('[data-trg-plp-sort]')) {
          const sortValue = target.value;
          const nextUrl = new URL(window.location.href);
          nextUrl.searchParams.delete('page');
          if (sortValue) {
            nextUrl.searchParams.set('sort_by', sortValue);
          } else {
            nextUrl.searchParams.delete('sort_by');
          }
          window.location.assign(nextUrl.toString());
          return;
        }

        if (
          target.matches(
            '.facets input, .facets select, .sorting-filter input, .sorting-filter select, .price-facet input'
          )
        ) {
          this.scheduleSync();
        }
      }

      handleClick(event) {
        const target = event.target instanceof Element ? event.target : null;
        if (!target) return;

        const toggleButton = target.closest('[data-trg-plp-filter-toggle]');
        if (toggleButton) {
          event.preventDefault();
          if (window.matchMedia('(max-width: 989px)').matches) {
            const dialog = document.querySelector('dialog-component#filters-drawer');
            if (dialog && typeof dialog.showDialog === 'function') {
              dialog.showDialog();
            } else {
              document.querySelector('.facets-toggle__button')?.click();
            }
            return;
          }
          const hidden = !document.body.classList.contains('filters-hidden');
          document.body.classList.toggle('filters-hidden', hidden);
          window.localStorage.setItem(FILTER_STORAGE_KEY, hidden ? '0' : '1');
          return;
        }

        const mobileFilterButton = target.closest('[data-trg-plp-mobile-filter-button]');
        if (mobileFilterButton) {
          event.preventDefault();
          const dialog = document.querySelector('dialog-component#filters-drawer');
          if (dialog && typeof dialog.showDialog === 'function') {
            dialog.showDialog();
          } else {
            document.querySelector('.facets-toggle__button')?.click();
          }
          return;
        }

        const searchPill = target.closest('[data-trg-search-pill]');
        if (searchPill instanceof HTMLElement) {
          event.preventDefault();
          const searchInput = document.querySelector('[data-trg-search-input]');
          if (searchInput instanceof HTMLInputElement) {
            searchInput.value = searchPill.dataset.trgSearchPill || '';
            this.applySearch();
          }
          return;
        }

        const activeTag = target.closest('[data-trg-active-tag]');
        if (activeTag instanceof HTMLElement) {
          event.preventDefault();
          this.removeActiveTag(activeTag.dataset);
          return;
        }

        const toggleFilter = target.closest('[data-trg-toggle]');
        if (toggleFilter instanceof HTMLButtonElement) {
          event.preventDefault();
          const isPressed = toggleFilter.getAttribute('aria-pressed') === 'true';
          toggleFilter.setAttribute('aria-pressed', String(!isPressed));
          this.renderActiveTags();
          this.applySearch();
          return;
        }

        const loadMoreButton = target.closest('[data-trg-load-more-btn]');
        if (loadMoreButton instanceof HTMLAnchorElement) {
          event.preventDefault();
          this.loadMore(loadMoreButton);
          return;
        }

        const wishlistButton = target.closest('[data-trg-wishlist]');
        if (wishlistButton instanceof HTMLButtonElement) {
          event.preventDefault();
          event.stopPropagation();
          this.toggleWishlist(wishlistButton);
          return;
        }

        const backToTop = target.closest('[data-trg-back-to-top]');
        if (backToTop instanceof HTMLButtonElement) {
          event.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }

      scheduleSync() {
        window.clearTimeout(this.syncTimeout);
        this.syncTimeout = window.setTimeout(() => {
          this.syncSortSelect();
          this.renderActiveTags();
          this.applySearch();
        }, 90);
      }

      syncSortSelect() {
        const sortSelect = document.querySelector('[data-trg-plp-sort]');
        if (!(sortSelect instanceof HTMLSelectElement)) return;

        const sourceSelect =
          Array.from(document.querySelectorAll('select[name="sort_by"]')).find((select) => !select.disabled) ||
          document.querySelector('select[name="sort_by"]');
        if (!(sourceSelect instanceof HTMLSelectElement)) return;

        const sourceSignature = Array.from(sourceSelect.options)
          .map((option) => `${option.value}:${option.textContent?.trim()}`)
          .join('|');

        if (sortSelect.dataset.sourceSignature !== sourceSignature) {
          sortSelect.innerHTML = '';
          for (const option of sourceSelect.options) {
            sortSelect.append(
              new Option(option.textContent?.trim() || option.value, option.value, option.selected, option.selected)
            );
          }
          sortSelect.dataset.sourceSignature = sourceSignature;
        }

        const currentSort = new URL(window.location.href).searchParams.get('sort_by') || sourceSelect.value;
        sortSelect.value = currentSort;
      }

      getSearchCards() {
        return Array.from(this.root.querySelectorAll('[data-trg-search-item]'));
      }

      getActiveToggles() {
        const active = new Set();

        for (const button of document.querySelectorAll('[data-trg-toggle]')) {
          if (!(button instanceof HTMLButtonElement)) continue;
          if (button.getAttribute('aria-pressed') === 'true' && button.dataset.trgToggle) {
            active.add(button.dataset.trgToggle);
          }
        }

        return active;
      }

      getToggleLabel(toggleName) {
        const label = document.querySelector(`[data-trg-toggle="${toggleName}"] .trg-plp-toggle-label`);
        return label?.textContent?.trim() || '';
      }

      matchesToggleFilters(card, activeToggles) {
        if (activeToggles.size === 0) return true;
        if (activeToggles.has('ships-ca') && card.dataset.trgShipsCa !== 'true') return false;
        if (activeToggles.has('on-sale') && card.dataset.trgOnSale !== 'true') return false;
        if (activeToggles.has('new-arrivals') && card.dataset.trgNewArrivals !== 'true') return false;
        return true;
      }

      applySearch() {
        const searchInput = document.querySelector('[data-trg-search-input]');
        const query = normalizeText(searchInput?.value);
        const cards = this.getSearchCards();
        const activeToggles = this.getActiveToggles();
        let visibleCount = 0;

        for (const card of cards) {
          const cardText = normalizeText(card.getAttribute('data-trg-search-text'));
          const matchesQuery = query === '' || cardText.includes(query);
          const matches = matchesQuery && this.matchesToggleFilters(card, activeToggles);
          card.hidden = !matches;
          if (matches) visibleCount += 1;
        }

        const searchEmpty = document.querySelector('[data-trg-search-empty]');
        if (searchEmpty instanceof HTMLElement) {
          searchEmpty.hidden = visibleCount !== 0 || query === '';
        }
      }

      resolveInputLabel(input) {
        if (input instanceof HTMLInputElement && input.dataset.label) return input.dataset.label;

        if (!(input instanceof HTMLInputElement)) return '';

        if (input.id) {
          const parentLabel = document.querySelector(`label[for="${input.id}"]`);
          const textTarget =
            parentLabel?.querySelector('.checkbox__label-text, .facets__pill-label, .facets__swatch-label') ||
            parentLabel;
          return textTarget?.textContent?.trim() || '';
        }

        return '';
      }

      renderActiveTags() {
        const container = document.querySelector('[data-trg-active-tags]');
        if (!(container instanceof HTMLElement)) return;

        const chips = [];
        const filterInputs = document.querySelectorAll(
          '.facets--vertical input[type="checkbox"]:checked, .facets--vertical input[type="radio"]:checked'
        );

        for (const input of filterInputs) {
          const label = this.resolveInputLabel(input);
          if (label) {
            chips.push({
              kind: 'input',
              label,
              name: input.name,
              value: input.value
            });
          }
        }

        const minPriceInput = document.querySelector('input[name="filter.v.price.gte"]');
        const maxPriceInput = document.querySelector('input[name="filter.v.price.lte"]');
        if (minPriceInput instanceof HTMLInputElement && minPriceInput.value.trim() !== '') {
          chips.push({
            kind: 'price-min',
            label: `Min $${minPriceInput.value.trim()}`
          });
        }
        if (maxPriceInput instanceof HTMLInputElement && maxPriceInput.value.trim() !== '') {
          chips.push({
            kind: 'price-max',
            label: `Max $${maxPriceInput.value.trim()}`
          });
        }

        for (const toggle of this.getActiveToggles()) {
          const label = this.getToggleLabel(toggle);
          if (!label) continue;
          chips.push({
            kind: 'toggle',
            label,
            toggle
          });
        }

        container.innerHTML = chips
          .map((chip) => {
            const attrs = Object.entries(chip)
              .map(([key, value]) => `data-${key === 'kind' ? 'kind' : key}="${escapeHtml(value)}"`)
              .join(' ');
            return `<button type="button" class="button-unstyled trg-search-bar__active-tag" data-trg-active-tag ${attrs}>${escapeHtml(
              chip.label
            )}<span>✕</span></button>`;
          })
          .join('');
      }

      removeActiveTag(data) {
        const kind = data.kind || '';
        if (kind === 'toggle') {
          const toggleName = data.toggle || '';
          const button = document.querySelector(`[data-trg-toggle="${toggleName}"]`);
          if (button instanceof HTMLButtonElement) {
            button.setAttribute('aria-pressed', 'false');
            this.renderActiveTags();
            this.applySearch();
          }
          return;
        }

        if (kind === 'price-min' || kind === 'price-max') {
          const selector = kind === 'price-min' ? 'input[name="filter.v.price.gte"]' : 'input[name="filter.v.price.lte"]';
          const input = document.querySelector(selector);
          if (input instanceof HTMLInputElement) {
            input.value = '';
            input.dispatchEvent(new Event('change', { bubbles: true }));
          }
          return;
        }

        const name = data.name || '';
        const value = data.value || '';
        if (!name) return;

        const matchingInput = Array.from(document.querySelectorAll('input')).find(
          (input) => input instanceof HTMLInputElement && input.name === name && input.value === value
        );

        if (matchingInput instanceof HTMLInputElement) {
          matchingInput.checked = false;
          matchingInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      async loadMore(button) {
        if (button.dataset.loading === 'true') return;

        const nextUrl = button.href;
        if (!nextUrl) return;

        button.dataset.loading = 'true';
        button.setAttribute('aria-busy', 'true');
        const originalLabel = button.textContent;
        button.textContent = 'Loading...';

        try {
          const response = await fetch(nextUrl, { credentials: 'same-origin' });
          if (!response.ok) return;

          const html = await response.text();
          const nextDocument = new DOMParser().parseFromString(html, 'text/html');
          const nextItems = nextDocument.querySelectorAll('#ResultsList .product-grid__item');
          const grid = this.root.querySelector('.product-grid');
          if (!(grid instanceof HTMLElement)) return;

          for (const item of nextItems) {
            grid.insertAdjacentHTML('beforeend', item.outerHTML);
          }

          const nextZone = nextDocument.querySelector('[data-trg-load-more-zone]');
          const currentZone = this.root.querySelector('[data-trg-load-more-zone]');
          if (nextZone && currentZone) {
            currentZone.replaceWith(nextZone);
          }

          const pushedUrl = new URL(nextUrl, window.location.href);
          history.replaceState({}, '', `${pushedUrl.pathname}${pushedUrl.search}${pushedUrl.hash}`);
          this.syncWishlistState();
          this.scheduleSync();
        } catch (error) {
          console.error('Failed to load more products.', error);
          button.textContent = originalLabel || 'Load more';
        } finally {
          button.dataset.loading = 'false';
          button.removeAttribute('aria-busy');
        }
      }

      getWishlistIds() {
        try {
          return JSON.parse(window.localStorage.getItem(WISHLIST_STORAGE_KEY) || '[]');
        } catch (error) {
          return [];
        }
      }

      syncWishlistState() {
        const savedIds = new Set(this.getWishlistIds().map(String));
        for (const button of document.querySelectorAll('[data-trg-wishlist]')) {
          if (!(button instanceof HTMLButtonElement)) continue;
          const productId = button.dataset.productId || '';
          const isSaved = savedIds.has(productId);
          button.classList.toggle('saved', isSaved);
          button.setAttribute('aria-pressed', String(isSaved));
        }
      }

      toggleWishlist(button) {
        const productId = button.dataset.productId;
        if (!productId) return;

        const savedIds = new Set(this.getWishlistIds().map(String));
        if (savedIds.has(productId)) {
          savedIds.delete(productId);
        } else {
          savedIds.add(productId);
        }

        window.localStorage.setItem(WISHLIST_STORAGE_KEY, JSON.stringify(Array.from(savedIds)));
        this.syncWishlistState();
      }

      updateBackToTop() {
        const button = document.querySelector('[data-trg-back-to-top]');
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle('visible', window.scrollY > window.innerHeight * 1.5);
      }

      handleScroll() {
        this.updateBackToTop();
      }
    }

    const initializeTrgPlp = () => {
      document.querySelectorAll('.trg-plp-body').forEach((root) => {
        const controller = new TrgPlpController(root);
        controller.connect();
      });
    };

    document.addEventListener('DOMContentLoaded', initializeTrgPlp, { once: true });
    document.addEventListener('shopify:section:load', initializeTrgPlp);
  })();
{% endjavascript %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container trg-plp-body color-{{ section.settings.color_scheme }}"
  style="
    --padding-block-start: {{ section.settings.padding-block-start }}px;
    --padding-block-end: {{ section.settings.padding-block-end }}px;
    --trg-plp-shell-max-width: {{ section.settings.trg_plp_shell_max_width }}px;
    --trg-plp-sidebar-width: {{ section.settings.trg_plp_sidebar_width }}px;
    --trg-plp-layout-gap: {{ section.settings.trg_plp_layout_gap }}px;
    --trg-plp-toolbar-gap: {{ section.settings.trg_plp_toolbar_gap }}px;
    --trg-plp-sidebar-padding: {{ section.settings.trg_plp_sidebar_padding }}px;
    --trg-plp-caption-padding: {{ section.settings.trg_plp_caption_padding }}px;
    --trg-plp-page-background: {{ section.settings.trg_plp_page_background }};
    --trg-plp-panel-background: {{ section.settings.trg_plp_panel_background }};
    --trg-plp-card-background: {{ section.settings.trg_plp_card_background }};
    --trg-plp-caption-background: {{ section.settings.trg_plp_caption_background }};
    --trg-plp-border-color: {{ section.settings.trg_plp_border_color }};
    --trg-plp-text-color: {{ section.settings.trg_plp_text_color }};
    --trg-plp-muted-color: {{ section.settings.trg_plp_muted_color }};
    --trg-plp-sale-background: {{ section.settings.trg_plp_sale_background }};
    --trg-plp-sale-text: {{ section.settings.trg_plp_sale_text }};
    --trg-plp-cta-background: {{ section.settings.trg_plp_cta_background }};
    --trg-plp-cta-text: {{ section.settings.trg_plp_cta_text }};
    --trg-plp-cta-hover: {{ section.settings.trg_plp_cta_hover }};
    --trg-plp-image-ratio: {{ section.settings.trg_plp_image_ratio }};
    --trg-plp-image-position: {{ section.settings.trg_plp_image_position }};
  "
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% for product in collection.products %}
          {% liquid
            assign product_tags = product.tags | join: ' '
            assign material_search = product.metafields.custom.material.value | default: product.metafields.custom.material
            assign ships_to_canada = false
            assign is_new_arrival = false
            assign is_on_sale = false
            if material_search == blank
              assign material_search = product.metafields.custom.fabric.value | default: product.metafields.custom.fabric
            endif
            if material_search == blank
              assign material_search = product.metafields.details.material.value | default: product.metafields.details.material
            endif
            if material_search == blank
              assign material_search = product.metafields.custom.primary_material.value | default: product.metafields.custom.primary_material
            endif
            assign color_search = product.metafields.custom.color.value | default: product.metafields.custom.color
            if color_search == blank
              assign color_search = product.metafields.details.color.value | default: product.metafields.details.color
            endif
            assign ships_to_canada_meta = product.metafields.custom.ships_to_canada.value | default: product.metafields.custom.ships_to_canada
            if ships_to_canada_meta == blank
              assign ships_to_canada_meta = product.metafields.custom.shipsToCanada.value | default: product.metafields.custom.shipsToCanada
            endif
            if ships_to_canada_meta == blank
              assign ships_to_canada_meta = product.metafields.custom.ships_canada.value | default: product.metafields.custom.ships_canada
            endif
            if ships_to_canada_meta == true or ships_to_canada_meta == 'true' or ships_to_canada_meta == '1'
              assign ships_to_canada = true
            endif
            assign new_flag = product.metafields.custom.is_new.value | default: product.metafields.custom.is_new
            if new_flag == blank
              assign new_flag = product.metafields.custom.new_arrival.value | default: product.metafields.custom.new_arrival
            endif
            if new_flag == blank
              assign new_flag = product.metafields.custom.newArrival.value | default: product.metafields.custom.newArrival
            endif
            if new_flag == true or new_flag == 'true' or new_flag == '1'
              assign is_new_arrival = true
            endif
            if product.compare_at_price > product.price
              assign is_on_sale = true
            endif
            if ships_to_canada == false or is_new_arrival == false
              for tag in product.tags
                assign normalized_tag = tag | downcase | strip
                if ships_to_canada == false
                  case normalized_tag
                    when 'ships-to-canada', 'ships to canada', 'ships_to_canada', 'shipscanada'
                      assign ships_to_canada = true
                  endcase
                endif
                if is_new_arrival == false
                  case normalized_tag
                    when 'new', 'new arrival', 'new-arrival', 'new arrivals', 'new-arrivals', 'new_arrival'
                      assign is_new_arrival = true
                  endcase
                endif
              endfor
            endif
            capture searchable_text
              echo product.title
              echo ' '
              echo product.vendor
              echo ' '
              echo product.type
              echo ' '
              echo material_search
              echo ' '
              echo color_search
              echo ' '
              echo product_tags
            endcapture
            assign searchable_text = searchable_text | strip | downcase | escape
            assign card_delay = forloop.index0 | modulo: products_per_page | times: 25
          %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            data-trg-search-item
            data-trg-search-text="{{ searchable_text }}"
            data-trg-ships-ca="{% if ships_to_canada %}true{% else %}false{% endif %}"
            data-trg-on-sale="{% if is_on_sale %}true{% else %}false{% endif %}"
            data-trg-new-arrivals="{% if is_new_arrival %}true{% else %}false{% endif %}"
            style="--trg-plp-card-delay: {{ card_delay }}ms;"
            ref="cards[]"
          >
            {% # theme-check-disable %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            {% # theme-check-enable %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>




