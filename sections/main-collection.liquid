

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container trg-plp-body color-{{ section.settings.color_scheme }}"
  style="
    --padding-block-start: {{ section.settings.padding-block-start }}px;
    --padding-block-end: {{ section.settings.padding-block-end }}px;
    --trg-plp-shell-max-width: {{ section.settings.trg_plp_shell_max_width }}px;
    --trg-plp-sidebar-width: {{ section.settings.trg_plp_sidebar_width }}px;
    --trg-plp-layout-gap: {{ section.settings.trg_plp_layout_gap }}px;
    --trg-plp-toolbar-gap: {{ section.settings.trg_plp_toolbar_gap }}px;
    --trg-plp-sidebar-padding: {{ section.settings.trg_plp_sidebar_padding }}px;
    --trg-plp-caption-padding: {{ section.settings.trg_plp_caption_padding }}px;
    --trg-plp-page-background: {{ section.settings.trg_plp_page_background }};
    --trg-plp-panel-background: {{ section.settings.trg_plp_panel_background }};
    --trg-plp-card-background: {{ section.settings.trg_plp_card_background }};
    --trg-plp-caption-background: {{ section.settings.trg_plp_caption_background }};
    --trg-plp-border-color: {{ section.settings.trg_plp_border_color }};
    --trg-plp-text-color: {{ section.settings.trg_plp_text_color }};
    --trg-plp-muted-color: {{ section.settings.trg_plp_muted_color }};
    --trg-plp-sale-background: {{ section.settings.trg_plp_sale_background }};
    --trg-plp-sale-text: {{ section.settings.trg_plp_sale_text }};
  "
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% for product in collection.products %}
          {% liquid
            assign product_tags = product.tags | join: ' '
            capture searchable_text
              echo product.title
              echo ' '
              echo product.vendor
              echo ' '
              echo product.type
              echo ' '
              echo product_tags
            endcapture
            assign searchable_text = searchable_text | strip | downcase | escape
          %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            data-trg-search-item
            data-trg-search-text="{{ searchable_text }}"
            ref="cards[]"
          >
            {% # theme-check-disable %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            {% # theme-check-enable %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>

{% stylesheet %}
  .trg-plp-body {
    background: var(--trg-plp-page-background);
    color: var(--trg-plp-text-color);
  }

  .trg-plp-body .collection-wrapper {
    width: min(calc(100% - (var(--page-margin) * 2)), var(--trg-plp-shell-max-width));
    margin-inline: auto;
  }

  .trg-plp-body .collection-wrapper {
    row-gap: 0;
  }

  .trg-plp-body .main-collection-grid {
    display: block;
    padding: 0;
  }

  .trg-plp-body .main-collection-grid > div[style*='container-name: product-grid'] {
    width: 100%;
  }

  .trg-plp-body .trg-collection-controls {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
    padding: 0 0 var(--trg-plp-toolbar-gap);
    border: 0;
    background: transparent;
  }

  .trg-plp-body .trg-collection-controls .facets--filters-title,
  .trg-plp-body .trg-collection-controls__active-filters {
    display: none;
  }

  .trg-plp-body .products-count-wrapper {
    margin: 0;
  }

  .trg-plp-body .products-count-wrapper span {
    color: var(--trg-plp-muted-color);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .trg-plp-body .sorting-filter {
    z-index: 4;
  }

  .trg-plp-body .sorting-filter .facets__panel {
    padding: 0;
    border: 0;
  }

  .trg-plp-body .sorting-filter .facets__summary {
    min-height: 34px;
    padding: 0 11px;
    gap: 8px;
    border: 1px solid var(--trg-plp-border-color);
    background: var(--trg-plp-caption-background);
    color: var(--trg-plp-muted-color);
    align-items: center;
  }

  .trg-plp-body .sorting-filter .facets__summary:hover {
    background: var(--trg-plp-caption-background);
  }

  .trg-plp-body .sorting-filter .facets__label {
    color: inherit;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: normal;
    text-transform: none;
  }

  .trg-plp-body .sorting-filter .sorting-filter__status {
    display: none;
  }

  .trg-plp-body .sorting-filter__options {
    border: 1px solid var(--trg-plp-border-color);
    background: var(--trg-plp-caption-background);
    box-shadow: none;
  }

  .trg-plp-body .sorting-filter__option {
    color: var(--trg-plp-text-color);
  }

  .trg-plp-body .sorting-filter__option:hover {
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .trg-plp-body .facets-block-wrapper--vertical {
    margin: 0;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) {
    background: var(--trg-plp-panel-background);
    border: 1px solid var(--trg-plp-border-color);
    padding: var(--trg-plp-sidebar-padding);
    color: var(--trg-plp-text-color);
    max-width: var(--trg-plp-sidebar-width);
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__form-wrapper {
    display: block;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets-remove--mobile-and-vertical {
    display: none !important;
  }

  .trg-plp-body .trg-facets-sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--trg-plp-border-color);
  }

  .trg-plp-body .trg-facets-sidebar-title {
    margin: 0;
    color: var(--trg-plp-muted-color);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .trg-plp-body .trg-facets-sidebar-clear {
    display: none;
  }

  .trg-plp-body .trg-facets-sidebar-clear--active {
    display: block;
  }

  .trg-plp-body .trg-facets-sidebar-clear-button {
    color: var(--trg-plp-muted-color);
    font-size: 12px;
  }

  .trg-plp-body .trg-facets-sidebar-clear-button:hover {
    color: var(--trg-plp-text-color);
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__filters-wrapper {
    display: grid;
    gap: 0;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__item {
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid var(--trg-plp-border-color);
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__summary {
    min-height: auto;
    padding: 0;
    color: var(--trg-plp-text-color);
    align-items: center;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__summary:hover {
    background: transparent;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__label {
    color: var(--trg-plp-text-color);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__status {
    display: none;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__panel-content {
    position: static;
    padding: 14px 0 0;
    border: 0;
    box-shadow: none;
    background: transparent;
    min-width: 0;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__inputs-wrapper {
    padding: 0;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .facets__inputs-list {
    gap: 6px;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .checkbox__label {
    gap: 8px;
    color: var(--trg-plp-muted-color);
    font-size: 13px;
    line-height: 1.25;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .checkbox__label-text {
    color: inherit;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .checkbox__input:disabled + .checkbox__label {
    color: #b7b1a9;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .checkbox__label::before {
    width: 14px;
    height: 14px;
    border-color: var(--trg-plp-border-color);
    border-radius: 0;
    background: var(--color-background);
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet {
    container-type: normal;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__inputs-wrapper {
    display: grid !important;
    grid-template-columns: minmax(78px, 1fr) auto minmax(78px, 1fr);
    align-items: center;
    gap: 10px;
    padding: 0;
    flex-wrap: nowrap !important;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__field,
  .trg-plp-body .facets--vertical:not(.facets--drawer) .field {
    min-width: 0;
    width: 100%;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__field .field__input {
    min-height: 40px;
    border-color: var(--trg-plp-border-color);
    background: var(--trg-plp-caption-background);
    padding-left: 28px;
    padding-right: 10px;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__label,
  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__separator,
  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__highest-price {
    color: var(--trg-plp-muted-color);
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__separator {
    white-space: nowrap;
    font-size: 13px;
  }

  .trg-plp-body .facets--vertical:not(.facets--drawer) .price-facet__highest-price {
    max-width: 140px;
    padding-top: 14px;
    line-height: 1.35;
  }

  .trg-plp-body .product-grid {
    --product-grid-gap: 1px !important;
    background: var(--trg-plp-page-background);
  }

  .trg-plp-body .product-grid__item {
    background: var(--trg-plp-caption-background);
  }

  .trg-plp-body product-card,
  .trg-plp-body .product-card,
  .trg-plp-body .product-card__content,
  .trg-plp-body .product-grid__card {
    height: 100%;
  }

  .trg-plp-body .product-grid__card {
    gap: 0 !important;
    background: var(--trg-plp-caption-background);
  }

  .trg-plp-body .card-gallery {
    background: var(--trg-plp-card-background);
    aspect-ratio: 4 / 5;
    min-height: 320px;
    display: block;
  }

  .trg-plp-body .card-gallery slideshow-component,
  .trg-plp-body .card-gallery slideshow-slides,
  .trg-plp-body .card-gallery slideshow-slide,
  .trg-plp-body .card-gallery .product-media-container {
    height: 100%;
    min-height: 100%;
  }

  .trg-plp-body .card-gallery img,
  .trg-plp-body .card-gallery video,
  .trg-plp-body .card-gallery .media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trg-plp-body .product-card-gallery__title-placeholder {
    position: relative;
    display: block;
    height: 100%;
    min-height: 320px;
    padding: 0;
    background: transparent;
    color: var(--trg-plp-text-color);
    border-radius: 0;
    overflow: hidden;
  }

  .trg-plp-body .product-grid[data-product-card-size] .product-card-gallery__title-placeholder {
    padding: 0 !important;
  }

  .trg-plp-body .product-card-gallery__title-placeholder .contents {
    display: block;
    height: 100%;
    color: inherit;
  }

  .trg-plp-body .card-gallery.card-gallery--badge-top-left .product-card-gallery__title-placeholder,
  .trg-plp-body .card-gallery.card-gallery--badge-top-right .product-card-gallery__title-placeholder,
  .trg-plp-body .card-gallery.card-gallery--badge-bottom-left .product-card-gallery__title-placeholder {
    padding: 0 !important;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    height: 100%;
    padding: 18px;
    text-align: center;
  }

  .trg-plp-body .product-card-gallery__placeholder-mark {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 1.1rem + 1.8vw, 3.2rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1;
    opacity: 0.56;
  }

  .trg-plp-body .product-card-gallery__placeholder-type {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel--tone-1 {
    background: #f3efe8;
    color: #b8afa5;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel--tone-2 {
    background: #445b90;
    color: #bbc4da;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel--tone-3 {
    background: #ccb88b;
    color: #a58f6d;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel--tone-4 {
    background: #c9c3bc;
    color: #ece8e1;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel--tone-5 {
    background: #171716;
    color: #55534e;
  }

  .trg-plp-body .product-card-gallery__placeholder-panel--tone-6 {
    background: #587bb4;
    color: #c4d0e4;
  }

  .trg-plp-body .card-gallery:has(.product-card-gallery__title-placeholder) {
    background: transparent;
  }

  .trg-plp-body .card-gallery:has(.product-media-container) .product-card-gallery__title-placeholder {
    display: none;
  }

  .trg-plp-body .product-badges {
    position: absolute;
    top: 10px;
    left: 10px;
    right: auto;
    bottom: auto;
    z-index: 2;
    pointer-events: none;
  }

  .trg-plp-body .product-badges__badge {
    border-radius: 0;
    background: var(--trg-plp-sale-background);
    color: var(--trg-plp-sale-text);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 8px 4px;
  }

  .trg-plp-body .quick-add {
    display: none !important;
  }

  .trg-plp-body .group-block__media-wrapper {
    display: none;
  }

  .trg-plp-body .group-block {
    display: flex;
    flex: 1 1 auto;
    padding: var(--trg-plp-caption-padding) var(--trg-plp-caption-padding) 0;
    border-top: 1px solid rgb(var(--color-border-rgb) / 0.55);
    background: var(--trg-plp-caption-background);
  }

  .trg-plp-body .group-block-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    width: 100%;
    min-height: 100%;
  }

  .trg-plp-body .trg-plp-card-brand {
    margin: 0;
    color: var(--trg-plp-muted-color);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .trg-plp-body .group-block-content > a.contents.user-select-text {
    display: block;
    width: 100%;
    margin-top: 8px;
    color: var(--trg-plp-text-color);
    text-decoration: none;
  }

  .trg-plp-body .group-block-content > a.contents.user-select-text .text-block {
    width: 100%;
  }

  .trg-plp-body .group-block-content > a.contents.user-select-text .text-block p {
    margin: 0;
    color: var(--trg-plp-text-color);
    font-family: var(--font-heading--family);
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.18;
    text-transform: none;
  }

  .trg-plp-body .trg-plp-card-material {
    margin: 6px 0 0;
    color: var(--trg-plp-muted-color);
    font-size: 13px;
    line-height: 1.35;
  }

  .trg-plp-body .group-block-content > product-price {
    width: 100%;
    margin-top: 16px;
  }

  .trg-plp-body .group-block-content > product-price,
  .trg-plp-body .group-block-content > product-price .price,
  .trg-plp-body .group-block-content > product-price .compare-at-price {
    color: var(--trg-plp-text-color);
    line-height: 1.25;
  }

  .trg-plp-body .group-block-content > product-price .price {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .trg-plp-body .group-block-content > product-price .compare-at-price {
    color: #aea79d;
    font-size: 0.82rem;
    text-decoration: line-through;
  }

  .trg-plp-body .group-block-content > product-price > div {
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
  }

  .trg-plp-body .trg-plp-card-cta-block {
    width: calc(100% + (var(--trg-plp-caption-padding) * 2));
    margin-top: auto;
    margin-left: calc(var(--trg-plp-caption-padding) * -1);
    padding: 14px var(--trg-plp-caption-padding) 12px;
    border-top: 1px solid rgb(var(--color-border-rgb) / 0.55);
  }

  .trg-plp-body .trg-plp-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--trg-plp-text-color);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .trg-plp-body .trg-plp-card-cta:hover {
    color: var(--trg-plp-muted-color);
  }

  .trg-plp-body .facets-toggle {
    margin-top: 0;
  }

  @media screen and (min-width: 990px) {
    .trg-plp-body .collection-wrapper,
    .trg-plp-body
      .collection-wrapper:has(.facets-block-wrapper--vertical:not(#filters-drawer)):has(
        .collection-wrapper--full-width
      ) {
      display: grid;
      grid-template-columns: minmax(220px, var(--trg-plp-sidebar-width)) minmax(0, 1fr) !important;
      column-gap: var(--trg-plp-layout-gap);
      align-items: start;
      grid-template-areas: none;
    }

    .trg-plp-body .collection-wrapper > .trg-collection-controls {
      grid-column: 2 !important;
      grid-row: 1 !important;
    }

    .trg-plp-body .collection-wrapper > div.facets-block-wrapper--vertical:not(.hidden) {
      --grid-column--desktop: 1;
      grid-column: 1 !important;
      grid-row: 2 !important;
      align-self: start;
    }

    .trg-plp-body .facets--vertical:not(.facets--drawer) {
      position: sticky;
      top: 24px;
    }

    .trg-plp-body .collection-wrapper > .main-collection-grid {
      --grid-column--desktop: 2;
      grid-column: 2 !important;
      grid-row: 2 !important;
      min-width: 0;
    }

    .trg-plp-body .collection-wrapper > .facets-toggle {
      display: none !important;
      grid-column: auto !important;
      grid-row: auto !important;
    }

    .trg-plp-body .collection-wrapper > dialog-component#filters-drawer {
      grid-column: auto !important;
      grid-row: auto !important;
      position: absolute;
      width: 0;
      height: 0;
      overflow: hidden;
    }
  }

  @media screen and (max-width: 989px) {
    .trg-plp-body .collection-wrapper {
      width: min(calc(100% - (var(--page-margin) * 2)), var(--trg-plp-shell-max-width));
    }

    .trg-plp-body .trg-collection-controls {
      justify-content: space-between;
      gap: 10px;
      padding-bottom: 16px;
    }

    .trg-plp-body .products-count-wrapper span {
      font-size: 10px;
    }
  }

  @media screen and (max-width: 749px) {
    .trg-plp-body .card-gallery,
    .trg-plp-body .product-card-gallery__title-placeholder {
      min-height: 220px;
    }

    .trg-plp-body .group-block-content > a.contents.user-select-text .text-block p {
      font-size: 0.96rem;
    }
  }

  .main-collection-grid {
    grid-column: var(--grid-column--mobile);

    @media screen and (min-width: 750px) {
      grid-column: var(--grid-column--desktop);
    }
  }
{% endstylesheet %}

