      border-radius: 2px !important;
      background: #fff !important;
      color: var(--trg-plp-muted-color, #8a8478) !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 0.72rem !important;
      font-weight: 500 !important;
      letter-spacing: 0.08em !important;
      text-transform: uppercase !important;
      white-space: nowrap !important;
      flex: 0 0 auto !important;
    }

    .trg-plp-body .trg-plp-show-filters-btn .svg-wrapper,
    .trg-plp-body .trg-plp-show-filters-btn svg {
      width: 14px !important;
      height: 14px !important;
      flex-shrink: 0 !important;
    }

    .trg-plp-body .products-count-wrapper {
      display: block !important;
      position: static !important;
      inset: auto !important;
      margin: 0 !important;
      transform: none !important;
      flex: 1 1 auto !important;
      text-align: center !important;
      pointer-events: none !important;
    }

    .trg-plp-body .products-count-wrapper span {
      font-size: 0.62rem !important;
      letter-spacing: 0.14em !important;
    }

    .trg-plp-body .trg-collection-controls .trg-plp-sort-shell,
    .trg-plp-body .trg-collection-controls .sorting-filter {
      margin-left: auto !important;
      flex: 0 0 auto !important;
    }

    .trg-plp-body .trg-plp-sort-select,
    .trg-plp-body .trg-collection-controls .sorting-filter__select {
      min-width: 0 !important;
      max-width: 130px !important;
      min-height: 36px !important;
      padding: 0.5rem 1.9rem 0.5rem 0.75rem !important;
      font-size: 0.75rem !important;
    }

    .trg-plp-body .product-grid {
      --product-grid-gap: 0.75rem !important;
    }

    .trg-plp-body .product-card:hover {
      transform: none !important;
      box-shadow: none !important;
    }

    .trg-plp-body .trg-plp-card-wishlist {
      width: 30px !important;
      height: 30px !important;
      top: 10px !important;
      right: 10px !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transform: none !important;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "TRG PLP body"
    },
    {
      "type": "range",
      "id": "trg_plp_shell_max_width",
      "label": "Max body width",
      "min": 900,
      "max": 1600,
      "step": 10,
      "unit": "px",
      "default": 1320
    },
    {
      "type": "range",
      "id": "trg_plp_sidebar_width",
      "label": "Sidebar width",
      "min": 200,
      "max": 360,
      "step": 4,
      "unit": "px",
      "default": 220
    },
    {
      "type": "select",
      "id": "trg_plp_desktop_columns",
      "label": "Desktop columns",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "trg_plp_layout_gap",
      "label": "Sidebar/content gap",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "trg_plp_toolbar_gap",
      "label": "Toolbar bottom gap",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "trg_plp_sidebar_padding",
      "label": "Sidebar padding",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "trg_plp_caption_padding",
      "label": "Card caption padding",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "text",
      "id": "trg_plp_sort_label",
      "label": "Sort dropdown label",
      "default": "Sort"
    },
    {
      "type": "select",
      "id": "trg_plp_image_ratio",
      "label": "Card image ratio",
      "options": [
        {
          "value": "3 / 4",
          "label": "3:4 Portrait (default)"
        },
        {
          "value": "4 / 5",
          "label": "4:5 Portrait"
        },
        {
          "value": "1 / 1",
          "label": "1:1 Square"
        },
        {
          "value": "16 / 9",
          "label": "16:9 Landscape"
        }
      ],
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "trg_plp_image_position",
      "label": "Card image crop position",
      "options": [
        {
          "value": "top center",
          "label": "Top center (default)"
        },
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "bottom center",
          "label": "Bottom center"
        }
      ],
      "default": "top center"
    },
    {
      "type": "checkbox",
      "id": "trg_plp_show_toggles",
      "label": "Show sidebar toggle filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "trg_plp_toggle_ships_ca",
      "label": "Show Ships to Canada toggle",
      "default": true,
      "visible_if": "{{ section.settings.trg_plp_show_toggles }}"
    },
    {
      "type": "text",
      "id": "trg_plp_toggle_ships_ca_label",
      "label": "Ships CA toggle label",
      "default": "Ships to Canada",
      "visible_if": "{{ section.settings.trg_plp_show_toggles and section.settings.trg_plp_toggle_ships_ca }}"
    },
    {
      "type": "checkbox",
      "id": "trg_plp_toggle_on_sale",
      "label": "Show On Sale toggle",
      "default": true,
      "visible_if": "{{ section.settings.trg_plp_show_toggles }}"
    },
    {
      "type": "text",
      "id": "trg_plp_toggle_on_sale_label",
      "label": "On Sale toggle label",
      "default": "On Sale",
      "visible_if": "{{ section.settings.trg_plp_show_toggles and section.settings.trg_plp_toggle_on_sale }}"
    },
    {
      "type": "checkbox",
      "id": "trg_plp_toggle_new",
      "label": "Show New Arrivals toggle",
      "default": true,
      "visible_if": "{{ section.settings.trg_plp_show_toggles }}"
    },
    {
      "type": "text",
      "id": "trg_plp_toggle_new_label",
      "label": "New Arrivals toggle label",
      "default": "New Arrivals",
      "visible_if": "{{ section.settings.trg_plp_show_toggles and section.settings.trg_plp_toggle_new }}"
    },
    {
      "type": "color",
      "id": "trg_plp_page_background",
      "label": "Page background",
      "default": "#efede8"
    },
    {
      "type": "color",
      "id": "trg_plp_panel_background",
      "label": "Sidebar background",
      "default": "#f6f4f0"
    },
    {
      "type": "color",
      "id": "trg_plp_card_background",
      "label": "Media panel background",
      "default": "#ececeb"
    },
    {
      "type": "color",
      "id": "trg_plp_caption_background",
      "label": "Card caption background",
      "default": "#faf8f4"
    },
    {
      "type": "color",
      "id": "trg_plp_border_color",
      "label": "Border color",
      "default": "#d8d3ca"
    },
    {
      "type": "color",
      "id": "trg_plp_text_color",
      "label": "Primary text color",
      "default": "#2f2b27"
    },
    {
      "type": "color",
      "id": "trg_plp_muted_color",
      "label": "Muted text color",
      "default": "#8e877d"
    },
    {
      "type": "color",
      "id": "trg_plp_sale_background",
      "label": "Sale badge background",
      "default": "#8d644f"
    },
    {
      "type": "color",
      "id": "trg_plp_sale_text",
      "label": "Sale badge text",
      "default": "#f8f2ec"
    },
    {
      "type": "color",
      "id": "trg_plp_cta_background",
      "label": "CTA overlay background",
      "default": "#1a1a18"
    },
    {
      "type": "color",
      "id": "trg_plp_cta_text",
      "label": "CTA overlay text",
      "default": "#f5f1eb"
    },
    {
      "type": "color",
      "id": "trg_plp_cta_hover",
      "label": "CTA overlay hover color",
      "default": "#c4562a"
    }
  ],
  "presets": []
}
{% endschema %}
