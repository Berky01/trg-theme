{% liquid
  assign brand = metaobject
  if brand == blank and shop.metaobjects.brand != blank
    assign brand = shop.metaobjects.brand.values | first
  endif
  if brand != blank
    assign name = brand.name.value | default: brand.name | default: brand.handle
    assign country = brand.country.value | default: brand.country | strip
    assign made_in = brand.made_in.value | default: brand.made_in | strip
    assign primary_raw = brand.primary_category.value | default: brand.primary_category | strip
    assign cat_src = primary_raw | downcase
    assign broad = 'Other'
    if cat_src contains 'footwear'
      assign broad = 'Footwear'
    elsif cat_src contains 'outerwear'
      assign broad = 'Outerwear'
    elsif cat_src contains 'formalwear' or cat_src contains 'tailoring'
      assign broad = 'Formalwear & Tailoring'
    elsif cat_src contains 'knitwear'
      assign broad = 'Knitwear'
    elsif cat_src contains 'denim'
      assign broad = 'Denim'
    elsif cat_src contains 'shirting' or cat_src contains 'shirt'
      assign broad = 'Shirting'
    elsif cat_src contains 'basics'
      assign broad = 'Basics'
    elsif cat_src contains 'workwear'
      assign broad = 'Workwear'
    elsif cat_src contains 'smart casual'
      assign broad = 'Smart Casual'
    elsif cat_src contains 'streetwear'
      assign broad = 'Streetwear'
    elsif cat_src contains 'accessories'
      assign broad = 'Accessories'
    elsif cat_src contains 'activewear'
      assign broad = 'Activewear'
    elsif cat_src contains 'casualwear' or cat_src contains 'contemporary'
      assign broad = 'Casualwear'
    endif
    assign description = brand.description.value | default: brand.description | strip
    assign notes = brand.notes.value | default: brand.notes | strip
    assign tagline_source = description | default: notes | strip
    assign tagline = tagline_source | split: '. ' | first | strip
    assign website = brand.website.value | default: brand.website | strip
    assign affiliate_link = brand.affiliate_link.value | default: brand.affiliate_link | strip
    assign buy_path = brand.buy_path.value | default: brand.buy_path | strip
    assign buy_url = affiliate_link | default: website
    if buy_url != blank and buy_url contains '://'
    elsif buy_url != blank
      assign buy_url = 'https://' | append: buy_url
    endif
    assign price_range = brand.price_range.value | default: brand.price_range | strip
    assign affiliate_program = brand.affiliate_program.value | default: brand.affiliate_program | downcase | strip
    assign affiliate_network = brand.affiliate_network.value | default: brand.affiliate_network | strip
    assign commission = brand.commission.value | default: brand.commission | strip
    assign ships_to_canada = brand.ships_to_canada.value | default: brand.ships_to_canada | downcase | strip
    assign canadian_brand = brand.canadian_brand.value | default: brand.canadian_brand | downcase | strip
    assign ddp_duties = brand.ddp_duties.value | default: brand.ddp_duties | downcase | strip
    assign natural_materials = brand.natural_materials.value | default: brand.natural_materials | downcase | strip
    assign best_retailer_na = brand.best_retailer_na.value | default: brand.best_retailer_na | strip
    assign best_retailer_ca = brand.best_retailer_ca.value | default: brand.best_retailer_ca | strip
    assign retailer_network_ca = brand.retailer_network_ca.value | default: brand.retailer_network_ca | strip
    assign pos = brand.brand_positioning.value | default: brand.brand_positioning | default: '' | replace: ';', ',' | replace: '/', ',' | replace: '|', ',' | split: ','
    assign brands_index_url = pages['brands'].url | default: '/pages/brands'
    assign logo = brand.logo.value | default: brand.logo
    if logo != blank and logo.preview_image != blank
      assign logo = logo.preview_image
    endif
    assign collection_obj = brand.collection.value | default: brand.collection
    if collection_obj == blank
      assign collection_obj = collections[brand.handle]
    endif
    assign name_handle = name | handleize
    if collection_obj == blank
      assign collection_obj = collections[name_handle]
    endif
    assign initial_products = 4
  endif
%}
{% if brand != blank %}
{{ 'trg-brand-profile.css' | asset_url | stylesheet_tag }}
<script src="{{ 'trg-brand-profile.js' | asset_url }}" defer></script>
<section class="section section--full-width trg-bpdp" data-id="{{ section.id }}">
  <div class="trg-bpdp__crumbs"><div class="page-width"><a href="{{ routes.root_url }}">Home</a><span>›</span><a href="{{ brands_index_url }}">Brands</a><span>›</span><a href="{{ brands_index_url }}#{{ broad | handleize }}">{{ broad }}</a><span>›</span><span>{{ name }}</span></div></div>
  <div class="trg-bpdp__hero"><div class="page-width trg-bpdp__hero-in"><div class="trg-bpdp__logo">{% if logo != blank %}{{ logo | image_url: width: 200 | image_tag: loading: 'eager', widths: '96,160,200', sizes: '96px', alt: name }}{% else %}<span>{{ name | slice: 0, 2 | upcase }}</span>{% endif %}</div><div class="trg-bpdp__copy"><div class="trg-bpdp__badges">{% if made_in != blank %}<span>Made in {{ made_in }}</span>{% endif %}{% if affiliate_program == 'yes' or affiliate_program == 'true' %}<span class="is-aff">Affiliate</span>{% endif %}{% if ships_to_canada == 'yes' or ships_to_canada == 'true' %}<span class="canada-only canada-only-inline">Ships to Canada</span>{% endif %}{% if ddp_duties == 'yes' or ddp_duties == 'true' %}<span class="canada-only canada-only-inline is-ok">Duties Included</span>{% endif %}</div><h1>{{ name }}</h1>{% if tagline != blank %}<p class="trg-bpdp__tagline">{{ tagline }}</p>{% endif %}</div><div class="trg-bpdp__cta-col">{% if buy_path == 'Direct' or buy_path == 'Both' %}{% if buy_url != blank %}<a class="trg-bpdp__btn" href="{{ buy_url }}" target="_blank" rel="noopener sponsored">Shop Direct →</a>{% endif %}{% elsif best_retailer_na != blank %}<div class="trg-bpdp__btn trg-bpdp__btn--ghost">Via {{ best_retailer_na }} →</div>{% endif %}{% if best_retailer_ca != blank %}<div class="trg-bpdp__btn trg-bpdp__btn--ghost canada-only canada-only-block">Via {{ best_retailer_ca }} (CA) →</div>{% endif %}{% if affiliate_program == 'yes' or affiliate_program == 'true' %}{% if commission != blank %}<p class="trg-bpdp__comm">Affiliate link · {{ commission }} commission</p>{% endif %}{% endif %}</div></div></div>
  <div class="trg-bpdp__cta-strip">{% if buy_path == 'Direct' or buy_path == 'Both' %}{% if buy_url != blank %}<a class="trg-bpdp__btn" href="{{ buy_url }}" target="_blank" rel="noopener sponsored">Shop Direct →</a>{% endif %}{% endif %}{% if best_retailer_ca != blank %}<div class="trg-bpdp__btn trg-bpdp__btn--ghost canada-only canada-only-block">Via {{ best_retailer_ca }} (CA) →</div>{% endif %}</div>
  <div class="trg-bpdp__facts"><div class="page-width trg-bpdp__facts-in"><div class="trg-bpdp__fact"><strong>Price Range</strong><span>{{ price_range | default: 'TBD' }}</span></div><div class="trg-bpdp__fact"><strong>Country</strong><span>{{ country | default: 'TBD' }}</span></div><div class="trg-bpdp__fact"><strong>Made In</strong><span>{{ made_in | default: 'TBD' }}</span></div><div class="trg-bpdp__fact"><strong>Returns</strong><span>See brand site</span></div>{% if affiliate_program == 'yes' or affiliate_program == 'true' %}{% if affiliate_network != blank %}<div class="trg-bpdp__fact"><strong>Affiliate Network</strong><span>{{ affiliate_network }}</span></div>{% endif %}{% endif %}<div class="trg-bpdp__fact canada-only canada-only-flex"><strong>Duties to Canada</strong><span>{% if ddp_duties == 'yes' or ddp_duties == 'true' %}<span class="is-green">Included (DDP)</span>{% else %}<span class="is-warn">Not Included</span>{% endif %}</span></div><div class="trg-bpdp__fact canada-only canada-only-flex"><strong>Free CA Shipping</strong><span>See brand site</span></div></div></div>
  <div class="page-width trg-bpdp__main"><div class="trg-bpdp__content"><div class="trg-bpdp__block"><div class="trg-bpdp__sec">About the Brand</div><div class="trg-bpdp__rte">{{ description | newline_to_br }}</div><div class="trg-bpdp__pos">{% for item in pos %}{% assign p = item | strip %}{% if p != blank %}<span class="{% if forloop.index <= 2 %}is-pri{% endif %}">{{ p }}</span>{% endif %}{% endfor %}</div></div><div class="trg-bpdp__block canada-only canada-only-block trg-bpdp__canada"><div class="trg-bpdp__sec">Canadian Shipping Intelligence</div><div class="trg-bpdp__can-grid"><div><strong>Ships Direct to Canada</strong><span>{% if ships_to_canada == 'yes' or ships_to_canada == 'true' %}✓ Yes{% else %}✗ No{% endif %}</span></div><div><strong>Duties & Taxes</strong><span>{% if ddp_duties == 'yes' or ddp_duties == 'true' %}Included (DDP){% else %}Not Included{% endif %}</span></div><div><strong>Best CA Retailer</strong><span>{{ best_retailer_ca | default: '—' }}</span></div><div><strong>CA Affiliate Network</strong><span>{{ retailer_network_ca | default: '—' }}</span></div><div><strong>Natural Materials</strong><span>{% if natural_materials == 'yes' or natural_materials == 'true' %}Yes{% else %}—{% endif %}</span></div><div><strong>Canadian Brand</strong><span>{% if canadian_brand == 'yes' or canadian_brand == 'true' %}Yes{% else %}—{% endif %}</span></div></div>{% if ddp_duties == 'yes' or ddp_duties == 'true' %}<p class="trg-bpdp__can-note">DDP means the landed price should include duties and taxes. Confirm on the brand site before ordering.</p>{% endif %}</div><div class="trg-bpdp__block"><div class="trg-bpdp__sec">Brand Attributes</div><div class="trg-bpdp__attrs"><div><strong>Aesthetic</strong><span>{% for item in pos %}{% assign p = item | strip %}{% if p != blank %}<em>{{ p }}</em>{% endif %}{% endfor %}</span></div><div><strong>Price Tier</strong><span>{{ price_range | default: '—' }}</span></div><div><strong>Buy Path</strong><span>{{ buy_path | default: '—' }}</span></div><div><strong>Country</strong><span>{{ country | default: '—' }}</span></div><div><strong>Made In</strong><span>{{ made_in | default: '—' }}</span></div><div><strong>Affiliate Program</strong><span>{% if affiliate_program == 'yes' or affiliate_program == 'true' %}{{ affiliate_network }}{% if commission != blank %} · {{ commission }}{% endif %}{% else %}{{ brand.affiliate_program.value | default: brand.affiliate_program | default: 'No' }}{% endif %}</span></div><div><strong>Natural Materials</strong><span>{% if natural_materials == 'yes' or natural_materials == 'true' %}Yes{% else %}No{% endif %}</span></div><div><strong>Ships to Canada</strong><span>{% if ships_to_canada == 'yes' or ships_to_canada == 'true' %}Yes{% else %}No{% endif %}</span></div></div></div><div class="trg-bpdp__block"><div class="trg-bpdp__sechead"><div class="trg-bpdp__sec">Products from {{ name }}</div>{% if collection_obj != blank and collection_obj.url != blank %}<a href="{{ collection_obj.url }}">View all {{ collection_obj.products_count }} →</a>{% endif %}</div>{% if collection_obj != blank and collection_obj.products_count > 0 %}<ul class="trg-bpdp__products" data-products>{% for product in collection_obj.products %}<li class="trg-bpdp__product{% if forloop.index > initial_products %} is-hidden{% endif %}" data-product-card><a href="{{ product.url }}"><div class="trg-bpdp__product-media">{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '280,420,600', sizes: '(min-width: 990px) 22vw, 48vw', alt: product.title }}{% else %}<span>{{ name | slice: 0, 2 | upcase }}</span>{% endif %}{% if product.tags contains 'new' %}<span class="trg-bpdp__pbadge">New</span>{% elsif product.compare_at_price > product.price %}<span class="trg-bpdp__pbadge is-sale">Sale</span>{% endif %}</div><div class="trg-bpdp__product-body"><p>{{ product.vendor }}</p><h3>{{ product.title }}</h3><div class="trg-bpdp__price">{% if product.compare_at_price > product.price %}<span>{{ product.price | money }}</span><s>{{ product.compare_at_price | money }}</s>{% else %}<span>{{ product.price | money }}</span>{% endif %}</div></div><div class="trg-bpdp__product-cta">Shop Direct →</div></a></li>{% endfor %}</ul><div class="trg-bpdp__prodprog" data-prod-prog><div><span data-prod-copy>Showing {{ initial_products | at_most: collection_obj.products_count }} of {{ collection_obj.products_count }} products</span></div><div class="trg-bpdp__bar"><span data-prod-fill></span></div></div><div class="trg-bpdp__prodmore"><button type="button" class="trg-bpdp__ghost" data-prod-more>Load More Products</button></div>{% else %}<div class="trg-bpdp__soon">Products coming soon.</div>{% endif %}</div></div><aside class="trg-bpdp__side"><div class="trg-bpdp__card"><div class="trg-bpdp__cardt">Quick Facts</div><div class="trg-bpdp__rows">{% if affiliate_network != blank %}<div><span>Affiliate Program</span><strong>{{ affiliate_network }}</strong></div>{% endif %}{% if commission != blank %}<div><span>Commission</span><strong class="is-green">{{ commission }}</strong></div>{% endif %}{% if buy_path != blank %}<div><span>Buy Path</span><strong>{{ buy_path }}</strong></div>{% endif %}{% if price_range != blank %}<div><span>Price Range</span><strong>{{ price_range }}</strong></div>{% endif %}<div><span>Ships to Canada</span><strong class="{% if ships_to_canada == 'yes' or ships_to_canada == 'true' %}is-green{% else %}is-warn{% endif %}">{% if ships_to_canada == 'yes' or ships_to_canada == 'true' %}Yes{% else %}No{% endif %}</strong></div><div><span>Affiliate Link</span><strong class="{% if affiliate_link != blank %}is-green{% endif %}">{% if affiliate_link != blank %}Active{% else %}None{% endif %}</strong></div><div><span>Natural Materials</span><strong class="{% if natural_materials == 'yes' or natural_materials == 'true' %}is-green{% else %}is-warn{% endif %}">{% if natural_materials == 'yes' or natural_materials == 'true' %}Yes{% else %}No{% endif %}</strong></div><div><span>Made in NA</span><strong class="{% if country == 'USA' or country == 'Canada' %}is-green{% endif %}">{% if country == 'USA' or country == 'Canada' %}Yes{% else %}No{% endif %}</strong></div></div></div><div class="trg-bpdp__card"><div class="trg-bpdp__cardt">Where to Buy</div><div class="trg-bpdp__buyrows">{% if buy_path == 'Direct' or buy_path == 'Both' %}<div class="trg-bpdp__buyrow"><span class="trg-bpdp__mono2">{{ name | slice: 0, 2 | upcase }}</span><div><strong>Brand Direct</strong><span>US{% if ships_to_canada == 'yes' or ships_to_canada == 'true' %} · <span class="canada-only canada-only-inline">CA</span>{% endif %}</span></div></div>{% endif %}{% if best_retailer_ca != blank %}<div class="trg-bpdp__buyrow canada-only canada-only-flex"><span class="trg-bpdp__mono2">{{ best_retailer_ca | slice: 0, 2 | upcase }}</span><div><strong>{{ best_retailer_ca }}</strong><span>CA Best</span></div></div>{% endif %}{% if best_retailer_na != blank %}<div class="trg-bpdp__buyrow"><span class="trg-bpdp__mono2">{{ best_retailer_na | slice: 0, 2 | upcase }}</span><div><strong>{{ best_retailer_na }}</strong><span>US</span></div></div>{% endif %}</div></div><div class="trg-bpdp__card trg-bpdp__card--dark"><div class="trg-bpdp__cardt">Newsletter</div><h3>Stay close to the best brands.</h3><p>New discoveries, buying notes, and editorial launches from The Right Garment.</p><input type="email" placeholder="Email address"><button type="button" class="trg-bpdp__btn">Subscribe</button></div></aside></div>
  <div class="page-width trg-bpdp__similar-wrap">{% assign sim_count = 0 %}<div class="trg-bpdp__sec">Similar Brands</div><div class="trg-bpdp__similar">{% for item in shop.metaobjects.brand.values %}{% liquid
assign cname = item.name.value | default: item.name | default: item.handle
assign ccat = item.primary_category.value | default: item.primary_category | strip
assign csrc = ccat | downcase
assign cbroad = 'Other'
if csrc contains 'footwear'
  assign cbroad = 'Footwear'
elsif csrc contains 'outerwear'
  assign cbroad = 'Outerwear'
elsif csrc contains 'formalwear' or csrc contains 'tailoring'
  assign cbroad = 'Formalwear & Tailoring'
elsif csrc contains 'knitwear'
  assign cbroad = 'Knitwear'
elsif csrc contains 'denim'
  assign cbroad = 'Denim'
elsif csrc contains 'shirting' or csrc contains 'shirt'
  assign cbroad = 'Shirting'
elsif csrc contains 'basics'
  assign cbroad = 'Basics'
elsif csrc contains 'workwear'
  assign cbroad = 'Workwear'
elsif csrc contains 'smart casual'
  assign cbroad = 'Smart Casual'
elsif csrc contains 'streetwear'
  assign cbroad = 'Streetwear'
elsif csrc contains 'accessories'
  assign cbroad = 'Accessories'
elsif csrc contains 'activewear'
  assign cbroad = 'Activewear'
elsif csrc contains 'casualwear' or csrc contains 'contemporary'
  assign cbroad = 'Casualwear'
endif
%}{% if item.handle != brand.handle and cbroad == broad and sim_count < 4 %}{% capture sim_url %}{% render 'trg-brand-page-url', brand_item: item %}{% endcapture %}<a class="trg-bpdp__sim" href="{{ sim_url | strip }}"><span class="trg-bpdp__mono2">{{ cname | slice: 0, 2 | upcase }}</span><h3>{{ cname }}</h3><p>{{ item.country.value | default: item.country }} · {{ cbroad }}</p><div>{% assign sim_pos = item.brand_positioning.value | default: item.brand_positioning | default: '' | replace: ';', ',' | replace: '/', ',' | replace: '|', ',' | split: ',' %}{% if item.affiliate_program.value == 'Yes' or item.affiliate_program.value == 'true' %}<span class="is-aff">Affiliate</span>{% endif %}{% for tag in sim_pos limit: 2 %}{% assign t = tag | strip %}{% if t != blank %}<span>{{ t }}</span>{% endif %}{% endfor %}</div></a>{% assign sim_count = sim_count | plus: 1 %}{% endif %}{% endfor %}</div></div>
  <button type="button" class="trg-bpdp__top" data-top aria-label="Back to top">↑</button>
</section>
{% endif %}
{% schema %}
{
  "name": "TRG Brand Profile",
  "tag": "section",
  "class": "trg-brand-profile-section",
  "settings": [
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "TRG Brand Profile"
    }
  ]
}
{% endschema %}
