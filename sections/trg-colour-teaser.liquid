        { "type": "family", "settings": { "label": "Sand & Khaki", "count": "11 colours", "colour_1": "#d09030", "colour_2": "#c8b88a", "colour_3": "#a09080" } },
        { "type": "family", "settings": { "label": "Browns", "count": "10 colours", "colour_1": "#b06828", "colour_2": "#7a5028", "colour_3": "#3c2010" } },
        { "type": "family", "settings": { "label": "Greens", "count": "11 colours", "colour_1": "#a0c8a0", "colour_2": "#305838", "colour_3": "#388888" } },
        { "type": "family", "settings": { "label": "Blues", "count": "14 colours", "colour_1": "#a0c4d8", "colour_2": "#3464a8", "colour_3": "#282858" } },
        { "type": "family", "settings": { "label": "Greys", "count": "9 colours", "colour_1": "#ccc8c0", "colour_2": "#808078", "colour_3": "#181818" } },
        { "type": "family", "settings": { "label": "Reds & Burgundy", "count": "8 colours", "colour_1": "#c09080", "colour_2": "#a01028", "colour_3": "#501828" } },
