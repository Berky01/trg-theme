        {"type":"brand_category","settings":{"title_override":"Streetwear"}},
        {"type":"featured_brand","settings":{"brand_name":"Norse Projects","brand_eyebrow":"Casualwear · Copenhagen","brand_description":"Scandinavian precision. Quietly considered, built to last."}},
