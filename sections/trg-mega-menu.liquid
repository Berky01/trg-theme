{% comment %}trg-mm-v4.0{% endcomment %}
{%- liquid
  assign bd = shop.metaobjects['brand']
  assign has_mo = false
  if bd and bd.values.size > 0
    assign has_mo = true
  endif
-%}

<div class="trg-mm-bk" id="trg-mm-bk"></div>

<div class="trg-mm-p" id="trg-mm-p-shop" role="region" aria-label="Shop by products">
  <button class="trg-mm-x" type="button" aria-label="Close">&#10005;</button>
  <div class="trg-mm-in">
    <nav class="trg-mm-sb" aria-label="Product families">
      <div class="trg-mm-sb-lbl">Product Family</div>
      {%- assign fi = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'family' -%}
          {%- liquid
            assign ft = block.settings.title_override
            if ft == blank and block.settings.collection != blank
              assign ft = block.settings.collection.title
            endif
            if ft == blank
              assign ft = 'Untitled'
            endif
          -%}
          {%- assign sc = 0 -%}{%- assign ctg = false -%}
          {%- for b in section.blocks -%}
            {%- if b.id == block.id -%}{%- assign ctg = true -%}{%- continue -%}{%- endif -%}
            {%- if ctg -%}{%- if b.type == 'family' -%}{%- break -%}{%- elsif b.type == 'subcategory' -%}{%- assign sc = sc | plus: 1 -%}{%- endif -%}{%- endif -%}
          {%- endfor -%}
          <button class="trg-mm-t{% if fi == 0 %} on{% endif %}" data-tab="shop-{{ ft | handleize }}" type="button" {{ block.shopify_attributes }}>{{ ft }}{%- if sc > 0 %}<span class="trg-mm-tc">{{ sc }}</span>{%- endif -%}</button>
          {%- assign fi = fi | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if fi == 0 -%}<p class="trg-mm-empty">Add Product Family blocks in Customizer</p>{%- endif -%}
    </nav>
    <div class="trg-mm-c">
      {%- assign fi = 0 -%}{%- assign po = false -%}{%- assign go = false -%}{%- assign ao = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'family' -%}
          {%- if po -%}
            {%- if ao -%}</div></div>{%- assign ao = false -%}{%- endif -%}
            {%- if go -%}</div>{%- assign go = false -%}{%- endif -%}
            <div class="trg-mm-va"><a href="{{ pfu }}" class="trg-mm-val">View all {{ pft | downcase }}</a></div></div>
            {%- assign po = false -%}
          {%- endif -%}
          {%- liquid
            assign ft = block.settings.title_override
            if ft == blank and block.settings.collection != blank
              assign ft = block.settings.collection.title
            endif
            if ft == blank
              assign ft = 'Untitled'
            endif
            assign fu = block.settings.title_override | default: 'all' | handleize | prepend: '/collections/'
            if block.settings.collection != blank and block.settings.collection.url != blank
              assign fu = block.settings.collection.url
            endif
            assign pft = ft
            assign pfu = fu
            assign ao = false
          -%}
          <div class="trg-mm-pn{% if fi == 0 %} on{% endif %}" id="trg-mm-pn-shop-{{ ft | handleize }}" {{ block.shopify_attributes }}>
            <div class="trg-mm-ph"><span class="trg-mm-pt">{{ ft }}</span>{%- if block.settings.subtitle != blank -%}<span class="trg-mm-ps">{{ block.settings.subtitle }}</span>{%- endif -%}</div>
          {%- if block.settings.chips != blank -%}
            <div class="trg-mm-ar"><span class="trg-mm-al">Style Aesthetic</span>
              <div class="trg-mm-acs">
                {%- assign chip_list = block.settings.chips | split: ',' -%}
                {%- for chip in chip_list -%}
                  {%- assign chip_clean = chip | strip -%}
                  <a href="{{ fu }}" class="trg-mm-ac{% if forloop.first %} on{% endif %}">{{ chip_clean }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
          {%- assign po = true -%}{%- assign fi = fi | plus: 1 -%}

        {%- comment -%}aesthetic_chip blocks deprecated - chips now in family settings{%- endcomment -%}

        {%- elsif block.type == 'subcategory' and po -%}
          {%- unless go -%}<span class="trg-mm-sl">Shop by type</span><div class="trg-mm-sg">{%- assign go = true -%}{%- endunless -%}
          {%- liquid
            assign st = block.settings.title_override
            if st == blank and block.settings.collection != blank
              assign st = block.settings.collection.title
            endif
            if st == blank
              assign st = 'Untitled'
            endif
            assign su = block.settings.title_override | default: 'all' | handleize | prepend: '/collections/'
            if block.settings.collection != blank and block.settings.collection.url != blank
              assign su = block.settings.collection.url
            endif
          -%}
          <a href="{{ su }}" class="trg-mm-st" {{ block.shopify_attributes }}><span class="trg-mm-sn">{{ st }}</span>{%- if block.settings.count != blank -%}<span class="trg-mm-sc">{{ block.settings.count }}</span>{%- endif -%}</a>
        {%- endif -%}
      {%- endfor -%}
      {%- if ao -%}</div></div>{%- endif -%}
      {%- if po -%}{%- if go -%}</div>{%- endif -%}<div class="trg-mm-va"><a href="{{ pfu }}" class="trg-mm-val">View all {{ pft | downcase }}</a></div></div>{%- endif -%}
      {%- if fi == 0 -%}<div class="trg-mm-pn on"><div class="trg-mm-ph"><span class="trg-mm-pt">Shop by Products</span></div><p class="trg-mm-empty">Add Product Family, Style Chip, and Subcategory blocks in the Theme Customizer.</p></div>{%- endif -%}
    </div>
    {%- for block in section.blocks -%}
      {%- if block.type == 'featured_brand_shop' and block.settings.brand_name != blank -%}
        <div class="trg-mm-ft" {{ block.shopify_attributes }}>
          <div class="trg-mm-fl">Featured Brand</div>
          <a href="{{ block.settings.brand_url | default: '#' }}" class="trg-mm-fc">
            <div class="trg-mm-fi">{%- if block.settings.brand_image != blank -%}<img src="{{ block.settings.brand_image | image_url: width: 400 }}" alt="{{ block.settings.brand_name }}" loading="lazy" width="400" height="300">{%- else -%}<div class="trg-mm-ff">{{ block.settings.brand_name | truncate: 2, '' }}</div>{%- endif -%}</div>
            <div class="trg-mm-fb">{%- if block.settings.brand_eyebrow != blank -%}<div class="trg-mm-fe">{{ block.settings.brand_eyebrow }}</div>{%- endif -%}<div class="trg-mm-fn">{{ block.settings.brand_name }}</div>{%- if block.settings.brand_description != blank -%}<div class="trg-mm-fd">{{ block.settings.brand_description }}</div>{%- endif -%}<div class="trg-mm-fct">View brand</div></div>
          </a>
          {%- if block.settings.link_1_text != blank -%}<div class="trg-mm-fv"></div><div class="trg-mm-fl">Quick Filters</div><div class="trg-mm-fls">{%- if block.settings.link_1_text != blank -%}<a href="{{ block.settings.link_1_url | default: '#' }}" class="trg-mm-fq">{{ block.settings.link_1_text }}</a>{%- endif -%}{%- if block.settings.link_2_text != blank -%}<a href="{{ block.settings.link_2_url | default: '#' }}" class="trg-mm-fq">{{ block.settings.link_2_text }}</a>{%- endif -%}{%- if block.settings.link_3_text != blank -%}<a href="{{ block.settings.link_3_url | default: '#' }}" class="trg-mm-fq">{{ block.settings.link_3_text }}</a>{%- endif -%}</div>{%- endif -%}
        </div>{%- break -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<div class="trg-mm-p" id="trg-mm-p-brands" role="region" aria-label="Browse brands">
  <button class="trg-mm-x" type="button" aria-label="Close">&#10005;</button>
  <div class="trg-mm-in">
    <nav class="trg-mm-sb" aria-label="Brand categories">
      <div class="trg-mm-sb-lbl">Filter by Category</div>
      <button class="trg-mm-t on" data-tab="brands-all" type="button">All Brands</button>
      {%- for block in section.blocks -%}
        {%- if block.type == 'brand_category' -%}
          {%- liquid
            assign ctt = block.settings.title_override
            if ctt == blank and block.settings.collection != blank
              assign ctt = block.settings.collection.title
            endif
            if ctt == blank
              assign ctt = 'Untitled'
            endif
          -%}
          <button class="trg-mm-t" data-tab="brands-{{ ctt | handleize }}" data-bc="{{ ctt | handleize }}" type="button" {{ block.shopify_attributes }}>{{ ctt }}</button>
        {%- endif -%}
      {%- endfor -%}
    </nav>
    <div class="trg-mm-c">
      <div class="trg-mm-bs">
        <div class="trg-mm-sf">
          <svg class="trg-mm-si" viewBox="0 0 16 16" fill="none"><circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/><line x1="10.5" y1="10.5" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          <input type="text" id="trg-mm-bi" class="trg-mm-sin" placeholder="Search 460+ brands…" autocomplete="off" spellcheck="false">
          <button class="trg-mm-sx" id="trg-mm-sx" type="button" aria-label="Clear">&#10005;</button>
        </div>
        <div class="trg-mm-sm" id="trg-mm-sm"></div>
      </div>
      <div class="trg-mm-bg" id="trg-mm-bg"></div>
      <div class="trg-mm-va"><a href="/pages/brands" class="trg-mm-val">Open full brand directory</a></div>
    </div>
    {%- for block in section.blocks -%}
      {%- if block.type == 'featured_brand' and block.settings.brand_name != blank -%}
        <div class="trg-mm-ft" {{ block.shopify_attributes }}>
          <div class="trg-mm-fl">Featured Brand</div>
          <a href="{{ block.settings.brand_url | default: '#' }}" class="trg-mm-fc">
            <div class="trg-mm-fi">{%- if block.settings.brand_image != blank -%}<img src="{{ block.settings.brand_image | image_url: width: 400 }}" alt="{{ block.settings.brand_name }}" loading="lazy" width="400" height="300">{%- else -%}<div class="trg-mm-ff">{{ block.settings.brand_name | truncate: 2, '' }}</div>{%- endif -%}</div>
            <div class="trg-mm-fb">{%- if block.settings.brand_eyebrow != blank -%}<div class="trg-mm-fe">{{ block.settings.brand_eyebrow }}</div>{%- endif -%}<div class="trg-mm-fn">{{ block.settings.brand_name }}</div>{%- if block.settings.brand_description != blank -%}<div class="trg-mm-fd">{{ block.settings.brand_description }}</div>{%- endif -%}<div class="trg-mm-fct">View brand</div></div>
          </a>
          {%- if block.settings.link_1_text != blank -%}<div class="trg-mm-fv"></div><div class="trg-mm-fl">Explore</div><div class="trg-mm-fls">{%- if block.settings.link_1_text != blank -%}<a href="{{ block.settings.link_1_url | default: '#' }}" class="trg-mm-fq">{{ block.settings.link_1_text }}</a>{%- endif -%}{%- if block.settings.link_2_text != blank -%}<a href="{{ block.settings.link_2_url | default: '#' }}" class="trg-mm-fq">{{ block.settings.link_2_text }}</a>{%- endif -%}{%- if block.settings.link_3_text != blank -%}<a href="{{ block.settings.link_3_url | default: '#' }}" class="trg-mm-fq">{{ block.settings.link_3_text }}</a>{%- endif -%}</div>{%- endif -%}
        </div>{%- break -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script id="trg-mm-bd" type="application/json">{%- if has_mo -%}[{%- for brand in bd.values -%}{%- if brand.status == 'Active' or brand.status == 'Add' or brand.status == blank -%}{"name":{{ brand.name | json }},"slug":{{ brand.slug | default: brand.name | handleize | json }},"category":{{ brand.primary_category | default: '' | handleize | json }}}{% unless forloop.last %},{% endunless %}{%- endif -%}{%- endfor -%}]{%- else -%}[]{%- endif -%}</script>


{%- comment -%}
  ══════ MOBILE MEGA MENU DRAWER (≤989px) ══════
  Reads from the same section blocks as desktop.
  JS shows/hides this; Dwell native drawer is hidden via CSS.
{%- endcomment -%}
<div class="trg-mob" id="trg-mob" aria-hidden="true">
  <div class="trg-mob-bk" id="trg-mob-bk"></div>
  <div class="trg-mob-drawer">
    <div class="trg-mob-head">
      <a href="/" class="trg-mob-logo">The <span>Right</span> Garment</a>
      <button class="trg-mob-close" id="trg-mob-close" type="button" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="trg-mob-tabs">
      <button class="trg-mob-tab on" data-mob-tab="shop" type="button">Shop by Type</button>
      <button class="trg-mob-tab" data-mob-tab="brands" type="button">Brands</button>
    </div>
    <div class="trg-mob-body" id="trg-mob-body">

      {%- comment -%}═══ SHOP BY TYPE TAB ═══{%- endcomment -%}
      <div class="trg-mob-tc on" id="trg-mob-tc-shop">
        {%- assign mfi = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'family' -%}
            {%- assign pmft = mft -%}{%- assign pmfu = mfu -%}
            {%- liquid
              assign mft = block.settings.title_override
              if mft == blank and block.settings.collection != blank
                assign mft = block.settings.collection.title
              endif
              if mft == blank
                assign mft = 'Untitled'
              endif
              assign mfu = block.settings.title_override | default: 'all' | handleize | prepend: '/collections/'
              if block.settings.collection != blank and block.settings.collection.url != blank
                assign mfu = block.settings.collection.url
              endif
            -%}
            {%- comment -%}Close previous family body if open{%- endcomment -%}
            {%- if mfi > 0 -%}
              {%- if msubs_started -%}</div>{%- assign msubs_started = false -%}{%- endif -%}
              <a href="{{ pmfu }}" class="trg-mob-va">View all {{ pmft | downcase }}</a>
              </div></div></div>
            {%- endif -%}
            <div class="trg-mob-fam" data-fam-idx="{{ mfi }}">
              <button class="trg-mob-fam-hdr" type="button">
                <div class="trg-mob-fam-left">
                  <span class="trg-mob-fam-name">{{ mft }}</span>
                  {%- if block.settings.subtitle != blank -%}<span class="trg-mob-fam-count">{{ block.settings.subtitle }}</span>{%- endif -%}
                </div>
                <svg class="trg-mob-chv" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="trg-mob-fam-body"><div class="trg-mob-fam-inner">
                {%- if block.settings.chips != blank -%}
                  <span class="trg-mob-lbl">Style aesthetic</span>
                  <div class="trg-mob-chips" data-swipe>
                    {%- assign mchips = block.settings.chips | split: ',' -%}
                    {%- for chip in mchips -%}
                      <a href="{{ mfu }}" class="trg-mob-chip{% if forloop.first %} on{% endif %}">{{ chip | strip }}</a>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                {%- assign msubs_started = false -%}
            {%- assign mfi = mfi | plus: 1 -%}

          {%- elsif block.type == 'subcategory' and mfi > 0 -%}
            {%- unless msubs_started -%}
              <span class="trg-mob-lbl">Shop by type</span>
              <div class="trg-mob-subs">
              {%- assign msubs_started = true -%}
            {%- endunless -%}
            {%- liquid
              assign mst = block.settings.title_override
              if mst == blank and block.settings.collection != blank
                assign mst = block.settings.collection.title
              endif
              if mst == blank
                assign mst = 'Untitled'
              endif
              assign msu = block.settings.title_override | default: 'all' | handleize | prepend: '/collections/'
              if block.settings.collection != blank and block.settings.collection.url != blank
                assign msu = block.settings.collection.url
              endif
            -%}
            <a href="{{ msu }}" class="trg-mob-sub">
              <span class="trg-mob-sub-name">{{ mst }}</span>
              {%- if block.settings.count != blank -%}<span class="trg-mob-sub-count">{{ block.settings.count }}</span>{%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
        {%- if mfi > 0 -%}
          {%- if msubs_started -%}</div>{%- endif -%}
          <a href="{{ mfu }}" class="trg-mob-va">View all {{ mft | downcase }}</a>
          </div></div></div>
        {%- endif -%}

        {%- comment -%}Footer links{%- endcomment -%}
        <div class="trg-mob-footer">
          <a href="/blogs/journal" class="trg-mob-flink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h4l2 3h8a2 2 0 012 2v9a2 2 0 01-2 2z"/></svg>Journal</a>
          <a href="/pages/about" class="trg-mob-flink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>About</a>
          <a href="/pages/submit-brand" class="trg-mob-flink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>Submit a Brand</a>
        </div>
        <div class="trg-mob-nl">
          <div class="trg-mob-nl-title">The Right Edit</div>
          <div class="trg-mob-nl-text">Curated menswear picks, brand deep-dives, and style notes — delivered weekly.</div>
          <a href="/pages/newsletter" class="trg-mob-nl-btn">Subscribe</a>
        </div>
      </div>

      {%- comment -%}═══ BRANDS TAB ═══{%- endcomment -%}
      <div class="trg-mob-tc" id="trg-mob-tc-brands">
        <div class="trg-mob-bsearch" id="trg-mob-bsearch">
          <div class="trg-mob-bsf">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
            <input type="text" id="trg-mob-bi" class="trg-mob-bin" placeholder="Search 460+ brands…" autocomplete="off" spellcheck="false">
            <button class="trg-mob-bsx" id="trg-mob-bsx" type="button">✕</button>
          </div>
        </div>
        <div class="trg-mob-bchips" data-swipe id="trg-mob-bchips">
          <button class="trg-mob-chip on" data-bcat="all" type="button">All</button>
          {%- for block in section.blocks -%}
            {%- if block.type == 'brand_category' -%}
              {%- liquid
                assign bctt = block.settings.title_override
                if bctt == blank and block.settings.collection != blank
                  assign bctt = block.settings.collection.title
                endif
                if bctt == blank
                  assign bctt = 'Untitled'
                endif
              -%}
              <button class="trg-mob-chip" data-bcat="{{ bctt | handleize }}" type="button">{{ bctt }}</button>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="trg-mob-bcount" id="trg-mob-bcount"></div>
        <div class="trg-mob-bpicks" id="trg-mob-bpicks"></div>
        <div class="trg-mob-brest" id="trg-mob-brest"></div>
      </div>

    </div>
  </div>
</div>


