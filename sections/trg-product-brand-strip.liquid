{% liquid
  assign brand_name = product.vendor
  assign brand_handle = brand_name | handleize

  comment
    Look up the brand metaobject by handle
  endcomment
  assign brand_meta = shop.metaobjects.brand[brand_handle]

  comment
    Pull fields from metaobject
  endcomment
  assign brand_desc = blank
  assign brand_positioning = blank
  assign brand_price = blank
  assign brand_country = blank
  assign brand_made_in = blank
  assign brand_ships_ca = blank
  assign brand_logo_url = blank

  if brand_meta != blank
    assign brand_desc = brand_meta.description.value | default: brand_meta.description
    assign brand_positioning = brand_meta.brand_positioning.value | default: brand_meta.brand_positioning
    assign brand_price = brand_meta.price_range.value | default: brand_meta.price_range
    assign brand_country = brand_meta.country.value | default: brand_meta.country
    assign brand_made_in = brand_meta.made_in.value | default: brand_meta.made_in
    assign brand_ships_ca = brand_meta.ships_to_canada.value | default: brand_meta.ships_to_canada
    assign brand_logo_url = brand_meta.logo.value | default: brand_meta.logo
  endif

  comment
    Build brand collection URL
  endcomment
  assign brand_url = '/collections/' | append: brand_handle

  comment
    Build initials from brand name for logo fallback
  endcomment
  assign brand_words = brand_name | split: ' '
  assign brand_initials = ''
  for word in brand_words
    if forloop.index <= 2
      assign first_char = word | slice: 0, 1 | upcase
      assign brand_initials = brand_initials | append: first_char
    endif
  endfor
  if brand_initials == blank
    assign brand_initials = brand_name | slice: 0, 2 | upcase
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--full-width color-{{ section.settings.color_scheme }} trg-section trg-pdp-brand-strip">
  <div class="trg-brand-strip-inner">
    <div class="trg-brand-strip-logo-wrap">
      {% if brand_logo_url != blank %}
        <img class="trg-brand-strip-logo-img" src="{{ brand_logo_url }}" alt="{{ brand_name | escape }}" loading="lazy">
      {% else %}
        <span class="trg-brand-strip-logo-text">{{ brand_initials }}</span>
      {% endif %}
    </div>

    <div class="trg-brand-strip-info">
      <p class="trg-brand-strip-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="trg-brand-strip-name">{{ brand_name | escape }}</h2>

      {% if brand_desc != blank %}
        <p class="trg-brand-strip-desc">{{ brand_desc }}</p>
      {% endif %}

      <div class="trg-brand-strip-tags">
        {% if brand_positioning != blank %}
          <span class="trg-brand-strip-tag">{{ brand_positioning | escape }}</span>
        {% endif %}
        {% if brand_price != blank %}
          <span class="trg-brand-strip-tag">{{ brand_price | escape }}</span>
        {% endif %}
        {% if brand_made_in != blank %}
          <span class="trg-brand-strip-tag">Made in {{ brand_made_in | escape }}</span>
        {% endif %}
        {% if brand_ships_ca == 'Yes' %}
          <span class="trg-brand-strip-tag trg-brand-strip-tag--ca" data-ca-only>Ships to CA</span>
        {% endif %}
      </div>
    </div>

    <a class="trg-brand-strip-cta" href="{{ brand_url }}">
      {{ section.settings.button_label | default: 'View Brand' | escape }} <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>

{% stylesheet %}
  .trg-pdp-brand-strip {
    padding: 2.5rem 2rem;
  }

  .trg-brand-strip-inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .trg-brand-strip-logo-wrap {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    background: rgba(245,241,235,0.06);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .trg-brand-strip-logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8px;
  }

  .trg-brand-strip-logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--color-foreground, #f5f1eb);
    font-style: italic;
    opacity: 0.8;
  }

  .trg-brand-strip-info {
    flex: 1;
    min-width: 0;
  }

  .trg-brand-strip-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.4;
    margin: 0 0 0.35rem;
  }

  .trg-brand-strip-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
  }

  .trg-brand-strip-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    line-height: 1.55;
    opacity: 0.5;
    max-width: 560px;
    margin: 0;
  }

  .trg-brand-strip-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .trg-brand-strip-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.4;
    border: 1px solid currentColor;
    border-color: rgba(128,128,128,0.2);
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
  }

  .trg-brand-strip-tag--ca {
    display: none;
  }

  body[data-region="CA"] .trg-brand-strip-tag--ca {
    display: inline-block;
  }

  .trg-brand-strip-cta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(128,128,128,0.2);
    padding: 0.6rem 1.1rem;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }

  .trg-brand-strip-cta:hover {
    border-color: rgba(128,128,128,0.5);
  }

  @media (max-width: 749px) {
    .trg-brand-strip-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }

    .trg-brand-strip-cta {
      width: 100%;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Product Brand Strip",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-header-ink"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Brand spotlight"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Brand"
    }
  ],
  "presets": [
    {
      "name": "TRG Product Brand Strip"
    }
  ]
}
{% endschema %}