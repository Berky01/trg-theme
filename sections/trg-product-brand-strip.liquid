{% liquid
  assign brand_name = product.vendor
  assign brand_description = product.metafields.custom.brand_description.value | default: product.metafields.custom.brand_description
  if brand_description == blank
    assign brand_description = product.metafields.custom.brand_bio.value | default: product.metafields.custom.brand_bio
  endif

  assign price_range_tag = product.metafields.custom.price_range.value | default: product.metafields.custom.price_range
  assign commission_tag = product.metafields.custom.commission_rate.value | default: product.metafields.custom.commission_rate
  if commission_tag == blank
    assign commission_tag = product.metafields.custom.est_commission.value | default: product.metafields.custom.est_commission
  endif

  capture tags_source
    if price_range_tag != blank
      echo price_range_tag
    endif
    if commission_tag != blank
      if price_range_tag != blank
        echo ','
      endif
      echo commission_tag
    endif
  endcapture

  assign tags_array = tags_source | split: ','
  capture brand_button_link
    render 'trg-brand-page-url', brand_name: product.vendor, fallback_url: section.settings.button_link
  endcapture
  assign brand_button_link = brand_button_link | strip
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--full-width color-{{ section.settings.color_scheme }} trg-section trg-pdp-brand-strip">
  <div class="trg-shell trg-split-layout" style="grid-template-columns: minmax(0, 1fr) auto; align-items: center;">
    <div data-trg-reveal>
      <p class="trg-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="trg-heading" style="font-size: clamp(1.25rem, 2vw, 1.9rem); margin-top: 6px;">{{ brand_name | escape }}</h2>
      {% if brand_description != blank %}
        <div class="trg-lead" style="margin-top: 8px;">{{ brand_description }}</div>
      {% endif %}

      {% if tags_source != blank %}
        <div class="trg-tag-row" style="margin-top: 12px;">
          {% for raw_tag in tags_array %}
            {% assign tag = raw_tag | strip %}
            {% if tag != blank %}<span class="trg-tag">{{ tag | escape }}</span>{% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.button_label != blank and brand_button_link != blank %}
      <div data-trg-reveal>
        <a class="button" href="{{ brand_button_link }}">{{ section.settings.button_label | escape }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "TRG Product Brand Strip",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Brand spotlight"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name override",
      "info": "Leave blank to use product vendor"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Describe the brand proposition, positioning, and why it appears in your directory.</p>"
    },
    {
      "type": "text",
      "id": "tags",
      "label": "Tags (comma separated)",
      "default": "Mid-range, Affiliate, Ships to Canada"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View brand profile"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "TRG Product Brand Strip"
    }
  ]
}
{% endschema %}
