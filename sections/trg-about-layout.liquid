{%- assign stat_blocks = section.blocks | where: 'type', 'sidebar_stat' -%}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section section--full-width color-{{ section.settings.color_scheme }} trg-section">
  <div class="trg-shell trg-split-layout">
    <div class="trg-main-flow">
      {%- assign principle_number = 0 -%}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'main_text' %}
            <article class="trg-main-block" data-trg-reveal {{ block.shopify_attributes }}>
              {% if block.settings.eyebrow != blank %}<p class="trg-eyebrow">{{ block.settings.eyebrow | escape }}</p>{% endif %}
              {% if block.settings.title != blank %}<div class="trg-main-block__heading">{{ block.settings.title }}</div>{% endif %}
              {% if block.settings.body != blank %}<div class="trg-body-copy trg-reading">{{ block.settings.body }}</div>{% endif %}
            </article>
          {% when 'pull_quote' %}
            <blockquote class="trg-main-block__quote trg-reading" data-trg-reveal {{ block.shopify_attributes }}>
              {{ block.settings.quote | escape }}
            </blockquote>
          {% when 'principle' %}
            {%- assign principle_number = principle_number | plus: 1 -%}
            <article class="trg-principle" data-trg-reveal {{ block.shopify_attributes }}>
              <div class="trg-principle__num">{{ principle_number | prepend: '0' | slice: -2, 2 }}</div>
              <div>
                <p class="trg-principle__title">{{ block.settings.title | escape }}</p>
                <p class="trg-principle__text">{{ block.settings.body | escape }}</p>
              </div>
            </article>
        {% endcase %}
      {% endfor %}
    </div>

    <aside class="trg-sidebar" data-sticky="{{ section.settings.sticky_sidebar }}">
      {% if stat_blocks.size > 0 %}
        <div class="trg-stat-grid" data-trg-reveal>
          {% for block in stat_blocks %}
            <div class="trg-stat-grid__item" {{ block.shopify_attributes }}>
              <p class="trg-stat-grid__value">{{ block.settings.value }}</p>
              <p class="trg-stat-grid__label">{{ block.settings.label | escape }}</p>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'sidebar_card' %}
            <article class="trg-sidebar-card" data-trg-reveal {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<div class="trg-sidebar-card__head">{{ block.settings.heading | escape }}</div>{% endif %}
              <div class="trg-sidebar-card__body trg-body-copy">{{ block.settings.body }}</div>
            </article>
          {% when 'sidebar_cta' %}
            <article class="trg-sidebar-card" data-trg-reveal {{ block.shopify_attributes }}>
              <div class="trg-sidebar-card__body">
                {% if block.settings.title != blank %}<h3 style="margin: 0; font-size: 1.08rem;">{{ block.settings.title }}</h3>{% endif %}
                {% if block.settings.body != blank %}<div class="trg-body-copy">{{ block.settings.body }}</div>{% endif %}
                {% if block.settings.button_label != blank %}
                  <a class="button" href="{{ block.settings.button_link | default: '#' }}">{{ block.settings.button_label | escape }}</a>
                {% endif %}
              </div>
            </article>
        {% endcase %}
      {% endfor %}
    </aside>
  </div>
</section>

{% schema %}
{
  "name": "TRG About Layout",
  "tag": "section",
  "class": "trg-about-layout",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "sticky_sidebar",
      "label": "Sticky sidebar on desktop",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "main_text",
      "name": "Main text block",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Why we built this"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
          "default": "<p>The menswear internet is broken. <em>We are fixing the index.</em></p>"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Use this section for your long-form editorial explanation.</p>"
        }
      ]
    },
    {
      "type": "pull_quote",
      "name": "Pull quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The best wardrobe isn't the biggest one."
        }
      ]
    },
    {
      "type": "principle",
      "name": "Principle",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Quality over completeness"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Focus on durable, high-signal brands instead of an endless directory."
        }
      ]
    },
    {
      "type": "sidebar_stat",
      "name": "Sidebar stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "317+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Brands tracked"
        }
      ]
    },
    {
      "type": "sidebar_card",
      "name": "Sidebar card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Who's behind this"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Independent, editorially curated, and Canada-focused.</p>"
        }
      ]
    },
    {
      "type": "sidebar_cta",
      "name": "Sidebar CTA",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The occasional well-edited email"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>New brands, restocks, and practical shopping intelligence.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Subscribe"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TRG About Layout",
      "blocks": [
        {
          "type": "main_text"
        },
        {
          "type": "pull_quote"
        },
        {
          "type": "main_text"
        },
        {
          "type": "principle"
        },
        {
          "type": "principle"
        },
        {
          "type": "sidebar_stat"
        },
        {
          "type": "sidebar_stat"
        },
        {
          "type": "sidebar_card"
        },
        {
          "type": "sidebar_cta"
        }
      ]
    }
  ]
}
{% endschema %}

