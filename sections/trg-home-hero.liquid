{% liquid
  assign live_catalog = collections['all']
  assign live_catalog_count = 0
  assign secondary_cta_label = section.settings.secondary_label
  if live_catalog != blank
    assign live_catalog_count = live_catalog.all_products_count | default: live_catalog.products_count
  endif
  if section.settings.secondary_link == '/collections/all' and live_catalog_count > 0 and live_catalog_count <= 12
    capture secondary_cta_label
      echo 'Browse '
      echo live_catalog_count
      echo ' live product'
      unless live_catalog_count == 1
        echo 's'
      endunless
    endcapture
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--full-width color-{{ section.settings.color_scheme }} trg-section trg-home-hero trg-home-hero--{{ section.settings.layout_preset }}{% if section.settings.fill_viewport %} trg-home-hero--viewport{% endif %}{% if section.settings.mosaic_left %} trg-home-hero--mosaic-left{% endif %}"
  style="

    --padding-block-start: {{ section.settings.padding_block_start }}px;

    --padding-block-end: {{ section.settings.padding_block_end }}px;

    --trg-hero-left-max: {{ section.settings.left_column_max }}px;

    --trg-hero-bg: {{ section.settings.hero_background }};

    --trg-hero-text: {{ section.settings.hero_text }};

    --trg-hero-accent: {{ section.settings.hero_accent }};

  "

>

  <div class="trg-shell">

    <div class="trg-home-hero__grid">

      <div class="trg-home-hero__left" data-trg-reveal>

        <p class="trg-eyebrow">{{ section.settings.eyebrow | escape }}</p>

        <h1 class="trg-heading">{{ section.settings.heading }}</h1>

        <div class="trg-lead">{{ section.settings.body }}</div>



        <div class="trg-home-hero__actions">

          {% if section.settings.primary_label != blank %}

            <a

              class="trg-hero-btn trg-hero-btn--{{ section.settings.primary_style }}"

              href="{{ section.settings.primary_link | default: '#' }}"

            >

              {{ section.settings.primary_label | escape }}

            </a>

          {% endif %}

          {% if section.settings.secondary_label != blank %}
            <a
              class="trg-hero-btn trg-hero-btn--{{ section.settings.secondary_style }}"
              href="{{ section.settings.secondary_link | default: '#' }}"
            >
              {{ secondary_cta_label | escape }}
            </a>
          {% endif %}
        </div>


        {% assign stats = section.blocks | where: 'type', 'stat' %}
        {% assign dynamic_brand_count = blank %}
        {% if shop.metaobjects.brand != blank %}
          {% assign dynamic_brand_count = shop.metaobjects.brand.values_count %}
        {% endif %}

        {% if stats.size > 0 %}

          <div class="trg-home-hero__stats" style="margin-top: 18px;">

            {% for block in stats %}
              {% assign stat_value = block.settings.value %}
              {% assign stat_suffix = block.settings.suffix %}
              {% assign stat_label_downcase = block.settings.label | downcase %}
              {% assign use_dynamic_brand_count = false %}
              {% if block.settings.use_dynamic_brand_count %}
                {% assign use_dynamic_brand_count = true %}
              {% elsif stat_label_downcase contains 'brand' %}
                {% assign use_dynamic_brand_count = true %}
              {% endif %}
              {% if use_dynamic_brand_count and dynamic_brand_count != blank and dynamic_brand_count > 0 %}
                {% assign stat_value = dynamic_brand_count %}
              {% endif %}

              <div class="trg-stat" {{ block.shopify_attributes }}>

                <p class="trg-stat__value">{{ stat_value | escape }}{% if stat_suffix != blank %}<em>{{ stat_suffix | escape }}</em>{% endif %}</p>

                <p class="trg-stat__label">{{ block.settings.label | escape }}</p>

              </div>

            {% endfor %}

          </div>

        {% endif %}

      </div>



      {% assign cards = section.blocks | where: 'type', 'mosaic_card' %}

      {% if cards.size > 0 %}

        <div class="trg-mosaic" data-trg-reveal>

          {% for block in cards %}

            {% assign bg = 'linear-gradient(140deg, [start], [end])' | replace: '[start]', block.settings.gradient_start | replace: '[end]', block.settings.gradient_end %}

            <a

              class="trg-mosaic__item"

              data-size="{{ block.settings.height }}"

              data-index="{{ forloop.index }}"

              href="{{ block.settings.link | default: '#' }}"

              style="
                --card-zoom: {{ block.settings.zoom | divided_by: 100.0 }};
                --card-focal-x: {{ block.settings.focal_x }}%;
                --card-focal-y: {{ block.settings.focal_y }}%;
                text-decoration: none;
                {% if block.settings.image != blank %}
                  background-image: url('{{ block.settings.image | image_url: width: 1500 }}');
                  background-size: calc(var(--card-zoom, 1) * 100%);
                  background-position: var(--card-focal-x, 50%) var(--card-focal-y, 50%);
                {% else %}
                  background: {{ bg }};
                {% endif %}
              "

              {{ block.shopify_attributes }}

            >



              {% if block.settings.badge != blank %}

                <span class="trg-mosaic__badge">{{ block.settings.badge | escape }}</span>

              {% endif %}



              <div>

                <p class="trg-mosaic__title">{{ block.settings.title | escape }}</p>

                {% if block.settings.meta != blank %}

                  <p class="trg-mosaic__meta">{{ block.settings.meta | escape }}</p>

                {% endif %}

              </div>

            </a>

          {% endfor %}

        </div>

      {% endif %}

    </div>

  </div>

</section>



