{%- comment -%}TRG Brand PDP v3 (page metafields) v1773720735{%- endcomment -%}
{%- liquid
  assign b_name = page.metafields.trg.brand_name | default: page.title
  assign has_brand = false
  if b_name != blank
    assign has_brand = true
  endif
  assign b_slug = page.metafields.trg.slug | default: page.title | handleize
  assign b_cat = page.metafields.trg.primary_category | default: ''
  assign b_country = page.metafields.trg.country | default: ''
  assign b_made = page.metafields.trg.made_in | default: ''
  assign b_price = page.metafields.trg.price_range | default: ''
  assign b_desc = page.metafields.trg.description | default: ''
  assign b_tagline = page.metafields.trg.brand_positioning | default: ''
  assign b_take = page.metafields.trg.trg_take | default: ''
  assign b_materials = page.metafields.trg.known_for_materials | default: ''
  assign b_bestfor = page.metafields.trg.known_for_best_for | default: ''
  assign b_fit = page.metafields.trg.fit_tendency | default: ''
  assign b_sizing = page.metafields.trg.sizing_note | default: ''
  assign b_returns = page.metafields.trg.returns_window | default: ''
  assign b_tags = page.metafields.trg.tags | default: ''
  assign b_buy_path = page.metafields.trg.buy_path | default: 'Direct'
  assign b_website = page.metafields.trg.website | default: '#'
  assign b_aff_link = page.metafields.trg.website | default: '#'
  assign b_ships_ca = page.metafields.trg.ships_to_canada | default: 'Unknown'
  assign b_ddp = page.metafields.trg.ddp_duties | default: ''
  assign b_best_ca = page.metafields.trg.best_retailer_ca | default: ''
  assign b_ret_url_ca = page.metafields.trg.retailer_url_ca | default: '#'
  assign b_free_ca = page.metafields.trg.free_shipping_ca_threshold | default: ''
  assign b_aff_prog = page.metafields.trg.affiliate_program | default: 'No'
  assign b_similar_raw = page.metafields.trg.similar_brands | default: ''
  assign b_initials = b_name | truncate: 2, ''
  assign b_origin_line = b_cat
  if b_country != blank
    if b_origin_line != blank
      assign b_origin_line = b_origin_line | append: ' · ' | append: b_country
    else
      assign b_origin_line = b_country
    endif
  endif
-%}

{%- unless has_brand -%}
<div style="max-width:800px;margin:4rem auto;padding:2rem;text-align:center;">
  <h1 style="font-family:'Playfair Display',serif;font-size:2rem;margin-bottom:1rem;">Brand not found</h1>
  <p style="color:#8a8478;">No brand data found for this page. <a href="/brands" style="color:#c4562a;">Browse all brands &rarr;</a></p>
</div>
{%- else -%}

<!-- HERO -->
<div class="bp-hero">
  <div class="bp-hero-in">
    <div class="bp-hero-c bp-reveal">
      <div class="bp-hero-top">
        {%- if brand.logo -%}
          <div class="bp-logo"><img src="{{ brand.logo | image_url: width: 144 }}" alt="{{ b_name }}" width="72" height="72" style="width:100%;height:100%;object-fit:contain;border-radius:3px;"></div>
        {%- else -%}
          <div class="bp-logo">{{ b_initials }}</div>
        {%- endif -%}
        <div>
          {%- if b_origin_line != blank -%}<div class="bp-origin">{{ b_origin_line }}</div>{%- endif -%}
          <h1 class="bp-name">{{ b_name }}</h1>
        </div>
      </div>
      {%- if b_tagline != blank -%}<p class="bp-tagline">{{ b_tagline }}</p>{%- endif -%}
      <div class="bp-badges">
        {%- if b_made != blank -%}<span class="bp-badge bp-badge-origin">Made in {{ b_made }}</span>{%- endif -%}
        {%- if b_price != blank -%}<span class="bp-badge bp-badge-origin">{{ b_price }}</span>{%- endif -%}
        {%- if b_ships_ca == 'Yes' -%}<span class="bp-badge bp-badge-ca bp-ca-only">🍁 Ships to Canada</span>{%- endif -%}
        {%- if b_ddp == 'Yes' or b_ddp == 'Included' -%}<span class="bp-badge bp-badge-ddp bp-ca-only">Duties Included</span>{%- endif -%}
      </div>
    </div>
    <div class="bp-hero-img">
      {%- if brand.hero_image -%}
        <div class="bp-hero-img-in"><img src="{{ brand.hero_image | image_url: width: 840 }}" alt="{{ b_name }}" loading="eager"></div>
      {%- else -%}
        <div class="bp-hero-img-in"><span class="bp-hero-ph">{{ b_name }}</span></div>
      {%- endif -%}
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="bp-main">

  <!-- LEFT COLUMN -->
  <div class="bp-left bp-reveal-1">

    {%- if b_take != blank -%}
    <!-- TRG Take -->
    <div class="bp-take">
      <div class="bp-take-lbl">The TRG Take</div>
      <div class="bp-take-txt">{{ b_take }}</div>
    </div>
    {%- endif -%}

    {%- if b_desc != blank -%}
    <!-- About -->
    <div class="bp-about">
      <div class="bp-lbl">About the Brand</div>
      <div class="bp-about-txt">{{ b_desc }}</div>
    </div>
    {%- endif -%}

    <!-- Known For -->
    {%- assign has_known = false -%}
    {%- if b_tags != blank or b_materials != blank or b_bestfor != blank or b_fit != blank or b_made != blank -%}
      {%- assign has_known = true -%}
    {%- endif -%}
    {%- if has_known -%}
    <div class="bp-lbl">Known For</div>
    <div class="bp-known">
      <div class="bp-known-in">
        {%- if b_tags != blank -%}
        <div class="bp-kf-row">
          <div class="bp-kf-lbl">Aesthetic</div>
          <div class="bp-kf-val">
            {%- assign tag_list = b_tags | split: ',' -%}
            {%- for t in tag_list -%}
              {%- assign t_clean = t | strip -%}
              {%- if t_clean != blank -%}
                {%- if forloop.index <= 2 -%}
                  <span class="bp-tag bp-tag-a">{{ t_clean }}</span>
                {%- else -%}
                  <span class="bp-tag">{{ t_clean }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        {%- endif -%}
        {%- if b_materials != blank -%}
        <div class="bp-kf-row">
          <div class="bp-kf-lbl">Materials</div>
          <div class="bp-kf-val">
            {%- assign mat_list = b_materials | split: ',' -%}
            {%- for m in mat_list -%}{%- assign mc = m | strip -%}{%- if mc != blank -%}<span class="bp-tag">{{ mc }}</span>{%- endif -%}{%- endfor -%}
          </div>
        </div>
        {%- endif -%}
        {%- if b_bestfor != blank -%}
        <div class="bp-kf-row">
          <div class="bp-kf-lbl">Best For</div>
          <div class="bp-kf-val">
            {%- assign bf_list = b_bestfor | split: ',' -%}
            {%- for bf in bf_list -%}{%- assign bfc = bf | strip -%}{%- if bfc != blank -%}<span class="bp-tag">{{ bfc }}</span>{%- endif -%}{%- endfor -%}
          </div>
        </div>
        {%- endif -%}
        {%- if b_made != blank -%}
        <div class="bp-kf-row">
          <div class="bp-kf-lbl">Made In</div>
          <div class="bp-kf-txt">{{ b_made }}</div>
        </div>
        {%- endif -%}
        {%- if b_fit != blank -%}
        <div class="bp-kf-row">
          <div class="bp-kf-lbl">Fit</div>
          <div class="bp-kf-txt">{{ b_fit }}</div>
        </div>
        {%- endif -%}
      </div>
    </div>
    {%- endif -%}

    <!-- Canada Intelligence (geo-gated accordion) -->
    {%- if b_ships_ca == 'Yes' -%}
    <div class="bp-ca bp-ca-only open" id="bp-ca-intel">
      <button class="bp-ca-tog" type="button" aria-expanded="true" onclick="this.parentElement.classList.toggle('open');this.setAttribute('aria-expanded',this.parentElement.classList.contains('open'))">
        <span class="bp-ca-title">🍁 Canadian Shipping Intelligence</span>
        <svg class="bp-ca-chv" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="bp-ca-body">
        <div class="bp-ca-row">
          <span class="bp-ca-l">Ships direct to Canada</span>
          <span class="bp-ca-v green">✓ Yes</span>
        </div>
        {%- if b_ddp != blank -%}
        <div class="bp-ca-row">
          <span class="bp-ca-l">Duties & taxes</span>
          <span class="bp-ca-v{% if b_ddp == 'Yes' or b_ddp == 'Included' %} green{% endif %}">{% if b_ddp == 'Yes' or b_ddp == 'Included' %}Included (DDP){% else %}{{ b_ddp }}{% endif %}</span>
        </div>
        {%- endif -%}
        {%- if b_free_ca != blank -%}
        <div class="bp-ca-row">
          <span class="bp-ca-l">Free shipping threshold</span>
          <span class="bp-ca-v">{{ b_free_ca }}</span>
        </div>
        {%- endif -%}
        {%- if b_best_ca != blank -%}
        <div class="bp-ca-row">
          <span class="bp-ca-l">Best CA retailer</span>
          <span class="bp-ca-v">{{ b_best_ca }}</span>
        </div>
        {%- endif -%}
        <div class="bp-ca-note">DDP means the price you see is the price you pay — no surprise duties at the door.</div>
      </div>
    </div>
    {%- endif -%}

    <!-- Products from brand (auto-populated) -->
    {%- assign brand_products = collections.all.products | where: 'vendor', b_name -%}
    {%- if brand_products.size > 0 -%}
    <div class="bp-prods">
      <div class="bp-prods-hd">
        <div class="bp-lbl" style="margin-bottom:0;flex:1;">Products</div>
        <a href="/collections/all?filter.p.vendor={{ b_name | url_encode }}" class="bp-va">View all {{ brand_products.size }}<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
      <div class="bp-pgrid">
        {%- for product in brand_products limit: 3 -%}
        <a href="{{ product.url }}" class="bp-pc">
          <div class="bp-pc-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy" width="400" style="width:100%;height:100%;object-fit:cover;">
            {%- else -%}
              {{ b_initials }}
            {%- endif -%}
          </div>
          <div class="bp-pc-body">
            <div class="bp-pc-name">{{ product.title }}</div>
            <div class="bp-pc-price">{{ product.price | money }}</div>
          </div>
        </a>
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    <!-- Similar Brands -->
    {%- if b_similar_raw != blank -%}
    <div class="bp-sim">
      <div class="bp-sim-hd">
        <div class="bp-lbl" style="margin-bottom:0;flex:1;">Similar Brands</div>
        {%- if b_cat != blank -%}<a href="/collections/{{ b_cat | handleize }}" class="bp-va">Browse all {{ b_cat }}<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>{%- endif -%}
      </div>
      <div class="bp-sim-grid">
        {%- assign sim_slugs = b_similar_raw | split: ',' -%}
        {%- for sim_slug_raw in sim_slugs limit: 4 -%}
          {%- assign sim_slug = sim_slug_raw | strip -%}
          {%- for sb in all_brands -%}
            {%- assign sb_slug = sb.slug | default: sb.name | handleize -%}
            {%- if sb_slug == sim_slug -%}
              <a href="/brands/{{ sb_slug }}" class="bp-sc">
                {%- if sb.logo -%}
                  <div class="bp-sc-logo"><img src="{{ sb.logo | image_url: width: 64 }}" alt="{{ sb.name }}" width="32" height="32" style="width:100%;height:100%;object-fit:contain;border-radius:2px;"></div>
                {%- else -%}
                  <div class="bp-sc-logo">{{ sb.name | truncate: 2, '' }}</div>
                {%- endif -%}
                <div class="bp-sc-name">{{ sb.name }}</div>
                <div class="bp-sc-meta">{{ sb.primary_category | default: '' }}{% if sb.country != blank %} · {{ sb.country }}{% endif %}</div>
                <div class="bp-sc-badges">
                  {%- if sb.primary_category != blank -%}<span class="bp-sb bp-sb-style">{{ sb.primary_category }}</span>{%- endif -%}
                  {%- if sb.ships_to_canada == 'Yes' -%}<span class="bp-sb bp-sb-ca bp-ca-only">🍁 CA</span>{%- endif -%}
                </div>
              </a>
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

  </div>

  <!-- RIGHT SIDEBAR -->
  <aside class="bp-side bp-reveal-2">

    <!-- CTA Card -->
    <div class="bp-cta">
      <div class="bp-cta-in">
        <div class="bp-cta-row">
          {%- if brand.logo -%}
            <div class="bp-cta-logo"><img src="{{ brand.logo | image_url: width: 80 }}" alt="{{ b_name }}" width="40" height="40" style="width:100%;height:100%;object-fit:contain;border-radius:2px;"></div>
          {%- else -%}
            <div class="bp-cta-logo">{{ b_initials }}</div>
          {%- endif -%}
          <div>
            <div class="bp-cta-name">{{ b_name }}</div>
            <div class="bp-cta-meta">{{ b_origin_line }}</div>
          </div>
        </div>
        <a href="{{ b_aff_link }}" target="_blank" rel="noopener nofollow" class="bp-btn-1">
          Shop {{ b_name | truncate: 20, '…' }}
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        {%- if b_best_ca != blank -%}
        <a href="{{ b_ret_url_ca | default: '#' }}" target="_blank" rel="noopener nofollow" class="bp-btn-ca bp-ca-only">
          🍁 Shop via {{ b_best_ca }} (CA)
          <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        {%- endif -%}
      </div>
      {%- if b_aff_prog == 'Yes' -%}
      <div class="bp-disc">Links may earn The Right Garment a commission at no cost to you. <a href="/pages/affiliate-disclosure">Disclosure ↗</a></div>
      {%- endif -%}
    </div>

    <!-- Quick Facts -->
    <div class="bp-qf">
      <div class="bp-qf-hd">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Quick Facts
      </div>
      <div class="bp-qf-body">
        {%- if b_price != blank -%}
        <div class="bp-qf-row"><span class="bp-qf-l">Price range</span><span class="bp-qf-v">{{ b_price }}</span></div>
        {%- endif -%}
        {%- if b_made != blank -%}
        <div class="bp-qf-row"><span class="bp-qf-l">Made in</span><span class="bp-qf-v">{{ b_made }}</span></div>
        {%- endif -%}
        {%- if b_returns != blank -%}
        <div class="bp-qf-row"><span class="bp-qf-l">Returns</span><span class="bp-qf-v green">{{ b_returns }}</span></div>
        {%- endif -%}
        {%- if b_ddp != blank -%}
        <div class="bp-qf-row bp-ca-only"><span class="bp-qf-l">Duties to CA</span><span class="bp-qf-v{% if b_ddp == 'Yes' or b_ddp == 'Included' %} green{% endif %}">{% if b_ddp == 'Yes' or b_ddp == 'Included' %}Included (DDP){% else %}{{ b_ddp }}{% endif %}</span></div>
        {%- endif -%}
        {%- if b_free_ca != blank -%}
        <div class="bp-qf-row bp-ca-only"><span class="bp-qf-l">Free CA shipping</span><span class="bp-qf-v">{{ b_free_ca }}</span></div>
        {%- endif -%}
      </div>
    </div>

    {%- if b_sizing != blank -%}
    <!-- Sizing Note -->
    <div class="bp-sz">
      <div class="bp-sz-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div>
      <div>
        <div class="bp-sz-lbl">Sizing Note</div>
        <div class="bp-sz-txt">{{ b_sizing }}</div>
      </div>
    </div>
    {%- endif -%}

  </aside>

</div>
{%- endunless -%}

{% schema %}
{
  "name": "Brand PDP",
  "tag": "div",
  "class": "trg-brand-pdp-shell",
  "limit": 1,
  "settings": [],
  "presets": [{ "name": "Brand PDP" }]
}
{% endschema %}
