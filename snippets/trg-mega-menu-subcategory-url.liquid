{%- liquid
  assign input_title = title | default: ''
  assign title_handle = input_title | handleize
  assign mapped_url = collection_url | default: ''

  if mapped_url == blank
    capture mapped_url
      echo '/collections/'
      echo title_handle
    endcapture

    case title_handle
      when 'casual-shirts'
        assign mapped_url = '/collections/casualwear'
      when 'dress-shirts'
        assign mapped_url = '/collections/mens-dress-shirts'
      when 't-shirts'
        assign mapped_url = '/collections/t-shirts'
      when 'polos'
        assign mapped_url = '/collections/polos'
      when 'overshirts'
        assign mapped_url = '/collections/mens-overshirts'
      when 'camp-collar'
        assign mapped_url = '/collections/shirting'
      when 'henleys'
        assign mapped_url = '/collections/basics'
      when 'linen-summer'
        assign mapped_url = '/collections/linen-clothing'
      when 'field-barn-jacket'
        assign mapped_url = '/collections/mens-field-jackets'
      when 'waxed-cotton'
        assign mapped_url = '/collections/outerwear'
      when 'down-insulated'
        assign mapped_url = '/collections/mens-down-jackets'
      when 'raincoat-mac'
        assign mapped_url = '/collections/mens-rainwear'
      when 'harrington-bomber'
        assign mapped_url = '/collections/mens-harrington-jackets'
      when 'parka'
        assign mapped_url = '/collections/outerwear'
      when 'leather-jacket'
        assign mapped_url = '/collections/outerwear'
      when 'overcoat-topcoat'
        assign mapped_url = '/collections/mens-overcoats'
      when 'chinos'
        assign mapped_url = '/collections/mens-chinos'
      when 'dress-trousers'
        assign mapped_url = '/collections/formalwear'
      when 'shorts'
        assign mapped_url = '/collections/shorts'
      when 'sweatpants-joggers'
        assign mapped_url = '/collections/bottoms'
      when 'corduroy'
        assign mapped_url = '/collections/bottoms'
      when 'cargo-utility'
        assign mapped_url = '/collections/workwear-inspired'
      when 'boots'
        assign mapped_url = '/collections/boots'
      when 'oxford-derby'
        assign mapped_url = '/collections/mens-dress-shoes'
      when 'loafers'
        assign mapped_url = '/collections/mens-loafers'
      when 'sneakers'
        assign mapped_url = '/collections/mens-sneakers'
      when 'moccasins'
        assign mapped_url = '/collections/footwear'
      when 'sandals'
        assign mapped_url = '/collections/sandals'
      when 'bespoke-mto'
        assign mapped_url = '/collections/handwelted-shoes'
      when 'crewneck'
        assign mapped_url = '/collections/knitwear'
      when 'cardigan'
        assign mapped_url = '/collections/knitwear'
      when 'turtleneck'
        assign mapped_url = '/collections/knitwear'
      when 'fisherman-cable'
        assign mapped_url = '/collections/wool-clothing'
      when 'cashmere'
        assign mapped_url = '/collections/cashmere-clothing'
      when 'merino'
        assign mapped_url = '/collections/merino-wool-clothing'
      when 'jeans'
        assign mapped_url = '/collections/jeans'
      when 'denim-jacket'
        assign mapped_url = '/collections/denim'
      when 'raw-selvedge'
        assign mapped_url = '/collections/selvedge-denim'
      when 'slim-tapered'
        assign mapped_url = '/collections/denim'
      when 'straight-relaxed'
        assign mapped_url = '/collections/denim'
      when 'suits'
        assign mapped_url = '/collections/suits'
      when 'sport-coats-blazers'
        assign mapped_url = '/collections/blazers'
      when 'tuxedo-black-tie'
        assign mapped_url = '/collections/formalwear'
      when 'bespoke-mtm'
        assign mapped_url = '/collections/bespoke-menswear'
      when 'waistcoats'
        assign mapped_url = '/collections/formalwear'
      when 'ties-pocket-squares'
        assign mapped_url = '/collections/mens-ties'
      when 'belts'
        assign mapped_url = '/collections/belts'
      when 'bags-leather-goods'
        assign mapped_url = '/collections/bags'
      when 'scarves-hats'
        assign mapped_url = '/collections/mens-hats-and-caps'
      when 'socks-underwear'
        assign mapped_url = '/collections/mens-underwear'
    endcase
  endif

  if mapped_url == blank
    assign mapped_url = fallback_url | default: '/collections/all'
  endif

  echo mapped_url
-%}
