{% comment %}
  TRG Category Icons — Garment-specific SVGs matching mega menu families
  Usage: {% render 'trg-category-icon', type: 'shirts-tops' %}
  Slugs generated via: name | downcase | remove '&' | handleize
{% endcomment %}

{% case type %}

{% when 'shirts-tops' or 'shirts' or 'shirting' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M3 5l3-2h12l3 2-4 3v14H7V8L3 5z"/>
  <path d="M9 3l3 4 3-4"/>
  <line x1="12" y1="7" x2="12" y2="14"/>
</svg>

{% when 'outerwear-jackets' or 'outerwear' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M6 4L2 8v12h6v-8h8v8h6V8l-4-4"/>
  <path d="M9 4c0 1.66 1.34 3 3 3s3-1.34 3-3"/>
  <line x1="12" y1="7" x2="12" y2="12"/>
</svg>

{% when 'trousers-bottoms' or 'trousers' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M6 2h12v6l-2 14h-3L12 12l-1 10H8L6 8V2z"/>
  <line x1="6" y1="7" x2="18" y2="7"/>
</svg>

{% when 'footwear' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M7 3v8c-2 1-4 3-4 5v3c0 1 1 2 2 2h14c1 0 2-1 2-2v-1c0-2-2-3-4-3h-3l-1-4V3H7z"/>
  <line x1="7" y1="8" x2="13" y2="8"/>
</svg>

{% when 'knitwear' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M4 5l4-2h8l4 2 1 5h-3v11H6V10H3L4 5z"/>
  <path d="M8 3c0 2.21 1.79 4 4 4s4-1.79 4-4"/>
  <path d="M9 13c1-1 2 1 3 0s2 1 3 0" stroke-width="1"/>
  <path d="M9 16c1-1 2 1 3 0s2 1 3 0" stroke-width="1"/>
</svg>

{% when 'denim' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M6 2h12v6l-2 14h-3L12 12l-1 10H8L6 8V2z"/>
  <line x1="6" y1="7" x2="18" y2="7"/>
  <path d="M9 8l-0.5 6" stroke-dasharray="1.5 1.5" stroke-width="1" opacity="0.5"/>
  <path d="M15 8l0.5 6" stroke-dasharray="1.5 1.5" stroke-width="1" opacity="0.5"/>
</svg>

{% when 'suits-tailoring' or 'suits' or 'formalwear' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M4 4l3-1h10l3 1 1 16H3L4 4z"/>
  <path d="M9 3l3 5 3-5"/>
  <line x1="12" y1="8" x2="12" y2="20"/>
  <circle cx="12" cy="12" r="0.7" fill="currentColor" stroke="none"/>
  <circle cx="12" cy="15" r="0.7" fill="currentColor" stroke="none"/>
</svg>

{% when 'accessories' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="12" cy="12" r="7"/>
  <circle cx="12" cy="12" r="5" stroke-width="0.8"/>
  <line x1="12" y1="9" x2="12" y2="12"/>
  <line x1="12" y1="12" x2="14.5" y2="13.5"/>
  <rect x="10.5" y="2" width="3" height="3" rx="0.5"/>
  <rect x="10.5" y="19" width="3" height="3" rx="0.5"/>
</svg>

{% when 'casualwear' or 'basics' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M4 5l4-2h8l4 2 1 5h-3v11H6V10H3L4 5z"/>
  <path d="M8 3c0 2.21 1.79 4 4 4s4-1.79 4-4"/>
</svg>

{% when 'workwear' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M5 4L2 7v13h20V7l-3-3"/>
  <path d="M9 4c0 1.66 1.34 3 3 3s3-1.34 3-3"/>
  <rect x="7" y="12" width="4" height="4" rx="0.5"/>
  <rect x="13" y="12" width="4" height="4" rx="0.5"/>
  <line x1="12" y1="7" x2="12" y2="20"/>
</svg>

{% when 'technical' %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M5 4L2 8v12h20V8l-3-4"/>
  <path d="M9 4c0 1.66 1.34 3 3 3s3-1.34 3-3"/>
  <line x1="12" y1="7" x2="12" y2="20" stroke-dasharray="2 2"/>
  <path d="M2 8l4-1" opacity="0.5"/>
  <path d="M22 8l-4-1" opacity="0.5"/>
</svg>

{% else %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
  <rect x="3" y="3" width="18" height="18" rx="2"/>
</svg>

{% endcase %}