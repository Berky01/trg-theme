{%- comment -%}
  TRG Cookie Consent Banner — snippets/trg-cookie-consent.liquid
  Rendered once in theme.liquid body.
  JS: assets/trg-cookie-consent.js (deferred)
{%- endcomment -%}

<div id="trg-cc-banner" hidden aria-live="polite" aria-label="Cookie preferences" role="dialog">
  <div class="trg-cc__inner">
    <div class="trg-cc__text">
      <p>We use cookies and similar technologies to understand how you use our site and to improve your experience. By clicking <strong>Accept</strong>, you consent to analytics and marketing cookies. See our <a href="/pages/privacy-policy">Privacy Policy</a>.</p>
    </div>
    <div class="trg-cc__actions">
      <button id="trg-cc-decline" class="trg-cc__btn trg-cc__btn--decline" type="button">Decline</button>
      <button id="trg-cc-accept" class="trg-cc__btn trg-cc__btn--accept" type="button">Accept</button>
    </div>
  </div>
</div>

<style>
