<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content="#c4562a"
>

{%- liquid
  assign default_site_description = 'A curated menswear directory for quality-conscious buyers, organized by style, price, and origin with editorial review and affiliate transparency.'
  assign rendered_page_title = page_title
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign meta_description_content = page_description
  assign og_description = meta_description_content | default: default_site_description | default: shop.name

  if request.page_type == 'index'
    assign rendered_page_title = 'Curated Menswear Directory'
    assign og_title = rendered_page_title
    assign meta_description_content = default_site_description
    assign og_description = meta_description_content
  endif

  if request.page_type == 'list-collections' or template.name == 'list-collections'
    assign rendered_page_title = 'Browse Menswear Collections'
    assign og_title = rendered_page_title
    assign live_catalog = collections['all']
    assign live_catalog_count = 0

    if live_catalog != blank
      assign live_catalog_count = live_catalog.all_products_count
    endif

    capture meta_description_content
      echo 'Browse menswear collections by category, use the brand directory for label discovery, and navigate the storefront with clearer collection paths.'
      if live_catalog_count > 0 and live_catalog_count <= 12
        echo ' '
        echo live_catalog_count
        if live_catalog_count == 1
          echo ' live product is currently published while the broader catalog is still being loaded.'
        else
          echo ' live products are currently published while the broader catalog is still being loaded.'
        endif
      endif
    endcapture

    assign og_description = meta_description_content
  endif

  if request.page_type == 'search' and search.performed and search.terms != blank
    assign search_products = search.results | where: 'object_type', 'product'
    assign search_product_count = search_products | size

    capture rendered_page_title
      if search_product_count > 0
        echo 'Search products for "'
      else
        echo 'No products found for "'
      endif
      echo search.terms | escape
      echo '"'
    endcapture

    assign og_title = rendered_page_title
  endif

  if request.page_type == 'collection' and collection.handle == 'all' and collection.all_products_count > 0 and collection.all_products_count <= 12
    assign live_catalog_count = collection.all_products_count

    capture rendered_page_title
      echo 'Browse the Live Assortment'
    endcapture

    assign og_title = rendered_page_title

    capture meta_description_content
      echo live_catalog_count
      if live_catalog_count == 1
        echo ' live product is currently available while the broader product catalog is being staged.'
      else
        echo ' live products are currently available while the broader product catalog is being staged.'
      endif
    endcapture

    assign og_description = meta_description_content
  endif

  if request.page_type == 'collection' and collection.handle != 'all' and collection.metafields.trg.brand.value == blank and collection.all_products_count > 0
    assign live_catalog = collections['all']
    assign live_catalog_count = 0

    if live_catalog != blank
      assign live_catalog_count = live_catalog.all_products_count
    endif

    if live_catalog_count > 0 and live_catalog_count <= 12
      capture meta_description_content
        echo collection.title
        echo ' currently has '
        echo collection.all_products_count
        if collection.all_products_count == 1
          echo ' live product published while the broader catalog is still being loaded.'
        else
          echo ' live products published while the broader catalog is still being loaded.'
        endif
      endcapture

      assign og_description = meta_description_content
    endif
  endif

  if request.page_type == 'collection' and collection.handle != 'all' and collection.metafields.trg.brand.value == blank and collection.all_products_count == 0
    assign live_catalog = collections['all']
    assign live_catalog_count = 0

    if live_catalog != blank
      assign live_catalog_count = live_catalog.all_products_count
    endif

    if live_catalog_count > 0 and live_catalog_count <= 12
      capture meta_description_content
        echo collection.title
        echo ' is staged for the broader catalog. '
        echo live_catalog_count
        if live_catalog_count == 1
          echo ' live product is currently published while the wider assortment is still being loaded.'
        else
          echo ' live products are currently published while the wider assortment is still being loaded.'
        endif
      endcapture

      assign og_description = meta_description_content
    endif
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

<title>
  {{ rendered_page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless rendered_page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{% if meta_description_content %}
  <meta
    name="description"
    content="{{ meta_description_content | escape }}"
  >
{% endif %}
