<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content="#b8491f"
>

{%- liquid
  assign default_site_description = 'A menswear directory for quality-conscious buyers, organized by style, price, and origin with editorial review and affiliate transparency.'
  assign rendered_page_title = page_title
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign meta_description_content = page_description | default: default_site_description
  assign og_description = meta_description_content | default: default_site_description | default: shop.name
  assign should_noindex = false

  if request.page_type == 'index'
    assign rendered_page_title = 'Menswear Directory'
    assign og_title = rendered_page_title
    assign meta_description_content = default_site_description
    assign og_description = meta_description_content
  endif

  if request.page_type == 'page' and page.handle == 'brands'
    assign rendered_page_title = 'Brand Directory'
    assign og_title = rendered_page_title
    assign meta_description_content = 'Browse the menswear brand directory by category, price, origin, and shipping behavior. Editorially reviewed with affiliate transparency.'
    assign og_description = meta_description_content
  endif

  if request.page_type == 'list-collections' or template.name == 'list-collections'
    assign rendered_page_title = 'Browse Menswear Collections'
    assign og_title = rendered_page_title
    assign meta_description_content = 'Browse menswear collections by category, use the brand directory for label discovery, and navigate the storefront with clearer collection paths.'
    assign og_description = meta_description_content
  endif

  if request.page_type == 'search' and search.performed and search.terms != blank
    assign search_products = search.results | where: 'object_type', 'product'
    assign search_product_count = search_products | size

    capture rendered_page_title
      if search_product_count > 0
        echo 'Search results for "'
      else
        echo 'No results for "'
      endif
      echo search.terms | escape
      echo '"'
    endcapture

    assign og_title = rendered_page_title
    assign meta_description_content = default_site_description
    assign og_description = meta_description_content
  endif

  if request.page_type == 'collection'
    assign brand_metaobject = collection.metafields.trg.brand.value
    assign brand_desc = blank
    if brand_metaobject != blank
      assign brand_desc = brand_metaobject.description
    endif

    assign collection_seo_desc = collection.metafields.global.description_tag | default: collection.description
    if brand_desc != blank
      assign meta_description_content = brand_desc | strip_html | truncate: 300
    elsif collection_seo_desc != blank
      assign meta_description_content = collection_seo_desc | strip_html | truncate: 300
    elsif brand_metaobject != blank
      capture meta_description_content
        echo 'Shop '
        echo collection.title
        echo ' menswear at The Right Garment. Browse the '
        echo collection.title
        echo ' catalogue with editorial review and affiliate transparency.'
      endcapture
    else
      assign meta_description_content = default_site_description
    endif

    if brand_metaobject != blank
      capture rendered_page_title
        echo collection.title
        echo ' brand directory'
      endcapture
    elsif collection.handle == 'all'
      assign rendered_page_title = 'Browse the Live Assortment'
    else
      assign rendered_page_title = collection.title
    endif
    assign og_title = rendered_page_title
    assign og_description = meta_description_content

    comment
      Brand PLPs use metaobject-driven product lists, so collection.all_products_count is always 0 — auto-noindex disabled. Use a per-collection metafield if specific brands need noindex.
    endcomment
  endif

  if request.page_type == 'blog'
    assign rendered_page_title = blog.title | default: 'Journal'
    assign og_title = rendered_page_title
    assign blog_seo_desc = blog.metafields.global.description_tag
    if blog_seo_desc != blank
      assign meta_description_content = blog_seo_desc | strip_html | truncate: 300
    else
      assign meta_description_content = 'Editorial features, brand profiles, and shopping intelligence from The Right Garment.'
    endif
    assign og_description = meta_description_content
  endif

  if request.page_type == 'article'
    assign rendered_page_title = article.title
    assign og_title = rendered_page_title
    assign article_seo_desc = article.metafields.global.description_tag | default: article.excerpt
    if article_seo_desc != blank
      assign meta_description_content = article_seo_desc | strip_html | truncate: 300
    else
      assign meta_description_content = default_site_description
    endif
    assign og_description = meta_description_content
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

<title>
  {{ rendered_page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless rendered_page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{% if meta_description_content %}
  <meta
    name="description"
    content="{{ meta_description_content | escape }}"
  >
{% endif %}

{%- if should_noindex -%}
  <meta name="robots" content="noindex,follow">
{%- endif -%}

{%- if request.page_type == 'index' -%}
  {%- capture website_search_url -%}{{ shop.url }}/search?q={search_term_string}{%- endcapture -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | append: '/' | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ website_search_url | json }}
        },
        "query-input": "required name=search_term_string"
      }
    }
  </script>
{%- endif -%}

{%- if request.page_type == 'collection' and should_noindex == false -%}
  {%- assign coll_breadcrumb_name = collection.title -%}
  {%- assign coll_breadcrumb_url = shop.url | append: collection.url -%}
  {%- assign coll_section_name = 'Collections' -%}
  {%- assign coll_section_url = shop.url | append: '/collections' -%}
  {%- if collection.metafields.trg.brand.value != blank -%}
    {%- assign coll_section_name = 'Brands' -%}
    {%- assign coll_section_url = shop.url | append: '/pages/brands' -%}
  {%- endif -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": {{ rendered_page_title | json }},
      "description": {{ meta_description_content | json }},
      "url": {{ coll_breadcrumb_url | json }},
      "isPartOf": {
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | append: '/' | json }}
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | append: '/' | json }} },
        { "@type": "ListItem", "position": 2, "name": {{ coll_section_name | json }}, "item": {{ coll_section_url | json }} },
        { "@type": "ListItem", "position": 3, "name": {{ coll_breadcrumb_name | json }}, "item": {{ coll_breadcrumb_url | json }} }
      ]
    }
  </script>
{%- endif -%}

{%- if request.page_type == 'blog' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": {{ blog.title | default: 'Journal' | json }},
      "url": {{ shop.url | append: blog.url | json }},
      "description": {{ meta_description_content | json }},
      "publisher": {
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | append: '/' | json }}
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | append: '/' | json }} },
        { "@type": "ListItem", "position": 2, "name": {{ blog.title | default: 'Journal' | json }}, "item": {{ shop.url | append: blog.url | json }} }
      ]
    }
  </script>
{%- endif -%}

{%- if request.page_type == 'article' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | append: '/' | json }} },
        { "@type": "ListItem", "position": 2, "name": {{ blog.title | default: 'Journal' | json }}, "item": {{ shop.url | append: blog.url | json }} },
        { "@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }} }
      ]
    }
  </script>
{%- endif -%}
