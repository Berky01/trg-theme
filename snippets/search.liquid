{%- doc -%}
  Renders the search action button.

  @param {string} [style] - The style of the search action.
  @param {string} [class] - Additional classes for the search action.
  @example
  {% render 'search', style: 'default', class: 'custom-class' %}
{%- enddoc -%}

{% unless style == 'none' %}
  <div class="search-action{% if class != blank %} {{ class | strip }}{% endif %}">
    <button
      type="button"
      class="button-unstyled header-actions__action trg-header-search-trigger"
      aria-label="{{ 'content.search_input_label' | t }}"
      aria-expanded="false"
      data-trg-nav-search-trigger
    >
      <span class="svg-wrapper" aria-hidden="true">
        {{ 'icon-search.svg' | inline_asset_content }}
      </span>
    </button>
  </div>
{% endunless %}

{% stylesheet %}
  .search-action {
    display: flex;
  }

  @media screen and (max-width: 749px) {
    .search-action--hidden-on-drawer {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    [data-menu-style='drawer'] .search-action--hidden-on-drawer {
      display: none;
    }

    [data-menu-style='menu'] .search-action--hidden-on-menu {
      display: none;
    }
  }

  [data-menu-style='menu'] .header__column--left .search-action {
    @media screen and (min-width: 750px) {
      margin-inline: calc(var(--padding-lg) * -1);
    }
  }

  .header__column--right .search-action {
    @media screen and (min-width: 750px) {
      margin-inline: calc(var(--gap-md) * -1) calc(var(--gap-xs) * -1);
    }
  }

  .trg-header-search-trigger {
    width: 32px;
    height: 32px;
    align-items: center;
    border-radius: 2px;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .trg-header-search-trigger:hover,
  .trg-header-search-trigger.is-open {
    color: rgb(var(--color-foreground-rgb));
  }

  .trg-header-search-trigger.is-open {
    background: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .trg-header-search-trigger:focus-visible {
    outline: 2px solid #c4562a;
    outline-offset: 2px;
  }

  .trg-header-search-trigger.header-actions__action .svg-wrapper {
    width: 16px;
    height: 16px;
  }

  .trg-header-search-trigger.header-actions__action svg {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}
