<a class="trg-brand-card" href="{{ card_link | default: '#' }}" data-trg-reveal {% if shopify_attributes != blank %}{{ shopify_attributes }}{% endif %}>
  <div class="trg-brand-card__badges">
    {% if card_badge_1 != blank %}
      <span class="trg-brand-badge trg-brand-badge--canada">{{ card_badge_1 | escape }}</span>
    {% endif %}
    {% if card_badge_2 != blank %}
      <span class="trg-brand-badge trg-brand-badge--affiliate">{{ card_badge_2 | escape }}</span>
    {% endif %}
  </div>

  <div class="trg-brand-logo">
    {% if card_logo != blank %}
      {{
        card_logo
        | image_url: width: 120
        | image_tag:
          loading: 'lazy',
          widths: '60, 80, 120',
          sizes: '44px',
          alt: card_title
      }}
    {% else %}
      <span>{{ card_logo_text | default: card_title | slice: 0, 2 | upcase }}</span>
    {% endif %}
  </div>

  <h3 class="trg-brand-name">{{ card_title | escape }}</h3>
  {% if card_origin != blank %}
    <p class="trg-brand-origin">{{ card_origin | escape }}</p>
  {% endif %}
  {% if card_body != blank %}
    <p class="trg-brand-body">{{ card_body | escape }}</p>
  {% endif %}

  <div class="trg-brand-footer">
    {% if card_price_tag != blank %}
      <span class="trg-brand-price">{{ card_price_tag | escape }}</span>
    {% endif %}
    <span class="trg-brand-cta">
      {{ card_cta_label | default: 'View' | escape }}
      <span aria-hidden="true">→</span>
    </span>
  </div>
</a>
