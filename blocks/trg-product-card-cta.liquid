{% liquid
  assign product = closest.product
  assign brand_label = product.vendor | default: 'Brand'
  assign prefix = block.settings.label | default: 'via'
  assign buy_path = blank
  assign retailer_name = blank
  assign is_trg_plp = false

  if section.settings.trg_plp_shell_max_width != blank
    assign is_trg_plp = true
  endif

  if product != blank
    assign buy_path = product.metafields.custom.buy_path.value | default: product.metafields.custom.buy_path
    if buy_path == blank
      assign buy_path = product.metafields.custom.buyPath.value | default: product.metafields.custom.buyPath
    endif
    if buy_path == blank
      assign buy_path = product.metafields.custom.purchase_path.value | default: product.metafields.custom.purchase_path
    endif
    if buy_path == blank
      assign buy_path = product.metafields.custom.purchasePath.value | default: product.metafields.custom.purchasePath
    endif

    assign retailer_name = product.metafields.custom.retailer.value | default: product.metafields.custom.retailer
    if retailer_name == blank
      assign retailer_name = product.metafields.custom.retailer_name.value | default: product.metafields.custom.retailer_name
    endif
    if retailer_name == blank
      assign retailer_name = product.metafields.custom.stockist.value | default: product.metafields.custom.stockist
    endif
    if retailer_name == blank
      assign retailer_name = product.metafields.custom.retailerName.value | default: product.metafields.custom.retailerName
    endif

    if buy_path == blank or retailer_name == blank
      for tag in product.tags
        assign normalized_tag = tag | downcase | strip

        if buy_path == blank
          if normalized_tag contains 'buy-path:'
            assign buy_path = normalized_tag | remove: 'buy-path:' | strip
          elsif normalized_tag contains 'buy path:'
            assign buy_path = normalized_tag | remove: 'buy path:' | strip
          elsif normalized_tag == 'direct' or normalized_tag == 'reseller'
            assign buy_path = normalized_tag
          endif
        endif

        if retailer_name == blank
          if normalized_tag contains 'retailer:'
            assign retailer_name = tag | remove_first: 'retailer:' | strip
          elsif normalized_tag contains 'stockist:'
            assign retailer_name = tag | remove_first: 'stockist:' | strip
          endif
        endif
      endfor
    endif

    if buy_path == blank
      assign buy_path = 'direct'
    endif

    if retailer_name == blank
      assign retailer_name = brand_label
    endif
  endif
%}

{% if product != blank and is_trg_plp %}
  <div class="trg-plp-card-cta-block" {{ block.shopify_attributes }}>
    {% if buy_path == 'reseller' and retailer_name != blank %}
      <p class="trg-plp-card-retailer">
        {{ prefix | escape }}
        <strong>{{ retailer_name | escape }}</strong>
      </p>
    {% endif %}
    <a class="trg-plp-card-shop-cta" href="{{ product.selected_or_first_available_variant.url }}">
      <span>
        {% if buy_path == 'reseller' %}
          Buy at {{ retailer_name | escape }}
        {% else %}
          Shop {{ brand_label | escape }}
        {% endif %}
      </span>
      <span aria-hidden="true">↗</span>
    </a>
  </div>
{% endif %}

{% schema %}
{
  "name": "TRG product CTA",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Retailer prefix",
      "default": "via"
    }
  ]
}
{% endschema %}
