{% liquid
  assign product = closest.product

  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  if product != blank
    assign material = product.metafields.custom.material_type
    assign made_in = product.metafields.custom.made_in_country
    assign fit = product.metafields.custom.style_aesthetic
    assign season = product.metafields.custom.season
    assign category = product.type
    assign brand = product.vendor
  endif
%}

{% if product != blank %}
  <div class="trg-product-meta" {{ block.shopify_attributes }}>
    {% if material != blank %}
      <div class="trg-product-meta__row">
        <span class="trg-product-meta__key">Material</span>
        <span class="trg-product-meta__val">{{ material }}</span>
      </div>
    {% endif %}

    {% if made_in != blank %}
      <div class="trg-product-meta__row">
        <span class="trg-product-meta__key">Made In</span>
        <span class="trg-product-meta__val">{{ made_in }}</span>
      </div>
    {% endif %}

    {% if fit != blank %}
      <div class="trg-product-meta__row">
        <span class="trg-product-meta__key">Style</span>
        <span class="trg-product-meta__val">{{ fit }}</span>
      </div>
    {% endif %}

    {% if season != blank %}
      <div class="trg-product-meta__row">
        <span class="trg-product-meta__key">Season</span>
        <span class="trg-product-meta__val">{{ season }}</span>
      </div>
    {% endif %}

    {% if category != blank %}
      <div class="trg-product-meta__row">
        <span class="trg-product-meta__key">Category</span>
        <span class="trg-product-meta__val">{{ category | escape }}</span>
      </div>
    {% endif %}

    {% if brand != blank %}
      <div class="trg-product-meta__row">
        <span class="trg-product-meta__key">Brand</span>
        <span class="trg-product-meta__val">{{ brand | escape }}</span>
      </div>
    {% endif %}
  </div>
{% endif %}

{% stylesheet %}
  .trg-product-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .trg-product-meta__row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 0.82rem;
  }

  .trg-product-meta__key {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8478;
    min-width: 80px;
    flex-shrink: 0;
  }

  .trg-product-meta__val {
    color: #1a1a18;
    font-weight: 300;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Product Meta",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "TRG Product Meta"
    }
  ]
}
{% endschema %}
