{%- liquid
  assign product = closest.product

  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign buy_path = product.metafields.trg.buy_path.value | default: product.metafields.trg.buy_path
  assign buy_path = buy_path | default: 'Direct' | strip
  assign buy_path_normalized = buy_path | downcase

  assign vendor_name = product.vendor | default: product.title | default: 'Brand'

  assign buy_url_us = product.metafields.trg.buy_url.value | default: product.metafields.trg.buy_url
  assign buy_url_us = buy_url_us | default: product.metafields.trg.affiliate_link.value | default: product.metafields.trg.affiliate_link
  assign buy_url_ca = product.metafields.trg.buy_url_ca.value | default: product.metafields.trg.buy_url_ca | default: buy_url_us
  assign retailer_name_us = product.metafields.trg.retailer_name_us.value | default: product.metafields.trg.retailer_name_us
  assign retailer_name_us = retailer_name_us | default: product.metafields.trg.best_retailer_na.value | default: product.metafields.trg.best_retailer_na
  assign retailer_url_us = product.metafields.trg.retailer_url_us.value | default: product.metafields.trg.retailer_url_us
  assign retailer_name_ca = product.metafields.trg.retailer_name_ca.value | default: product.metafields.trg.retailer_name_ca
  assign retailer_name_ca = retailer_name_ca | default: product.metafields.trg.best_retailer_ca.value | default: product.metafields.trg.best_retailer_ca
  assign retailer_url_ca = product.metafields.trg.retailer_url_ca.value | default: product.metafields.trg.retailer_url_ca

  assign show_direct_cta = false
  assign show_both_cta = false
  assign show_reseller_cta = false

  if buy_path_normalized == 'both'
    assign show_both_cta = true
  elsif buy_path_normalized == 'reseller only' or buy_path_normalized == 'reseller-only' or buy_path_normalized == 'reseller_only' or buy_path_normalized == 'reseller'
    assign show_reseller_cta = true
  else
    assign show_direct_cta = true
  endif

  # ── CA FALLBACKS ──────────────────────────────────────────────────────────
  # For Both + Reseller: if CA retailer is missing, fall back to US retailer
  assign effective_retailer_name_ca = retailer_name_ca
  assign effective_retailer_url_ca  = retailer_url_ca
  if effective_retailer_url_ca == blank
    assign effective_retailer_name_ca = retailer_name_us
    assign effective_retailer_url_ca  = retailer_url_us
  endif

  # ── HAS_CTA FLAGS ─────────────────────────────────────────────────────────
  assign has_us_cta = false
  assign has_ca_cta = false

  if show_direct_cta and buy_url_us != blank
    assign has_us_cta = true
  endif
  if show_direct_cta and buy_url_ca != blank
    assign has_ca_cta = true
  endif

  if show_both_cta
    if buy_url_us != blank or retailer_url_us != blank
      assign has_us_cta = true
    endif
    if buy_url_ca != blank or effective_retailer_url_ca != blank
      assign has_ca_cta = true
    endif
  endif

  if show_reseller_cta
    if retailer_url_us != blank
      assign has_us_cta = true
    endif
    if effective_retailer_url_ca != blank
      assign has_ca_cta = true
    endif
  endif
-%}

<div class="trg-affiliate-cta" {{ block.shopify_attributes }}>

  {%- comment -%} ── US MARKET ──────────────────────────────────────────── {%- endcomment -%}
  <div class="trg-affiliate-cta__market trg-affiliate-cta__market--us">
    {%- if has_us_cta -%}

      {%- if show_direct_cta and buy_url_us != blank -%}
        <a href="{{ buy_url_us }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--primary">
          <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ vendor_name | escape }}</span></span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      {%- endif -%}

      {%- if show_both_cta -%}
        {%- if buy_url_us != blank -%}
          <a href="{{ buy_url_us }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--primary">
            <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ vendor_name | escape }}</span></span>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        {%- endif -%}
        {%- if retailer_name_us != blank and retailer_url_us != blank -%}
          <div class="trg-affiliate-cta__divider"><span>Also sold at</span></div>
          <a href="{{ retailer_url_us }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--secondary">
            <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ retailer_name_us | escape }}</span></span>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        {%- endif -%}
      {%- endif -%}

      {%- if show_reseller_cta and retailer_name_us != blank and retailer_url_us != blank -%}
        <a href="{{ retailer_url_us }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--primary">
          <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ retailer_name_us | escape }}</span></span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      {%- endif -%}

    {%- else -%}
      <p class="trg-affiliate-cta__unavailable">No direct link available — search <strong>{{ product.title | escape }}</strong> at your preferred retailer.</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── CA MARKET ──────────────────────────────────────────── {%- endcomment -%}
  <div class="trg-affiliate-cta__market trg-affiliate-cta__market--ca">
    {%- if has_ca_cta -%}

      {%- if show_direct_cta and buy_url_ca != blank -%}
        <a href="{{ buy_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--primary">
          <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ vendor_name | escape }}</span></span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      {%- endif -%}

      {%- if show_both_cta -%}
        {%- if buy_url_ca != blank -%}
          <a href="{{ buy_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--primary">
            <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ vendor_name | escape }}</span></span>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        {%- endif -%}
        {%- if effective_retailer_url_ca != blank -%}
          <div class="trg-affiliate-cta__divider"><span>Also sold at</span></div>
          <a href="{{ effective_retailer_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--secondary">
            <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ effective_retailer_name_ca | escape }}</span></span>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        {%- endif -%}
        <p class="trg-affiliate-cta__ca-note">Ships to Canada via retailer. Duties may apply at delivery.</p>
      {%- endif -%}

      {%- if show_reseller_cta and effective_retailer_url_ca != blank -%}
        <a href="{{ effective_retailer_url_ca }}" target="_blank" rel="noopener sponsored" class="trg-affiliate-cta__btn trg-affiliate-cta__btn--primary">
          <span class="trg-affiliate-cta__label">Buy at <span class="trg-affiliate-cta__retailer">{{ effective_retailer_name_ca | escape }}</span></span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <p class="trg-affiliate-cta__ca-note">Ships to Canada via {{ effective_retailer_name_ca | escape }}. Duties may apply at delivery.</p>
      {%- endif -%}

    {%- else -%}
      <p class="trg-affiliate-cta__unavailable">No Canadian link available — search <strong>{{ product.title | escape }}</strong> at your preferred retailer.</p>
    {%- endif -%}
  </div>

  <p class="trg-affiliate-cta__disclosure">Affiliate link — TRG may earn a commission at no extra cost to you</p>

</div>

{% stylesheet %}
  .trg-affiliate-cta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .trg-affiliate-cta__market {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .trg-affiliate-cta__market--ca {
    display: none;
  }

  body[data-region='ca'] .trg-affiliate-cta__market--us {
    display: none;
  }

  body[data-region='ca'] .trg-affiliate-cta__market--ca {
    display: flex;
  }

  /* ── Primary button (brand direct / reseller-only) ── */
  .trg-affiliate-cta__btn--primary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.5rem;
    background: #c4562a;
    color: #ffffff;
    text-decoration: none;
    border-radius: 2px;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s;
    border: none;
    cursor: pointer;
  }

  .trg-affiliate-cta__btn--primary:hover {
    background: #b34d24;
    color: #ffffff;
  }

  /* ── Secondary button (retailer, Both path) ── */
  .trg-affiliate-cta__btn--secondary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: #ffffff;
    color: #1a1a18;
    text-decoration: none;
    border-radius: 2px;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: border-color 0.2s;
    border: 1px solid #ddd8cf;
    cursor: pointer;
  }

  .trg-affiliate-cta__btn--secondary:hover {
    border-color: #1a1a18;
    color: #1a1a18;
  }

  .trg-affiliate-cta__label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .trg-affiliate-cta__retailer {
    color: inherit;
  }

  /* ── "Also sold at" divider ── */
  .trg-affiliate-cta__divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8a8478;
    margin: 0.1rem 0;
  }

  .trg-affiliate-cta__divider::before,
  .trg-affiliate-cta__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #ddd8cf;
  }

  /* ── CA contextual note ── */
  .trg-affiliate-cta__ca-note {
    font-size: 0.72rem;
    color: #8a8478;
    line-height: 1.4;
    padding: 0.5rem 0.75rem;
    background: rgba(212, 41, 26, 0.04);
    border: 1px solid rgba(212, 41, 26, 0.12);
    border-radius: 2px;
  }

  .trg-affiliate-cta__disclosure {
    font-size: 0.7rem;
    color: #8a8478;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .trg-affiliate-cta__unavailable {
    font-size: 0.82rem;
    color: #8a8478;
    font-weight: 300;
    font-style: italic;
    padding: 0.75rem 0;
  }
{% endstylesheet %}

{% schema %}
