{%- liquid
  assign product = closest.product

  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  if product != blank
    assign affiliate_url = product.metafields.custom.buy_url
    assign retailer_name = product.metafields.custom.retailer | default: product.vendor
  endif
-%}

{% if product != blank %}
  <div class="trg-affiliate-cta" {{ block.shopify_attributes }}>
    {% if affiliate_url != blank %}
      <a
        href="{{ affiliate_url }}"
        target="_blank"
        rel="noopener sponsored"
        class="trg-affiliate-cta__btn"
      >
        <span class="trg-affiliate-cta__label">Shop at {{ retailer_name | escape }}</span>
        <span class="trg-affiliate-cta__arrow" aria-hidden="true">→</span>
      </a>
      <p class="trg-affiliate-cta__disclosure">
        Affiliate link — we may earn a commission
      </p>
    {% else %}
      <p class="trg-affiliate-cta__unavailable">
        No direct link available — search "{{ product.title | escape }}" at your preferred retailer.
      </p>
    {% endif %}
  </div>
{% endif %}

{% stylesheet %}
  .trg-affiliate-cta__btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem 1.5rem;
    background: #1a1a18;
    color: #f5f1eb;
    text-decoration: none;
    border-radius: 2px;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s;
  }

  .trg-affiliate-cta__btn:hover {
    background: #c4562a;
  }

  .trg-affiliate-cta__arrow {
    font-size: 1.1rem;
    font-weight: 300;
  }

  .trg-affiliate-cta__disclosure {
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: #8a8478;
    font-weight: 300;
  }

  .trg-affiliate-cta__unavailable {
    font-size: 0.82rem;
    color: #8a8478;
    font-weight: 300;
    font-style: italic;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Affiliate CTA",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "TRG Affiliate CTA"
    }
  ]
}
{% endschema %}
