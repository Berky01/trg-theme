{%- liquid
  assign product = closest.product

  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign buy_url_us = product.metafields.trg.buy_url
  assign buy_url_ca = product.metafields.trg.buy_url_ca
  assign retailer_name = product.metafields.trg.retailer_name | default: product.vendor
-%}

<div
  class="trg-affiliate-cta"
  data-buy-url-us="{{ buy_url_us }}"
  data-buy-url-ca="{{ buy_url_ca | default: buy_url_us }}"
  data-retailer="{{ retailer_name | escape }}"
  {{ block.shopify_attributes }}
>
  {%- if buy_url_us != blank or buy_url_ca != blank -%}
    <a
      href="{{ buy_url_us }}"
      target="_blank"
      rel="noopener sponsored"
      class="trg-affiliate-cta__btn"
      id="trg-affiliate-btn-{{ block.id }}"
    >
      <span class="trg-affiliate-cta__label">
        Shop at <span class="trg-affiliate-cta__retailer">{{ retailer_name }}</span>
      </span>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    </a>
    <p class="trg-affiliate-cta__disclosure">
      Affiliate link — TRG may earn a commission at no extra cost to you
    </p>
  {%- else -%}
    <p class="trg-affiliate-cta__unavailable">
      No direct link available — search
      <strong>{{ product.title }}</strong>
      at your preferred retailer.
    </p>
  {%- endif -%}
</div>

<script>
  (function() {
    var el = document.getElementById('trg-affiliate-btn-{{ block.id }}');
    if (!el) return;
    var wrap = el.closest('[data-buy-url-us]');
    if (!wrap) return;
    var isCA = document.body.getAttribute('data-region') === 'CA';
    var url = isCA
      ? (wrap.getAttribute('data-buy-url-ca') || wrap.getAttribute('data-buy-url-us'))
      : wrap.getAttribute('data-buy-url-us');
    if (url) el.setAttribute('href', url);
  })();
</script>

{% stylesheet %}
  .trg-affiliate-cta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .trg-affiliate-cta__btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.5rem;
    background: #1a1a18;
    color: #f5f1eb;
    text-decoration: none;
    border-radius: 2px;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s;
    border: none;
    cursor: pointer;
  }

  .trg-affiliate-cta__btn:hover {
    background: #c4562a;
    color: #ffffff;
  }

  .trg-affiliate-cta__label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .trg-affiliate-cta__retailer {
    color: inherit;
  }

  .trg-affiliate-cta__disclosure {
    font-size: 0.7rem;
    color: #8a8478;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .trg-affiliate-cta__unavailable {
    font-size: 0.82rem;
    color: #8a8478;
    font-weight: 300;
    font-style: italic;
    padding: 0.75rem 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TRG Affiliate CTA",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "TRG Affiliate CTA"
    }
  ]
}
{% endschema %}
