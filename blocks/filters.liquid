    .filters-sidebar .price-facet {
      gap: 0;
    }

    .filters-sidebar .price-facet__inputs-wrapper {
      padding: 0;
      gap: 0.75rem;
    }

    .filters-sidebar .price-facet__field {
      flex: 1 1 0;
      min-width: 0;
    }

    .filters-sidebar .field__input.price-facet__input {
      height: 48px;
      border: 1px solid var(--border, #ddd8cf);
      background: #fff;
      font-size: 1rem;
      padding-right: 0.85rem;
      padding-left: 2rem;
    }

    .filters-sidebar .price-facet__label {
      color: var(--mid, #8a8478);
      padding: 0.85rem 0.75rem;
    }

    .filters-sidebar .price-facet__separator {
      color: var(--mid, #8a8478);
      font-size: 0.95rem;
    }

    .filters-sidebar .price-facet__highest-price {
      padding: 0.9rem 0 0.15rem;
      color: var(--mid, #8a8478);
      font-size: 0.9rem;
      line-height: 1.45;
    }

    .filters-sidebar .facets__drawer-actions {
      padding: 1rem 1.25rem 1.25rem;
      background: var(--warm-white, #faf8f4);
      box-shadow: none;
    }

    .filters-sidebar .facets__clear-all {
      display: none !important;
    }

    .filters-sidebar .facets__see-results {
      min-height: 50px;
      border-radius: 0;
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .trg-plp-sidebar-hide-btn {
      display: none !important;
    }
  }

  @media screen and (max-width: 989px) {
    .trg-plp-body .trg-collection-controls.trg-collection-controls {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.75rem 0 0.85rem;
    }

    .trg-plp-body .trg-plp-show-filters-btn {
      display: inline-flex !important;
      align-items: center;
      gap: 0.45rem;
      padding: 0.6rem 0.95rem;
      border: 1px solid var(--trg-plp-border-color, #ddd8cf);
      border-radius: 2px;
      background: #ffffff;
      color: var(--trg-plp-muted-color, #8a8478);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .trg-plp-body .trg-plp-show-filters-btn .svg-wrapper,
    .trg-plp-body .trg-plp-show-filters-btn svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    .trg-plp-body .trg-collection-controls .products-count-wrapper {
      display: none !important;
    }
  }

  /* Status */
  .facets__status:not(:empty) {
    width: max-content;
    display: flex;
    margin-inline-start: auto;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .facets__panel[open] .facets__status {
    display: none;
  }

  .facets--filters-title {
    margin-block-end: 0;
    color: var(--color-foreground);
    height: fit-content;

    @media screen and (max-width: 749px) {
      display: none;
    }
  }

  .facets--horizontal .facets__panel .facets__status:has(:not(:empty)) {
    @media screen and (min-width: 750px) {
      display: flex;
      margin-inline-start: var(--margin-xs);
      margin-inline-end: var(--margin-xs);
    }
  }

  /* Horizontal filter style */
  .facets--horizontal .facets__form {
    @media screen and (min-width: 750px) {
      gap: 0 var(--facets-form-horizontal-gap);
    }
  }

  /* Facets - Actions */
  .facets__drawer-actions {
    --to-top-gradient-background: linear-gradient(
      to top,
      rgb(var(--color-background-rgb) / var(--opacity-90)),
      rgb(var(--color-background-rgb) / var(--opacity-80)),
      rgb(var(--color-background-rgb) / var(--opacity-40)),
      transparent
    );

    position: sticky;
    bottom: 0;
    z-index: var(--facets-sticky-z-index);
    order: 1;
    display: flex;
    flex-shrink: 0;
    justify-content: space-between;
    align-items: stretch;
    gap: var(--gap-sm);
    padding-block-start: var(--padding-xs);
    padding-block-end: var(--padding-md);
    padding-inline: var(--padding-lg);
    margin-top: auto;
    background-image: var(--to-top-gradient-background);
    background-color: var(--color-background);
  }

  /* Clear all button */
  .facets__clear-all {
    display: none;
    cursor: pointer;
    min-width: var(--facets-clear-all-min-width);
    flex-grow: 1;
    padding-block: var(--padding-lg);
    color: var(--button-color, inherit);
  }

  .facets__clear-all--active {
    display: block;
    opacity: 1;
    transform: translateY(0);
    transition: transform var(--animation-values), opacity var(--animation-values);
  }

  @starting-style {
    .facets__clear-all--active {
      opacity: 0;
      transform: translateY(100%);
    }
  }

  .facets__see-results {
    min-width: var(--facets-see-results-min-width);
    flex-grow: 1;
    padding-block: var(--padding-lg);
  }

  .facets-horizontal-remove {
    display: flex;
    align-items: center;
  }

  .facets-horizontal-remove--active::before {
    content: '';
    border-inline-start: var(--style-border-width) solid var(--color-border);
    height: var(--font-paragraph--size);
    position: absolute;
  }

  @media screen and (max-width: 989px) {
    .trg-plp-body .trg-collection-controls.trg-collection-controls {
      display: flex !important;
    }
  }

  @media screen and (max-width: 989px) {
    /* ═══════════════════════════════════════
       TRG FILTER DRAWER — full design system
       Targets dialog-component#filters-drawer only.
       Works with all Shopify Search & Discovery filter types.
    ═══════════════════════════════════════ */

    /* Dialog shell */
    dialog-component#filters-drawer dialog.facets--drawer {
      background: #faf8f4;
      color: #1a1a18;
      border: none;
      border-radius: 0;
      padding: 0;
      margin: 0;
      inset: 0;
      width: 100vw;
      max-width: 100vw;
      height: 100dvh;
      max-height: 100dvh;
      display: flex;
      flex-direction: column;
      font-family: var(--font-body--family, 'DM Sans', sans-serif);
    }

    /* Header */
    dialog-component#filters-drawer .facets__title-wrapper {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem 0.85rem;
      border-bottom: 1px solid #ddd8cf;
      background: #faf8f4;
      position: sticky;
      top: 0;
      z-index: 2;
      flex-shrink: 0;
    }

    dialog-component#filters-drawer .facets-drawer__title {
      font-family: var(--font-heading--family, 'Playfair Display', serif);
      font-size: 1.2rem;
      font-weight: 400;
      color: #1a1a18;
      margin: 0;
      letter-spacing: 0;
      text-transform: none;
      line-height: 1;
    }

    dialog-component#filters-drawer .facets-drawer__close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      background: none;
      border: none;
      color: #8a8478;
      cursor: pointer;
      padding: 0;
      border-radius: 2px;
      transition: color 0.15s;
    }

    dialog-component#filters-drawer .facets-drawer__close:hover {
      color: #1a1a18;
    }

    /* Active filter count bubble */
    dialog-component#filters-drawer .facets__bubble {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 17px;
      height: 17px;
      margin-left: 0.4rem;
      background: #c4562a;
      color: white;
      border-radius: 50%;
      font-size: 0.62rem;
      font-weight: 600;
      vertical-align: middle;
    }

    /* Scrollable body */
    dialog-component#filters-drawer .facets-drawer__filters {
      flex: 1 1 auto;
      overflow-y: auto;
      padding: 0 1.25rem 1.5rem;
      scrollbar-width: thin;
      scrollbar-color: #ddd8cf transparent;
    }

    /* ── Filter groups (all types: list, price, boolean, swatch) ── */
    dialog-component#filters-drawer .facets__filters-wrapper {
      display: flex;
      flex-direction: column;
    }

    dialog-component#filters-drawer .facets__item {
      padding: 1rem 0 0;
      margin: 0;
      border-top: 1px solid #e8e3db;
    }

    dialog-component#filters-drawer .facets__item:first-child {
      border-top: none;
      padding-top: 0.75rem;
    }

    /* Group header (collapsible summary) */
    dialog-component#filters-drawer .facets__summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 0 0.65rem;
      background: transparent;
      cursor: pointer;
      list-style: none;
      min-height: auto;
    }

    dialog-component#filters-drawer .facets__summary:hover {
      background: transparent;
    }

    dialog-component#filters-drawer .facets__summary::-webkit-details-marker {
      display: none;
    }

    dialog-component#filters-drawer .facets__label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #8a8478;
      line-height: 1;
    }

    dialog-component#filters-drawer .facets__status {
      font-size: 0.65rem;
      color: #c4562a;
    }

    /* Chevron icon */
    dialog-component#filters-drawer .facets__summary .icon-caret,
    dialog-component#filters-drawer .facets__summary svg {
      width: 12px;
      height: 12px;
      color: #8a8478;
      transition: transform 0.2s;
    }

    dialog-component#filters-drawer details[open] > .facets__summary svg {
      transform: rotate(180deg);
    }

    /* Filter options container */
    dialog-component#filters-drawer .facets__panel-content,
    dialog-component#filters-drawer .facets__inputs-wrapper {
      padding: 0 0 0.75rem;
      border: none;
      box-shadow: none;
      background: transparent;
      position: static;
      min-width: 0;
    }

    dialog-component#filters-drawer .facets__inputs-list {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      padding: 0;
      margin: 0;
      list-style: none;
    }

    dialog-component#filters-drawer .facets__inputs-list-item {
      padding: 0;
    }

    dialog-component#filters-drawer .checkbox {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.25rem 0;
      cursor: pointer;
    }

    dialog-component#filters-drawer .checkbox__input {
      position: absolute;
      opacity: 0;
      width: 15px;
      height: 15px;
      margin: 0;
      top: 50%;
      left: 0;
      transform: translateY(-50%);
      z-index: 1;
      cursor: pointer;
    }

    dialog-component#filters-drawer .checkbox__label > svg,
    dialog-component#filters-drawer .checkbox__label > .svg-wrapper {
      display: none !important;
    }

    dialog-component#filters-drawer .checkbox__label {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      font-size: 0.9rem;
      color: #1a1a18;
      cursor: pointer;
      line-height: 1.3;
      width: 100%;
      padding-left: 22px;
      position: relative;
    }

    dialog-component#filters-drawer .checkbox__label::before {
      content: '' !important;
      display: block !important;
      position: absolute !important;
      left: 0 !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      width: 15px !important;
      height: 15px !important;
      border: 1.5px solid #ddd8cf !important;
      border-radius: 2px !important;
      background: white !important;
      box-shadow: none !important;
      transition: background 0.15s, border-color 0.15s !important;
      pointer-events: none !important;
      z-index: 0 !important;
    }

    dialog-component#filters-drawer .checkbox__input:checked
      ~ .checkbox__label::before,
    dialog-component#filters-drawer .checkbox.checkbox--checked
      .checkbox__label::before {
      background: #1a1a18 !important;
      border-color: #1a1a18 !important;
      box-shadow: inset 0 0 0 3px white !important;
    }

    dialog-component#filters-drawer .checkbox__input:disabled
      ~ .checkbox__label {
      opacity: 0.38;
    }

    dialog-component#filters-drawer .checkbox__label-text {
      flex: 1;
      color: inherit;
    }

    dialog-component#filters-drawer .trg-facet-count {
      margin-left: auto;
      color: #8a8478;
      font-size: 0.75rem;
      flex-shrink: 0;
    }

    /* ── Swatch filters ── */
    dialog-component#filters-drawer .facets__swatch {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      border: 1.5px solid #ddd8cf;
      flex-shrink: 0;
    }

    /* ── Price range filter ── */
    dialog-component#filters-drawer .price-facet {
      container-type: normal;
    }

    dialog-component#filters-drawer .price-facet__inputs-wrapper {
      display: grid !important;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      align-items: center;
      gap: 0.5rem;
      padding: 0;
      flex-wrap: nowrap !important;
    }

    dialog-component#filters-drawer .price-facet__field,
    dialog-component#filters-drawer .field {
      min-width: 0;
      width: 100%;
    }

    dialog-component#filters-drawer .price-facet__field .field__input,
    dialog-component#filters-drawer .field__input {
      border: 1px solid #ddd8cf;
      border-radius: 2px;
      background: white;
      font-size: 0.88rem;
      color: #1a1a18;
      padding: 0.55rem 0.5rem 0.55rem 1.6rem;
      min-height: 38px;
      width: 100%;
    }

    dialog-component#filters-drawer .price-facet__separator {
      color: #8a8478;
      font-size: 0.82rem;
      white-space: nowrap;
      text-align: center;
    }

    dialog-component#filters-drawer .price-facet__highest-price {
      color: #8a8478;
      font-size: 0.72rem;
      padding-top: 0.5rem;
      line-height: 1.4;
    }

    dialog-component#filters-drawer .price-facet__label,
    dialog-component#filters-drawer .field__currency {
      color: #8a8478;
      font-size: 0.82rem;
    }

    /* ── Sorting inside drawer ── */
    dialog-component#filters-drawer .sorting-filter {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid #e8e3db;
    }

    dialog-component#filters-drawer .sorting-filter .facets__summary {
      padding-bottom: 0.5rem;
    }

    dialog-component#filters-drawer .sorting-filter .sorting-filter__status {
      font-size: 0.82rem;
      color: #1a1a18;
    }

    /* ── TRG toggle filters (Ships CA, On Sale, New) ── */
    dialog-component#filters-drawer .trg-plp-toggle-filters {
      padding: 0.75rem 0 1rem;
      border-bottom: 1px solid #e8e3db;
      margin-bottom: 0.25rem;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    dialog-component#filters-drawer .trg-plp-toggle-option {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 0.4rem 0;
      background: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
      text-align: left;
    }

    dialog-component#filters-drawer .trg-plp-toggle-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.88rem;
      color: #8a8478;
      transition: color 0.15s;
    }

    dialog-component#filters-drawer .trg-plp-toggle-option[aria-pressed='true'] .trg-plp-toggle-label {
      color: #1a1a18;
    }

    dialog-component#filters-drawer .trg-plp-canada-dot {
      width: 7px;
      height: 7px;
      background: #d4291a;
      border-radius: 50%;
      flex-shrink: 0;
    }

    dialog-component#filters-drawer .trg-plp-toggle-switch {
      width: 32px;
      height: 18px;
      background: #ddd8cf;
      border-radius: 999px;
      position: relative;
      flex-shrink: 0;
      transition: background 0.2s;
    }

    dialog-component#filters-drawer .trg-plp-toggle-switch::after {
      content: '';
      position: absolute;
      top: 2px;
      left: 2px;
      width: 14px;
      height: 14px;
      background: white;
      border-radius: 50%;
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.2);
      transition: transform 0.2s;
    }

    dialog-component#filters-drawer .trg-plp-toggle-option[aria-pressed='true'] .trg-plp-toggle-switch {
      background: #1a1a18;
    }

    dialog-component#filters-drawer .trg-plp-toggle-option[aria-pressed='true'][data-trg-toggle='ships-ca'] .trg-plp-toggle-switch {
      background: #d4291a;
    }

    dialog-component#filters-drawer .trg-plp-toggle-option[aria-pressed='true'] .trg-plp-toggle-switch::after {
      transform: translateX(14px);
    }

    /* ── Bottom action bar ── */
    dialog-component#filters-drawer .facets__drawer-actions {
      display: flex;
      align-items: stretch;
      gap: 0.65rem;
      padding: 1rem 1.25rem max(1.25rem, env(safe-area-inset-bottom));
      border-top: 1px solid #ddd8cf;
      background: #faf8f4;
      flex-shrink: 0;
      position: sticky;
      bottom: 0;
      z-index: 2;
    }

    dialog-component#filters-drawer .facets__clear-all {
      display: none;
      flex: 1;
      padding: 0.75rem 1rem;
      border: 1.5px solid #1a1a18;
      border-radius: 2px;
      background: transparent;
      color: #1a1a18;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.15s, color 0.15s;
      text-align: center;
    }

    dialog-component#filters-drawer .facets__clear-all--active {
      display: block;
    }

    dialog-component#filters-drawer .facets__clear-all:hover {
      background: #1a1a18;
      color: #f5f1eb;
    }

    dialog-component#filters-drawer .facets__see-results {
      flex: 2;
      padding: 0.75rem 1rem;
      background: #c4562a;
      color: white;
      border: none;
      border-radius: 2px;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: inherit;
      text-align: center;
      transition: background 0.15s;
    }

    dialog-component#filters-drawer .facets__see-results:hover {
      background: #b04a22;
    }
  }

  /* TRG FIX: prevent sidebar drop on desktop filter apply — align-self keeps sticky anchor */
  @media screen and (min-width: 990px) {
    .facets-block-wrapper--vertical {
      align-self: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.filters",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "t:settings.enable_filtering",
      "info": "t:info.enable_filtering_info",
      "default": false
    },
    {
      "type": "select",
      "id": "filter_style",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "horizontal",
          "label": "t:options.horizontal"
        },
        {
          "value": "vertical",
          "label": "t:options.vertical"
        }
      ],
      "default": "horizontal",
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "select",
      "id": "filter_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered",
      "visible_if": "{{ block.settings.enable_filtering == true and block.settings.filter_style == 'horizontal' }}"
    },
    {
      "type": "select",
      "id": "text_label_case",
      "label": "t:settings.text_label_case",
      "options": [
        {
          "value": "default",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "default",
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "show_swatch_label",
      "label": "t:settings.show_swatch_label",
      "default": false,
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "show_filter_label",
      "label": "t:settings.show_filter_label",
      "default": false,
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "t:settings.enable_sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_grid_density",
      "label": "t:settings.enable_grid_density",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.margin"
    },
    {
      "type": "range",
      "id": "facets_margin_bottom",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ block.settings.filter_style == 'horizontal' }}"
    },
    {
      "type": "range",
      "id": "facets_margin_right",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ block.settings.filter_style == 'vertical' }}"
    }
  ]
}
{% endschema %}
