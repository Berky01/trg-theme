{%- layout 'theme' -%}

<style>
  .trg-auth-wrap {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: var(--paper, #f5f1eb);
  }
  .trg-auth {
    background: #fff;
    width: 100%;
    max-width: 400px;
    padding: 2rem 1.5rem;
  }
  .trg-auth__logo {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    text-align: center;
    margin-bottom: 1.25rem;
    color: var(--ink, #1a1a18);
  }
  .trg-auth__logo span { color: var(--accent, #c4562a); font-style: italic; }
  .trg-auth__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 400;
    text-align: center;
    margin-bottom: 0.3rem;
  }
  .trg-auth__desc {
    font-size: 0.78rem;
    color: var(--mid, #8a8478);
    font-weight: 300;
    text-align: center;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  .trg-auth__field { margin-bottom: 0.75rem; }
  .trg-auth__field label {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mid, #8a8478);
    margin-bottom: 0.3rem;
  }
  .trg-auth__field input {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--border, #ddd8cf);
    border-radius: 2px;
    background: var(--warm-white, #faf8f4);
    color: var(--ink, #1a1a18);
    outline: none;
  }
  .trg-auth__field input:focus { border-color: var(--accent, #c4562a); }
  .trg-auth__btn {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.75rem;
    border-radius: 2px;
    cursor: pointer;
    border: none;
    background: var(--accent, #c4562a);
    color: #fff;
    margin-top: 0.5rem;
    transition: opacity 0.2s;
  }
  .trg-auth__btn:hover { opacity: 0.88; }
  .trg-auth__footer {
    font-size: 0.72rem;
    color: var(--mid, #8a8478);
    font-weight: 300;
    text-align: center;
    margin-top: 1.25rem;
  }
  .trg-auth__footer a { color: var(--accent, #c4562a); text-decoration: none; }
  .trg-auth__errors {
    background: rgba(196,86,42,0.08);
    border: 1px solid rgba(196,86,42,0.2);
    padding: 0.6rem 0.8rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    color: var(--accent, #c4562a);
    border-radius: 2px;
  }
</style>

<div class="trg-auth-wrap">
  <div class="trg-auth">
    <div class="trg-auth__logo">The Right <span>Garment</span></div>
    <div class="trg-auth__title">Welcome back</div>
    <div class="trg-auth__desc">Sign in to manage your followed brands and wishlist.</div>

    {% form 'customer_login' %}
      {% if form.errors %}
        <div class="trg-auth__errors">{{ form.errors | default_errors }}</div>
      {% endif %}
      <div class="trg-auth__field">
        <label for="CustomerEmail">Email</label>
        <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" autocapitalize="off" placeholder="you@example.com" autofocus>
      </div>
      <div class="trg-auth__field">
        <label for="CustomerPassword">Password</label>
        <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" placeholder="••••••••">
      </div>
      <button type="submit" class="trg-auth__btn">Sign In</button>
    {% endform %}

    <div class="trg-auth__footer">
      Don't have an account? <a href="{{ routes.account_register_url }}">Create one</a><br>
      <a href="#" onclick="document.getElementById('recover').style.display='block'; this.closest('.trg-auth__footer').style.display='none'; return false;">Forgot password?</a>
    </div>

    <div id="recover" style="display:none; margin-top:1rem;">
      {% form 'recover_customer_password' %}
        <div class="trg-auth__field">
          <label for="RecoverEmail">Email</label>
          <input type="email" id="RecoverEmail" name="email" placeholder="you@example.com" autocomplete="email">
        </div>
        <button type="submit" class="trg-auth__btn">Reset Password</button>
      {% endform %}
    </div>
  </div>
</div>
