<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
<script>
/* TRG focus fix - must load before Dwell's focus.js to win capture phase */
document.addEventListener('focusin',function(e){
  if(e.target&&e.target.closest&&e.target.closest('#trg-mob,#trg-mob-search-float,#trg-body-search')){
    e.stopImmediatePropagation();
  }
},true);
</script>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
{%- comment -%}TRG SEO â€” OG/Twitter (G1), meta description fallback (G2){%- endcomment -%}
{%- capture _trg_desc -%}{%- if template.name == 'collection' -%}Shop {{ collection.title }} at The Right Garment â€” curated menswear from 470+ vetted brands.{%- elsif template.name == 'product' -%}{{ product.title }} by {{ product.vendor }}. Discover more at The Right Garment.{%- elsif template.name == 'article' -%}{{ article.title }} â€” The Right Garment Journal.{%- else -%}The Right Garment â€” curated menswear brand directory. 470+ brands, vetted and organised.{%- endif -%}{%- endcapture -%}
{%- assign _trg_meta_desc = page_description | default: _trg_desc | strip | truncate: 160 -%}
{%- unless page_description -%}<meta name="description" content="{{ _trg_meta_desc | escape }}">{%- endunless -%}
<meta property="og:site_name" content="The Right Garment">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:type" content="{%- if template.name == 'product' -%}product{%- elsif template.name == 'article' -%}article{%- else -%}website{%- endif -%}">
<meta property="og:title" content="{{ page_title | escape }}">
<meta property="og:description" content="{{ _trg_meta_desc | escape }}">
{%- if page_image -%}<meta property="og:image" content="{{ page_image | image_url: width: 1200 }}"><meta property="og:image:width" content="1200">{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | escape }}">
<meta name="twitter:description" content="{{ _trg_meta_desc | escape }}">
{%- if page_image -%}<meta name="twitter:image" content="{{ page_image | image_url: width: 1200 }}">{%- endif -%}
    {%- render 'stylesheets' -%}
    {{ 'trg-mega-menu.css' | asset_url | stylesheet_tag }}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {{ 'trg-card-shared.css' | asset_url | stylesheet_tag }}
    {{ 'trg-audit-fixes.css' | asset_url | stylesheet_tag }}
    {%- if request.page_type == 'product' -%}{{ 'trg-pdp-v1.css' | asset_url | stylesheet_tag }}{%- endif -%}
    {%- if customer or template == 'customers/account' or template == 'customers/login' -%}<link rel="stylesheet" href="{{ 'trg-account.css' | asset_url }}" media="print" onload="this.media='all'">{%- endif -%}
    {%- if template.name == 'collection' or template.name == 'search' -%}{{ 'trg-plp.css' | asset_url | stylesheet_tag }}{%- endif -%}
    {%- if template.name == 'collection' -%}{{ 'trg-theme-overrides.css' | asset_url | stylesheet_tag }}{%- endif -%}
    {% if template == 'page.brands-directory' %}{{ 'trg-brand-directory.css' | asset_url | stylesheet_tag }}{% endif %}

    {% if template == 'page.colour-guide' %}{{ 'trg-colour-guide.css' | asset_url | stylesheet_tag }}{% endif %}
    {%- if customer or template == 'customers/account' or template == 'customers/login' -%}<script src="{{ 'trg-account.js' | asset_url }}" defer></script>{%- endif -%}
    {%- if template.name == 'collection' or template.name == 'search' -%}<script src="{{ 'trg-plp.js' | asset_url }}" defer></script>{%- endif -%}
    {%- comment -%}TRG SEO â€” noindex non-public pages (G8){%- endcomment -%}
    {%- if template == 'customers/account' or template == 'customers/login' or template == 'customers/register' or template == 'customers/order' or template == 'customers/addresses' or template == 'page.my-account' or template == 'page.newsletter' or collection.handle == 'brand-test1' -%}<meta name="robots" content="noindex, nofollow">{%- endif -%}
